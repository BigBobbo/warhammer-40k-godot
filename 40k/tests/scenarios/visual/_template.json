{
  "id": "T##_<slug>",
  "covers": ["design_guidelines.T##"],
  "fixture": "<fixture_name_or_omit>",
  "rng_seed": 42,
  "transition_to_phase": 7,
  "description": "What this task verifies. Reference the doc section.",

  "regions": {
    "<region_name>": [0, 0, 1920, 1080]
  },

  "steps": [
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "screenshot",   "label": "T##_before" },

    { "act": "dispatch_action", "action": { "type": "<ACTION_TYPE>" } },
    { "act": "expect_action_result", "path": "success", "equals": true },

    { "act": "execute_script",
      "script": "<expression returning a value>",
      "equals": "<expected>" },

    { "act": "screenshot", "label": "T##_after" },

    { "act": "pixel_diff",
      "before": "T##_before",
      "after":  "T##_after",
      "region": "<region_name>",
      "expect_min_pct": 1.0 },

    { "act": "expect_baseline_unchanged" }
  ]
}
