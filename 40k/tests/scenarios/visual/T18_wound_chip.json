{
  "id": "T18_wound_chip",
  "covers": ["design_guidelines.T18", "tokens.wound_chip"],
  "fixture": "co_pretrigger",
  "transition_to_phase": 10,
  "description": "TokenVisual.update_wound_chip(current, max). Multi-wound: wound_chip_text 'N/M' and WoundChip visible. Single-wound: chip hidden, wound_chip_text ''.",

  "steps": [
    { "act": "wait_seconds", "seconds": 0.4 },

    { "act": "expect_token_visible", "unit_id": "U_WARBOSS_B", "timeout_s": 3.0 },

    { "act": "execute_script",
      "script": "main.get_node(\"BoardRoot/TokenLayer\").get_child(0).wound_chip_text",
      "equals": "" },

    { "act": "execute_script",
      "script": "main.get_node(\"BoardRoot/TokenLayer\").get_child(0).update_wound_chip(3, 5)" },
    { "act": "execute_script",
      "script": "main.get_node(\"BoardRoot/TokenLayer\").get_child(0).wound_chip_text",
      "equals": "3/5" },
    { "act": "execute_script",
      "script": "main.get_node(\"BoardRoot/TokenLayer\").get_child(0).get_node(\"WoundChip\").visible",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node(\"BoardRoot/TokenLayer\").get_child(0).get_node(\"WoundChip\").text",
      "equals": "3/5" },

    { "act": "execute_script",
      "script": "main.get_node(\"BoardRoot/TokenLayer\").get_child(0).update_wound_chip(1, 1)" },
    { "act": "execute_script",
      "script": "main.get_node(\"BoardRoot/TokenLayer\").get_child(0).wound_chip_text",
      "equals": "" },
    { "act": "execute_script",
      "script": "main.get_node(\"BoardRoot/TokenLayer\").get_child(0).get_node(\"WoundChip\").visible",
      "equals": false },

    { "act": "expect_baseline_unchanged" }
  ]
}
