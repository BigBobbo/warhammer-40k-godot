{
  "id": "T09_exhaustion_grayscale",
  "covers": [
    "design_guidelines.T09",
    "tokens.exhaustion"
  ],
  "fixture": "co_pretrigger",
  "transition_to_phase": 7,
  "description": "Per-phase exhaustion: TokenVisual.set_exhausted_this_phase(true) sets modulate to Color(0.6,0.6,0.6,1). PhaseManager.phase_changed clears the flag and restores Color(1,1,1,1).",
  "steps": [
    {
