      "seconds": 0.4
    },
    {
      "act": "expect_token_visible",
      "unit_id": "U_WARBOSS_B",
      "timeout_s": 3.0
    },
    {
      "act": "execute_script",
      "script": "main.get_node(\"BoardRoot/TokenLayer\").get_child(0).is_exhausted_this_phase",
      "equals": false
    },
    {
      "act": "execute_script",
      "script": "main.get_node(\"BoardRoot/TokenLayer\").get_child(0).modulate.to_html(true)",
      "equals": "ffffffff"
    },
    {
      "act": "execute_script",
      "script": "main.get_node(\"BoardRoot/TokenLayer\").get_child(0).set_exhausted_this_phase(true)"
    },
    {
      "act": "execute_script",
      "script": "main.get_node(\"BoardRoot/TokenLayer\").get_child(0).is_exhausted_this_phase",
      "equals": true
    },
    {
      "act": "execute_script",
      "script": "main.get_node(\"BoardRoot/TokenLayer\").get_child(0).modulate.to_html(true)",
      "equals": "999999ff"
    },
    {
      "act": "execute_script",
      "script": "main.get_node(\"BoardRoot/TokenLayer\").get_child(1).is_exhausted_this_phase",
      "equals": false
    },
    {
      "act": "execute_script",
      "script": "main.get_node(\"BoardRoot/TokenLayer\").get_child(1).modulate.to_html(true)",
      "equals": "ffffffff"
    },
    {
      "act": "execute_script",
      "script": "PhaseManager.emit_signal(\"phase_changed\", 8)"
    },
    {
      "act": "wait_frames",
      "frames": 3
    },
    {
      "act": "execute_script",
      "script": "main.get_node(\"BoardRoot/TokenLayer\").get_child(0).is_exhausted_this_phase",
      "equals": false
    },
    {
      "act": "execute_script",
      "script": "main.get_node(\"BoardRoot/TokenLayer\").get_child(0).modulate.to_html(true)",
      "equals": "ffffffff"
    },
    {
      "act": "execute_script",
      "script": "main.fit_view_to_board()"
    },
    {
      "act": "wait_seconds",
      "seconds": 3.0
    },
    {
      "act": "screenshot",
      "label": "T09_review"
    },
    {
      "act": "expect_baseline_unchanged"
    }
  ]
