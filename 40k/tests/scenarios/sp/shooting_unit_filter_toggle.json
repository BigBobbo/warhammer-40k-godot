{
  "id": "shooting_unit_filter_toggle",
  "covers": [
    "shooting.select_shooter_filter",
    "settings.shooting_show_all_units",
    "scripts.ShootingController.show_all_units_checkbox"
  ],
  "fixture": "audit_383_battleshock_shoot",
  "rng_seed": 42,
  "transition_to_phase": 8,
  "description": "SELECT SHOOTER list filter: by default the shooting panel lists only units that can actually act this phase (an eligible shooting target or a mission action). The two Witchseekers squads carry only 12-inch flamers with every Ork 25\"+ away, so they have no eligible targets and no mission action — the default filter hides both. The panel exposes a 'Show all units' checkbox (labelled with the hidden count) that flips the filter off, revealing every unit that could shoot. Drives the real checkbox with a mouse click, asserts the Witchseekers appear/disappear and the setting persists, and confirms a board-token click still selects a hidden targetless unit (so the filter never makes a friendly token dead).",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "expect_state", "path": "meta.phase", "equals": 8 },
    { "act": "expect_state", "path": "meta.active_player", "equals": 1 },

    { "act": "execute_script", "script": "SettingsService.set_shooting_show_all_units(false)" },
    { "act": "execute_script", "script": "main.get_node(\"ShootingController\")._refresh_unit_list(false)" },
    { "act": "execute_script", "script": "SettingsService.get_shooting_show_all_units()", "equals": false },
    { "act": "screenshot", "label": "01_filtered_default" },

    { "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().unit_has_shooting_phase_activity(\"U_WITCHSEEKERS_C\")",
      "equals": false },
    { "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().unit_has_shooting_phase_activity(\"U_WITCHSEEKERS_D\")",
      "equals": false },

    { "act": "execute_script",
      "script": "is_instance_valid(main.get_node(\"ShootingController\").show_all_units_checkbox)",
      "equals": true },
    { "act": "expect_node_visible",
      "node": "/root/Main/HUD_Right/VBoxContainer/ShootingScrollContainer/ShootingPanel/DeclarationBox/ShowAllUnitsCheckbox",
      "timeout_s": 2.0 },
    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").show_all_units_checkbox.button_pressed",
      "equals": false },

    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\")._is_unit_in_shooter_list(\"U_WITCHSEEKERS_C\")",
      "equals": false },
    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\")._is_unit_in_shooter_list(\"U_WITCHSEEKERS_D\")",
      "equals": false },

    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").show_all_units_checkbox.text.contains(\"hidden\")",
      "equals": true },
    { "act": "execute_script",
      "script": "set_meta(\"filtered_count\", main.get_node(\"ShootingController\").unit_selector.get_item_count())" },

    { "act": "click_node",
      "node": "/root/Main/HUD_Right/VBoxContainer/ShootingScrollContainer/ShootingPanel/DeclarationBox/ShowAllUnitsCheckbox" },
    { "act": "wait_seconds", "seconds": 0.4 },

    { "act": "execute_script",
      "script": "SettingsService.get_shooting_show_all_units()",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").show_all_units_checkbox.button_pressed",
      "equals": true },
    { "act": "screenshot", "label": "02_show_all_on" },

    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\")._is_unit_in_shooter_list(\"U_WITCHSEEKERS_C\")",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\")._is_unit_in_shooter_list(\"U_WITCHSEEKERS_D\")",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").unit_selector.get_item_count() > get_meta(\"filtered_count\")",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").show_all_units_checkbox.text",
      "equals": "Show all units" },
    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").dice_log_display.get_parsed_text().contains(\"Click missed\")",
      "equals": false },

    { "act": "click_node",
      "node": "/root/Main/HUD_Right/VBoxContainer/ShootingScrollContainer/ShootingPanel/DeclarationBox/ShowAllUnitsCheckbox" },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script",
      "script": "SettingsService.get_shooting_show_all_units()",
      "equals": false },
    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\")._is_unit_in_shooter_list(\"U_WITCHSEEKERS_C\")",
      "equals": false },
    { "act": "screenshot", "label": "03_filtered_again" },

    { "act": "click_unit", "unit_id": "U_WITCHSEEKERS_C" },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").active_shooter_id",
      "equals": "U_WITCHSEEKERS_C" },
    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\")._is_unit_in_shooter_list(\"U_WITCHSEEKERS_C\")",
      "equals": true },
    { "act": "screenshot", "label": "04_board_click_selects_hidden_unit" },

    { "act": "execute_script",
      "script": "SettingsService.set_shooting_show_all_units(false)\nreturn true",
      "multiline": true, "equals": true }
  ]
}
