{
  "id": "cursor_focused_zoom",
  "covers": ["camera.zoom.cursor_focus"],
  "fixture": "audit_baseline_postdeploy",
  "disable_ai": true,
  "description": "Keyboard + zoom (KEY_EQUAL -> zoom_in) stays anchored on the mouse cursor. After fitting the board and hovering its centre, pressing + repeatedly must keep the SAME world point under the cursor (drift ~0 board px), instead of the view drifting toward the viewport's top-left corner. Also asserts the zoom actually increased so the key path is exercised.",
  "steps": [
    { "act": "wait_seconds", "seconds": 1.0 },

    { "act": "execute_script", "script": "main.fit_view_to_board()" },
    { "act": "wait_frames", "frames": 3 },

    { "act": "hover_board_at", "x": 880, "y": 1200 },
    { "act": "wait_frames", "frames": 2 },

    { "act": "execute_script", "script": "main.set_meta(\"cursor_screen\", main.get_viewport().get_mouse_position())" },
    { "act": "execute_script", "script": "main.set_meta(\"world_before\", main.screen_to_world_position(main.get_meta(\"cursor_screen\")))" },
    { "act": "execute_script", "script": "main.set_meta(\"zoom_before\", main.view_zoom)" },

    { "act": "execute_script", "script": "(main.get_meta(\"world_before\") - Vector2(880, 1200)).length()", "expect_max": 5.0 },

    { "act": "screenshot", "label": "01_before_zoom_cursor_at_board_center" },

    { "act": "simulate_key", "keycode": "Equal" },
    { "act": "simulate_key", "keycode": "Equal" },
    { "act": "simulate_key", "keycode": "Equal" },
    { "act": "simulate_key", "keycode": "Equal" },
    { "act": "simulate_key", "keycode": "Equal" },
    { "act": "simulate_key", "keycode": "Equal" },
    { "act": "simulate_key", "keycode": "Equal" },
    { "act": "simulate_key", "keycode": "Equal" },
    { "act": "simulate_key", "keycode": "Equal" },
    { "act": "simulate_key", "keycode": "Equal" },
    { "act": "simulate_key", "keycode": "Equal" },
    { "act": "simulate_key", "keycode": "Equal" },
    { "act": "simulate_key", "keycode": "Equal" },
    { "act": "simulate_key", "keycode": "Equal" },
    { "act": "simulate_key", "keycode": "Equal" },

    { "act": "execute_script", "script": "main.view_zoom - main.get_meta(\"zoom_before\")", "expect_min": 0.02 },

    { "act": "execute_script", "script": "(main.screen_to_world_position(main.get_meta(\"cursor_screen\")) - main.get_meta(\"world_before\")).length()", "expect_max": 1.0 },

    { "act": "screenshot", "label": "02_after_zoom_same_board_point_under_cursor" }
  ]
}
