      "seconds": 0.6
    },
    {
      "act": "execute_script",
      "script": "AIPlayer.configure({1: \"HUMAN\", 2: \"AI\"}, {2: 2})"
    },
    {
      "act": "execute_script",
      "script": "AIPlayer.set_ai_speed_preset(0)"
    },
    {
      "act": "execute_script",
      "script": "GameEventLog.clear()"
    },
    {
      "act": "execute_script",
      "script": "GameState.state[\"units\"][\"U_KAPTIN_BADRUKK_A\"][\"models\"][0].merge({\"position\": {\"x\": 850.0, \"y\": 350.0}}, true)"
    },
    {
      "act": "execute_script",
      "script": "GameState.state[\"units\"][\"U_WEIRDBOY_J\"][\"models\"][0].merge({\"position\": {\"x\": 1100.0, \"y\": 400.0}}, true)"
    },
    {
      "act": "execute_script",
      "script": "GameState.state[\"units\"][\"U_WARBOSS_IN_MEGA_ARMOUR_D\"][\"models\"][0].merge({\"position\": {\"x\": 600.0, \"y\": 500.0}}, true)"
    },
    {
      "act": "execute_script",
      "script": "GameState.set_active_player(2)"
    },
    {
      "act": "execute_script",
      "script": "PhaseManager.transition_to_phase(8)"
    },
    {
      "act": "wait_seconds",
      "seconds": 4.0
    },
    {
      "act": "screenshot",
      "label": "01_shooting_plan_card_in_log",
      "region": [0, 105, 420, 760]
    },
    {
      "act": "wait_seconds",
      "seconds": 22.0
    },
    {
      "act": "execute_script",
      "script": "GameEventLog.has_ai_entry_containing_any([\"Shooting plan\"])",
      "equals": true
    },
    {
      "act": "execute_script",
      "script": "GameEventLog.shooting_plan_integrity()[\"plans\"] >= 1",
      "equals": true
    },
    {
      "act": "execute_script",
      "script": "GameEventLog.shooting_plan_integrity()[\"checked\"] >= 1",
      "equals": true
    },
    {
      "act": "execute_script",
      "script": "GameEventLog.shooting_plan_integrity()[\"mismatches\"].size()",
      "equals": 0
