{
  "id": "fight_no_targets_autoend_11e",
  "covers": [
    "phases.FightPhase._request_attack_assignment",
    "phases.FightPhase.11e_sequencer",
    "dialogs.AttackAssignmentDialog",
    "scripts.FightController",
    "rules.FightSequencer"
  ],
  "fixture": "audit_370_bgnt_shoot",
  "edition": 11,
  "rng_seed": 42,
  "transition_to_phase": 10,
  "disable_ai": true,
  "description": "Deadlock regression (Blade Champion report): a unit that charged but whose overrun pile-in (12.06) cannot reach any enemy used to open the Assign Attacks dialog with 0 eligible targets and no way to skip — self-locking the game. Part 1 recreates the legacy dialog state (signal emitted with empty targets) and proves the new 'End Fight (No Targets)' escape hatch ends the activation via SKIP_UNIT. Part 2 drives the real path for a second charged-but-out-of-reach unit and proves the phase now auto-ends the activation: no AttackAssignmentDialog appears, the unit is marked as fought, and the fight sequence continues.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "expect_state", "path": "meta.phase", "equals": 10 },

    { "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().pile_in_step_11e",
      "equals": 1 },
    { "act": "dispatch_action", "action": { "type": "END_PILE_IN", "player": 1 } },
    { "act": "expect_action_result", "path": "success", "equals": true },
    { "act": "dispatch_action", "action": { "type": "END_PILE_IN", "player": 2 } },
    { "act": "expect_action_result", "path": "success", "equals": true },

    { "act": "execute_script",
      "script": "GameState.state[\"units\"][\"U_BLADE_CHAMPION_A\"][\"flags\"].merge({\"charged_this_turn\": true}, true)" },
    { "act": "execute_script",
      "script": "RulesEngine.is_unit_engaged(\"U_BLADE_CHAMPION_A\", GameState.state)",
      "equals": false },

    { "act": "dispatch_action",
      "action": { "type": "SELECT_FIGHTER", "unit_id": "U_BLADE_CHAMPION_A" } },
    { "act": "expect_action_result", "path": "success", "equals": true },
    { "act": "expect_action_result", "path": "trigger_epic_challenge", "equals": true },
    { "act": "dispatch_action",
      "action": { "type": "DECLINE_EPIC_CHALLENGE", "unit_id": "U_BLADE_CHAMPION_A", "player": 1 } },
    { "act": "expect_action_result", "path": "success", "equals": true },
    { "act": "expect_action_result", "path": "trigger_katah_stance", "equals": true },
    { "act": "dispatch_action",
      "action": { "type": "SELECT_KATAH_STANCE", "unit_id": "U_BLADE_CHAMPION_A", "stance": "dacatarai", "player": 1 } },
    { "act": "expect_action_result", "path": "success", "equals": true },
    { "act": "expect_action_result", "path": "trigger_pile_in", "equals": true },
    { "act": "expect_phase_property", "property": "overrun_pile_in_unit_11e", "equals": "U_BLADE_CHAMPION_A" },

    { "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().emit_signal(\"attack_assignment_required\", \"U_BLADE_CHAMPION_A\", {})" },
    { "act": "wait_seconds", "seconds": 0.8 },
    { "act": "expect_node_visible", "node": "/root/AttackAssignmentDialog" },
    { "act": "expect_node_visible", "node": "/root/AttackAssignmentDialog/Content/ButtonContainer/SkipFightButton" },
    { "act": "expect_node_property",
      "node": "/root/AttackAssignmentDialog/Content/ButtonContainer/ConfirmButton",
      "property": "disabled", "equals": true },
    { "act": "screenshot", "label": "01_no_targets_dialog_offers_end_fight" },
    { "act": "click_node", "node": "/root/AttackAssignmentDialog/Content/ButtonContainer/SkipFightButton", "emit_pressed": true },
    { "act": "wait_seconds", "seconds": 0.6 },
    { "act": "execute_script",
      "script": "\"U_BLADE_CHAMPION_A\" in PhaseManager.get_current_phase_instance().units_that_fought",
      "equals": true },
    { "act": "expect_phase_property", "property": "active_fighter_id", "equals": "" },
    { "act": "execute_script",
      "script": "Engine.get_main_loop().root.get_node_or_null(\"AttackAssignmentDialog\") == null",
      "equals": true },
    { "act": "screenshot", "label": "02_escape_hatch_ended_activation" },

    { "act": "execute_script",
      "script": "GameState.state[\"units\"][\"U_STRIKE_FORCE_A\"][\"flags\"].merge({\"charged_this_turn\": true}, true)" },
    { "act": "execute_script",
      "script": "RulesEngine.is_unit_engaged(\"U_STRIKE_FORCE_A\", GameState.state)",
      "equals": false },
    { "act": "dispatch_action",
      "action": { "type": "SELECT_FIGHTER", "unit_id": "U_STRIKE_FORCE_A" } },
    { "act": "expect_action_result", "path": "success", "equals": true },
    { "act": "expect_action_result", "path": "trigger_pile_in", "equals": true },
    { "act": "expect_phase_property", "property": "overrun_pile_in_unit_11e", "equals": "U_STRIKE_FORCE_A" },
    { "act": "screenshot", "label": "03_overrun_pile_in_pending" },

    { "act": "dispatch_action",
      "action": { "type": "PILE_IN", "unit_id": "U_STRIKE_FORCE_A", "movements": {}, "player": 2 } },
    { "act": "expect_action_result", "path": "success", "equals": true },
    { "act": "expect_action_result", "path": "trigger_attack_assignment", "exists": false },
    { "act": "expect_action_result", "path": "trigger_fight_selection", "equals": true },
    { "act": "expect_phase_property", "property": "active_fighter_id", "equals": "" },
    { "act": "expect_state", "path": "units.U_STRIKE_FORCE_A.flags.has_fought", "equals": true },
    { "act": "execute_script",
      "script": "\"U_STRIKE_FORCE_A\" in PhaseManager.get_current_phase_instance().units_that_fought",
      "equals": true },
    { "act": "wait_seconds", "seconds": 1.0 },
    { "act": "execute_script",
      "script": "Engine.get_main_loop().root.get_node_or_null(\"AttackAssignmentDialog\") == null",
      "equals": true },
    { "act": "screenshot", "label": "04_no_target_activation_autoended" },

    { "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().sequencer_11e.peek_selection(GameState.state)[\"done\"]",
      "equals": false },
    { "act": "screenshot", "label": "05_fight_sequence_continues" }
  ]
}
