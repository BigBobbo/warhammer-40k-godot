{
  "id": "pad_m1_full_turn_cursor",
  "covers": ["controller.m1.full_turn", "controller.m1.phase_confirm", "controller.m1.dialog_focus"],
  "fixture": "audit_baseline_postdeploy",
  "transition_to_phase": 6,
  "disable_ai": true,
  "rng_seed": 42,
  "description": "M1 gate: a complete solo player turn (command -> movement -> shooting -> charge -> fight -> scoring, into player 2's command phase) played pad-only. Start opens the end-phase confirm (focused OK via the dialog watcher), B cancels it natively via ui_cancel, A confirms; phase-specific dialogs (shooting summary, unfought-units warning, mission discard) land pad focus on their confirm button so A proceeds; the movement phase does a real cursor interaction (select, drag a model, confirm) before ending.",
  "steps": [
    { "act": "wait_seconds", "seconds": 1.5 },
    { "act": "expect_state", "path": "meta.phase", "equals": 6 },
    { "act": "screenshot", "label": "01_command_phase" },

    { "act": "simulate_joy_button", "button_index": 6 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script", "script": "main._pad_phase_confirm.visible", "equals": true },
    { "act": "execute_script", "script": "main._pad_phase_confirm.get_ok_button().has_focus()", "equals": true },
    { "act": "screenshot", "label": "02_end_phase_confirm_dialog" },
    { "act": "simulate_joy_button", "button_index": 1 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main._pad_phase_confirm.visible", "equals": false },
    { "act": "expect_state", "path": "meta.phase", "equals": 6 },

    { "act": "simulate_joy_button", "button_index": 6 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 1.2 },
    { "act": "expect_state", "path": "meta.phase", "equals": 7 },
    { "act": "screenshot", "label": "03_movement_phase" },

    { "act": "pad_cursor_glide", "unit_id": "U_BLADE_CHAMPION_A" },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "str(main.movement_controller.active_unit_id)", "equals": "U_BLADE_CHAMPION_A" },
    { "act": "pad_cursor_glide", "unit_id": "U_BLADE_CHAMPION_A" },
    { "act": "wait_seconds", "seconds": 0.2 },
    { "act": "simulate_joy_button", "button_index": 0, "state": "press" },
    { "act": "pad_cursor_glide", "x": 120.0, "y": 220.0 },
    { "act": "simulate_joy_button", "button_index": 0, "state": "release" },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "pad_cursor_glide", "button_text": "End This Unit's Move" },
    { "act": "wait_seconds", "seconds": 0.2 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "abs(GameState.state.units.U_BLADE_CHAMPION_A.models[0].position.y - 220.0)", "expect_max": 15 },
    { "act": "screenshot", "label": "04_model_moved_by_cursor" },

    { "act": "simulate_joy_button", "button_index": 6 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 1.0 },
    { "act": "expect_state", "path": "meta.phase", "equals": 8 },
    { "act": "screenshot", "label": "05_shooting_phase" },

    { "act": "simulate_joy_button", "button_index": 6 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.8 },
    { "act": "screenshot", "label": "06_shooting_summary_dialog" },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 1.0 },
    { "act": "expect_state", "path": "meta.phase", "equals": 9 },
    { "act": "screenshot", "label": "07_charge_phase" },

    { "act": "simulate_joy_button", "button_index": 6 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 1.0 },
    { "act": "expect_state", "path": "meta.phase", "equals": 10 },
    { "act": "screenshot", "label": "08_fight_phase" },

    { "act": "simulate_joy_button", "button_index": 6 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.8 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 1.0 },
    { "act": "expect_state", "path": "meta.phase", "equals": 11 },
    { "act": "screenshot", "label": "09_scoring_phase" },

    { "act": "simulate_joy_button", "button_index": 6 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.8 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 1.2 },
    { "act": "expect_state", "path": "meta.phase", "equals": 6 },
    { "act": "expect_state", "path": "meta.active_player", "equals": 2 },
    { "act": "screenshot", "label": "10_player2_command_phase" }
  ]
}
