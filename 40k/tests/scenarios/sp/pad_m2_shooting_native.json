{
  "id": "pad_m2_shooting_native",
  "covers": ["controller.m2.shooting_native", "controller.m2.target_cycling"],
  "fixture": "audit_370_bgnt_shoot",
  "transition_to_phase": 8,
  "disable_ai": true,
  "rng_seed": 42,
  "description": "M2 gate: a full shooting activation with ZERO virtual-cursor use. RB cycles to an eligible shooter (camera pans to it), RB cycles the eligible-target ring (camera pans to the highlighted target), A assigns the target to the current weapon, Start confirms targets (context-dependent Menu), and the staged dice resolution is walked with A on watcher-focused dialog buttons until the shooter is marked has_shot.",
  "steps": [
    { "act": "wait_seconds", "seconds": 1.5 },
    { "act": "expect_state", "path": "meta.phase", "equals": 8 },

    { "act": "simulate_joy_button", "button_index": 10 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "str(main.shooting_controller.active_shooter_id) != \"\"", "equals": true },
    { "act": "execute_script", "script": "InputDeviceManager.set_meta(\"shooter\", str(main.shooting_controller.active_shooter_id))" },
    { "act": "screenshot", "label": "01_shooter_cycled" },

    { "act": "simulate_joy_button", "button_index": 10 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script", "script": "PadRouter.target_highlight_id != \"\"", "equals": true },
    { "act": "screenshot", "label": "02_target_highlighted" },

    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "main.shooting_controller.weapon_assignments.size()", "expect_min": 1 },
    { "act": "screenshot", "label": "03_target_assigned" },

    { "act": "simulate_joy_button", "button_index": 6 },
    { "act": "wait_seconds", "seconds": 5.5 },
    { "act": "screenshot", "label": "04_resolution_started" },

    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 1.0 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 1.0 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 1.0 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 1.0 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 1.0 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 1.0 },
    { "act": "screenshot", "label": "05_resolution_walked" },

    { "act": "simulate_joy_button", "button_index": 2 },
    { "act": "wait_seconds", "seconds": 0.8 },
    { "act": "execute_script", "script": "GameState.state.units[InputDeviceManager.get_meta(\"shooter\")].flags.get(\"has_shot\", false)", "equals": true },
    { "act": "screenshot", "label": "06_shooter_has_shot" }
  ]
}
