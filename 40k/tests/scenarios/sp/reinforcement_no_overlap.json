            "y": 50.0
          },
          {
            "x": 1270.0,
            "y": 50.0
          },
          {
            "x": 1330.0,
            "y": 50.0
          },
          {
            "x": 1390.0,
            "y": 50.0
          }
        ]
      }
    },
    {
      "act": "expect_action_result",
      "path": "success",
      "equals": false
    },
    {
      "act": "execute_script",
      "script": "GameState.state.units.U_BOYZ_K.status",
      "equals": 7
    },
    {
      "act": "screenshot",
      "label": "02_overlapping_arrival_rejected"
    },
    {
      "act": "dispatch_action",
      "action": {
        "type": "PLACE_REINFORCEMENT",
        "unit_id": "U_BOYZ_K",
