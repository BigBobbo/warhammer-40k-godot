{
  "id": "attached_char_charge_drag_leader",
  "covers": [
    "scripts.ChargeController.attached_character_drag",
    "phases.ChargePhase.composite_path_keys",
    "charge.leader_manually_draggable"
  ],
  "fixture": "attached_char_charge_overlap",
  "edition": 11,
  "rng_seed": 42,
  "transition_to_phase": 9,
  "disable_ai": true,
  "description": "Regression for the 'cannot drag the attached character during a Charge move' bug (Custodian Guard led by a Blade Champion). The fixture formation is first pushed back 2\"+ from the enemy (11e engagement range is 2\" — the stock fixture starts engaged and could not legally declare). Player path: DECLARE_CHARGE (11e: empty target list — targets are selected with the move) + CHARGE_ROLL, then the BLADE CHAMPION's token is dragged FIRST with a real drag_board (mouse press on the leader's token, motion, release) into base contact with the enemy — before the fix the click fell through (_handle_mouse_down only accepted tokens of the bodyguard unit) and the leader never moved. Each Custodian is then dragged into contact, the real 'Confirm Charge Moves' button is clicked, and the move validates end-to-end through ChargePhase's composite '<char_unit>:<model>' path keys (11e target inference included). Asserts: the leader enters models_to_move, its drag stages a move under the composite key, the confirmed position is the player's dragged spot (NOT the auto-ride translation), it ends in base contact with the enemy, and both units carry charged_this_turn/fights_first.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.8 },
    { "act": "expect_phase", "equals": 9 },
    { "act": "expect_token_visible", "unit_id": "U_CUSTODIAN_GUARD_B", "timeout_s": 3.0 },
    { "act": "expect_token_visible", "unit_id": "U_BLADE_CHAMPION_A", "timeout_s": 3.0 },
    { "act": "expect_state", "path": "units.U_CUSTODIAN_GUARD_B.attachment_data.attached_characters.0", "equals": "U_BLADE_CHAMPION_A" },
    { "act": "execute_script", "script": "GameState.set_edition(11)", "equals": 11 },

    { "act": "execute_script",
      "script": "GameState.state.units[\"U_CUSTODIAN_GUARD_B\"].models[0].merge({\"position\": {\"x\": 520.0, \"y\": 880.0}}, true)" },
    { "act": "execute_script",
      "script": "GameState.state.units[\"U_CUSTODIAN_GUARD_B\"].models[1].merge({\"position\": {\"x\": 680.0, \"y\": 880.0}}, true)" },
    { "act": "execute_script",
      "script": "GameState.state.units[\"U_CUSTODIAN_GUARD_B\"].models[2].merge({\"position\": {\"x\": 600.0, \"y\": 800.0}}, true)" },
    { "act": "execute_script",
      "script": "GameState.state.units[\"U_BLADE_CHAMPION_A\"].models[0].merge({\"position\": {\"x\": 600.0, \"y\": 880.0}}, true)" },
    { "act": "execute_script", "script": "main.update_unit_visuals(\"U_CUSTODIAN_GUARD_B\")" },
    { "act": "execute_script", "script": "main.update_unit_visuals(\"U_BLADE_CHAMPION_A\")" },
    { "act": "wait_frames", "frames": 8 },
    { "act": "execute_script",
      "script": "self.min_edge_distance_between_units(\"U_CUSTODIAN_GUARD_B\", \"U_ENEMY_BOYZ_X\")",
      "expect_min": 2.1 },
    { "act": "screenshot", "label": "01_setup_squad_with_leader" },

    { "act": "dispatch_action", "action": { "type": "DECLARE_CHARGE", "actor_unit_id": "U_CUSTODIAN_GUARD_B", "payload": { "target_unit_ids": [] } } },
    { "act": "expect_action_result", "path": "success", "equals": true },
    { "act": "execute_script", "script": "main.charge_controller.set(\"active_unit_id\", \"U_CUSTODIAN_GUARD_B\")" },
    { "act": "execute_script", "script": "main.charge_controller.set(\"selected_targets\", [\"U_ENEMY_BOYZ_X\"])" },

    { "act": "dispatch_action", "action": { "type": "CHARGE_ROLL", "actor_unit_id": "U_CUSTODIAN_GUARD_B" } },
    { "act": "expect_action_result", "path": "success", "equals": true },
    { "act": "wait_frames", "frames": 6 },

    { "act": "execute_script",
      "script": "get_tree().root.find_children(\"KeepRollButton\", \"\", true, false)[0].emit_signal(\"pressed\")" },
    { "act": "wait_frames", "frames": 6 },
    { "act": "execute_script", "script": "main.charge_controller.set(\"selected_targets\", [\"U_ENEMY_BOYZ_X\"])" },

    { "act": "execute_script", "script": "main.charge_controller.awaiting_movement", "equals": true },

    { "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().pending_charges[\"U_CUSTODIAN_GUARD_B\"].merge({\"distance\": 9, \"dice_rolls\": [4, 5]}, true)" },
    { "act": "execute_script", "script": "main.charge_controller.set(\"charge_distance\", 9)" },

    { "act": "execute_script",
      "script": "main.charge_controller.models_to_move.has(\"U_BLADE_CHAMPION_A:m1\")",
      "equals": true },
    { "act": "execute_script",
      "script": "main.charge_controller.models_to_move.size()",
      "equals": 4 },
    { "act": "screenshot", "label": "02_movement_enabled_leader_in_move_list" },

    { "act": "drag_board", "from_x": 600, "from_y": 880, "to_x": 600, "to_y": 656, "steps": 12 },
    { "act": "wait_frames", "frames": 6 },
    { "act": "execute_script",
      "script": "main.charge_controller.moved_models.has(\"U_BLADE_CHAMPION_A:m1\")",
      "equals": true },
    { "act": "execute_script",
      "script": "Vector2(GameState.state.units[\"U_BLADE_CHAMPION_A\"].models[0].position[\"x\"], GameState.state.units[\"U_BLADE_CHAMPION_A\"].models[0].position[\"y\"]).distance_to(Vector2(600, 656))",
      "expect_max": 8.0 },
    { "act": "screenshot", "label": "03_leader_dragged_into_contact" },

    { "act": "drag_board", "from_x": 600, "from_y": 800, "to_x": 662, "to_y": 622, "steps": 12 },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script",
      "script": "main.charge_controller.moved_models.has(\"m3\")",
      "equals": true },

    { "act": "drag_board", "from_x": 520, "from_y": 880, "to_x": 538, "to_y": 614, "steps": 12 },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script",
      "script": "main.charge_controller.moved_models.has(\"m1\")",
      "equals": true },

    { "act": "drag_board", "from_x": 680, "from_y": 880, "to_x": 672, "to_y": 550, "steps": 14 },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script",
      "script": "main.charge_controller.moved_models.has(\"m2\")",
      "equals": true },
    { "act": "execute_script",
      "script": "main.charge_controller.models_to_move.size()",
      "equals": 0 },
    { "act": "screenshot", "label": "04_all_models_dragged" },

    { "act": "expect_node_property",
      "node": "/root/Main/HUD_Right/VBoxContainer/ChargeScrollContainer/ChargePanel/ChargeActionButtons/ConfirmRow/ConfirmChargeButton",
      "property": "disabled", "equals": false },
    { "act": "click_node",
      "node": "/root/Main/HUD_Right/VBoxContainer/ChargeScrollContainer/ChargePanel/ChargeActionButtons/ConfirmRow/ConfirmChargeButton",
      "emit_pressed": true },
    { "act": "wait_frames", "frames": 10 },

    { "act": "expect_state", "path": "units.U_CUSTODIAN_GUARD_B.flags.charged_this_turn", "equals": true },
    { "act": "expect_state", "path": "units.U_BLADE_CHAMPION_A.flags.charged_this_turn", "equals": true },
    { "act": "expect_state", "path": "units.U_BLADE_CHAMPION_A.flags.fights_first", "equals": true },

    { "act": "execute_script",
      "script": "Vector2(GameState.state.units[\"U_BLADE_CHAMPION_A\"].models[0].position[\"x\"], GameState.state.units[\"U_BLADE_CHAMPION_A\"].models[0].position[\"y\"]).distance_to(Vector2(600, 656))",
      "expect_max": 8.0 },
    { "act": "execute_script",
      "script": "Vector2(GameState.state.units[\"U_BLADE_CHAMPION_A\"].models[0].position[\"x\"], GameState.state.units[\"U_BLADE_CHAMPION_A\"].models[0].position[\"y\"]).distance_to(Vector2(618, 614))",
      "expect_min": 20.0 },
    { "act": "execute_script",
      "script": "self.min_edge_distance_between_units(\"U_BLADE_CHAMPION_A\", \"U_ENEMY_BOYZ_X\")",
      "expect_max": 0.5 },
    { "act": "execute_script",
      "script": "int(Measurement.models_overlap(GameState.get_unit(\"U_BLADE_CHAMPION_A\").models[0], GameState.get_unit(\"U_CUSTODIAN_GUARD_B\").models[0])) + int(Measurement.models_overlap(GameState.get_unit(\"U_BLADE_CHAMPION_A\").models[0], GameState.get_unit(\"U_CUSTODIAN_GUARD_B\").models[1])) + int(Measurement.models_overlap(GameState.get_unit(\"U_BLADE_CHAMPION_A\").models[0], GameState.get_unit(\"U_CUSTODIAN_GUARD_B\").models[2]))",
      "equals": 0 },
    { "act": "screenshot", "label": "05_charge_confirmed_leader_at_dragged_spot" }
  ]
}
