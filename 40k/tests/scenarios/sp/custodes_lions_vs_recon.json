{
 "id": "custodes_lions_vs_recon",
 "covers": [
  "armies.custodes_lions.load_path",
  "autoloads.ArmyListManager.scan_available_armies",
  "scripts.MainMenu.army_selection",
  "autoloads.CharacterAttachmentManager.blade_champion_can_lead"
 ],
 "edition": 11,
 "rng_seed": 42,
 "disable_ai": true,
 "description": "Player path for the Custodes base army list: boots to the real MainMenu, asserts the base-list census is exactly {custodes_lions, recon_stomps}, switches Player 2's dropdown to Custodes Lions (OptionButton.select — the army dropdowns have no item_selected handler; Start Game reads .selected directly), real-clicks Start Game, and asserts the battle starts Orks 17 units vs Adeptus Custodes 11 units (2000 pts each) with Lions of the Emperor dispatched, ordinal repeat pricing intact (215/215/215 + 225/225/225 Custodian Guard, 110 + 125/125 Blade Champions), the P1 Recon Stomps warlord flag intact, and the Blade Champions offering Custodian Guard attachment during formations.",
 "steps": [
  { "act": "wait_seconds", "seconds": 1.5 },
  { "act": "execute_script", "script": "ArmyListManager.get_available_armies().size()", "equals": 2 },
  { "act": "execute_script", "script": "ArmyListManager.get_available_armies().has(\"custodes_lions\")", "equals": true },
  { "act": "execute_script", "script": "ArmyListManager.get_available_armies().has(\"recon_stomps\")", "equals": true },
  { "act": "execute_script", "script": "main.army_options[0][\"id\"]", "equals": "custodes_lions" },
  { "act": "execute_script", "script": "main.get_node(\"ScrollContainer/MenuContainer/ArmySection/Player2Container/Player2Dropdown\").select(0)" },
  { "act": "execute_script", "script": "main.get_node(\"ScrollContainer/MenuContainer/ArmySection/Player2Container/Player2Dropdown\").get_item_text(main.get_node(\"ScrollContainer/MenuContainer/ArmySection/Player2Container/Player2Dropdown\").selected).contains(\"Custodes Lions\")", "equals": true },
  { "act": "screenshot", "label": "01_menu_p2_custodes_selected" },
  { "act": "execute_script", "script": "main.get_node(\"ScrollContainer\").ensure_control_visible(main.get_node(\"ScrollContainer/MenuContainer/ButtonSection/StartButton\"))" },
  { "act": "wait_frames", "frames": 5 },
  { "act": "click_node", "node": "/root/MainMenu/ScrollContainer/MenuContainer/ButtonSection/StartButton" },
  { "act": "wait_seconds", "seconds": 3.0 },
  { "act": "execute_script", "script": "GameState.state[\"units\"].size()", "equals": 28 },
  { "act": "execute_script", "script": "GameState.get_units_for_player(1).size()", "equals": 17 },
  { "act": "execute_script", "script": "GameState.get_units_for_player(2).size()", "equals": 11 },
  { "act": "execute_script", "script": "GameState.state[\"factions\"][\"1\"][\"name\"]", "equals": "Orks" },
  { "act": "execute_script", "script": "GameState.state[\"factions\"][\"2\"][\"name\"]", "equals": "Adeptus Custodes" },
  { "act": "execute_script", "script": "GameState.state[\"factions\"][\"2\"][\"detachment\"]", "equals": "Lions of the Emperor" },
  { "act": "execute_script", "script": "GameState.get_unit(\"U_BLADE_CHAMPION_A\")[\"meta\"][\"is_warlord\"]", "equals": true },
  { "act": "execute_script", "script": "GameState.get_unit(\"U_BLADE_CHAMPION_B\")[\"meta\"][\"points\"]", "equals": 125 },
  { "act": "execute_script", "script": "GameState.get_unit(\"U_CUSTODIAN_GUARD_D\")[\"meta\"][\"points\"]", "equals": 225 },
  { "act": "execute_script", "script": "GameState.get_unit(\"U_CUSTODIAN_GUARD_A\")[\"models\"].size()", "equals": 5 },
  { "act": "execute_script", "script": "GameState.get_unit(\"U_BLADE_CHAMPION_A\")[\"meta\"][\"leader_data\"][\"can_lead\"].has(\"CUSTODIAN GUARD\")", "equals": true },
  { "act": "execute_script", "script": "GameState.get_eligible_bodyguards_for_character(\"U_BLADE_CHAMPION_A\").has(\"U_CUSTODIAN_GUARD_A\")", "equals": true },
  { "act": "execute_script", "script": "GameState.get_unit(\"U_WAZDAKKA_GUTSMEK_A\")[\"meta\"][\"is_warlord\"]", "equals": true },
  { "act": "screenshot", "label": "02_orks_vs_custodes_started" }
 ]
}
