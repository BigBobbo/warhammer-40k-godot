{
  "id": "battleshock_marker_hover_explains",
  "covers": ["ui.token_hover_tooltip", "ui.status_marker_explanations", "scripts.Main._build_status_marker_hover_text"],
  "fixture": "audit_383_battleshock_shoot",
  "description": "Hovering a model with an on-token status marker explains WHY it is marked. The battle-shocked Contemptor-Achillus Dreadnought (red ring + '!') must show a 'Battle-shocked' tooltip entry naming the red ring, its cause, its effects (OC 0, no Stratagems, no Actions, Desperate Escape 1-3) and recovery (re-test next Command phase). A unit that shot+moved decodes its colored action bar ('This turn: Shot, Moved'). An unmarked unit shows neither block.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "expect_state", "path": "units.U_CONTEMPTOR-ACHILLUS_DREADNOUGHT_H.flags.battle_shocked", "equals": true },

    { "act": "hover_unit", "unit_id": "U_CONTEMPTOR-ACHILLUS_DREADNOUGHT_H" },
    { "act": "expect_node_visible", "node": "/root/Main/TokenHoverTooltip", "timeout_s": 2.0 },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('Battle-shocked')",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('red ring')",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('OC 0')",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('Desperate Escape')",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('Command phase')",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('This turn: Moved')",
      "equals": true },
    { "act": "screenshot", "label": "01_battleshock_marker_explained" },

    { "act": "hover_unit", "unit_id": "U_CALADIUS_GRAV-TANK_E" },
    { "act": "expect_node_visible", "node": "/root/Main/TokenHoverTooltip", "timeout_s": 2.0 },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('Battle-shocked')",
      "equals": false },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('This turn: Shot, Moved')",
      "equals": true },
    { "act": "screenshot", "label": "02_action_bar_decoded" },

    { "act": "hover_unit", "unit_id": "U_WARBOSS_B" },
    { "act": "expect_node_visible", "node": "/root/Main/TokenHoverTooltip", "timeout_s": 2.0 },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('Battle-shocked')",
      "equals": false },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('This turn:')",
      "equals": false },
    { "act": "screenshot", "label": "03_unmarked_unit_no_status_block" }
  ]
}
