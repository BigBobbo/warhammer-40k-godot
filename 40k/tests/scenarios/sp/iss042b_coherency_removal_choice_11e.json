      "script": "GameState.get_unit(\"U_BOYZ_K\")[\"models\"][0].merge({\"position\": {\"x\": 1624.0, \"y\": 1118.0}}, true)"
    },
    {
      "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance()._get_incoherent_human_units().size()",
      "equals": 1
    },
    {
      "act": "screenshot",
      "label": "01_boyz_k_broken_coherency"
    },
    {
