      "act": "screenshot",
      "label": "02_coherency_removal_dialog_open"
    },
    {
      "act": "execute_script",
      "script": "tree.root.get_node(\"CoherencyRemovalDialog\").position.y > tree.root.size.y * 0.5",
      "equals": true
    },
