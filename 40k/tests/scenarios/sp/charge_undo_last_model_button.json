{
  "id": "charge_undo_last_model_button",
  "covers": ["charge.ux.undo_last_model_button", "charge.per_model_undo"],
  "fixture": "test_charge_congestion",
  "edition": 11,
  "rng_seed": 42,
  "transition_to_phase": 9,
  "disable_ai": true,
  "description": "The charge-phase 'Undo Last Model' button, driven as a real player would: select the 3-model Boyz unit, declare, roll (seeded 12), MOVE model m1 ~50px toward the Shield-Captain (through the real _end_model_drag path, so it lands on the per-model undo stack and the button enables), then CLICK the real UndoLastModelButton with a genuine mouse event (NOT emit_pressed). Before the fix the click did nothing: ChargeController._input() whitelisted only confirm_button before calling get_viewport().set_input_as_handled(), so the press was swallowed before Godot's GUI pass and the button's pressed signal never fired — m1 stayed at its dropped spot. After the fix the whitelist covers every charge-panel action button, so the real click reaches the button, _on_undo_last_charge_model() runs, and m1 snaps back to its pre-charge origin (971.2, 770.0) and returns to models_to_move. This is a REAL click (emit_pressed omitted) precisely because emit_pressed would bypass the input path where the bug lived.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.8 },
    { "act": "expect_state", "path": "meta.phase", "equals": 9 },
    { "act": "expect_state", "path": "meta.active_player", "equals": 2 },

    { "act": "execute_script",
      "script": "GameState.state.players[\"1\"].merge({\"cp\": 0}, true)" },
    { "act": "execute_script",
      "script": "GameState.state.players[\"2\"].merge({\"cp\": 0}, true)" },
    { "act": "screenshot", "label": "01_charge_phase_start" },

    { "act": "execute_script",
      "script": "main.charge_controller.unit_selector.select(0)" },
    { "act": "execute_script",
      "script": "main.charge_controller._on_unit_selected(0)" },
    { "act": "execute_script",
      "script": "main.charge_controller.active_unit_id", "equals": "U_CHARGER_0" },
    { "act": "execute_script",
      "script": "main.charge_controller.target_list.select(0)" },
    { "act": "execute_script",
      "script": "main.charge_controller._on_target_selected(0)" },
    { "act": "execute_script",
      "script": "main.charge_controller._on_declare_charge_pressed()" },
    { "act": "wait_seconds", "seconds": 0.2 },
    { "act": "execute_script",
      "script": "main.charge_controller._on_roll_charge_pressed()" },
    { "act": "wait_seconds", "seconds": 0.3 },

    { "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().has_pending_charge(\"U_CHARGER_0\")",
      "equals": true },
    { "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().pending_charges[\"U_CHARGER_0\"].merge({\"distance\": 12}, true)" },
    { "act": "execute_script",
      "script": "main.charge_controller.set(\"charge_distance\", 12)" },
    { "act": "execute_script",
      "script": "main.charge_controller.models_to_move.size()", "equals": 3 },
    { "act": "screenshot", "label": "02_rolled_before_move" },

    { "act": "execute_script",
      "script": "main.charge_controller.set(\"dragging_model\", GameState.get_unit(\"U_CHARGER_0\").models[0])" },
    { "act": "execute_script",
      "script": "main.charge_controller._end_model_drag(Vector2(922, 778.6))" },
    { "act": "wait_seconds", "seconds": 0.2 },

    { "act": "execute_script",
      "script": "main.charge_controller._moved_model_order.size()", "equals": 1 },
    { "act": "execute_script",
      "script": "main.charge_controller.models_to_move.size()", "equals": 2 },
    { "act": "execute_script",
      "script": "Vector2(GameState.get_unit(\"U_CHARGER_0\").models[0].position[\"x\"], GameState.get_unit(\"U_CHARGER_0\").models[0].position[\"y\"]).distance_to(Vector2(971.2, 770.0))",
      "expect_min": 40.0 },
    { "act": "screenshot", "label": "03_m1_moved_toward_target" },

    { "act": "expect_node_visible",
      "node": "/root/Main/HUD_Right/VBoxContainer/ChargeScrollContainer/ChargePanel/ChargeActionButtons/ConfirmRow/UndoLastModelButton" },
    { "act": "expect_node_property",
      "node": "/root/Main/HUD_Right/VBoxContainer/ChargeScrollContainer/ChargePanel/ChargeActionButtons/ConfirmRow/UndoLastModelButton",
      "property": "disabled", "equals": false },

    { "act": "click_node",
      "node": "/root/Main/HUD_Right/VBoxContainer/ChargeScrollContainer/ChargePanel/ChargeActionButtons/ConfirmRow/UndoLastModelButton" },
    { "act": "wait_seconds", "seconds": 0.3 },

    { "act": "execute_script",
      "script": "main.charge_controller._moved_model_order.size()", "equals": 0 },
    { "act": "execute_script",
      "script": "main.charge_controller.models_to_move.size()", "equals": 3 },
    { "act": "execute_script",
      "script": "Vector2(GameState.get_unit(\"U_CHARGER_0\").models[0].position[\"x\"], GameState.get_unit(\"U_CHARGER_0\").models[0].position[\"y\"]).distance_to(Vector2(971.2, 770.0))",
      "expect_max": 0.5 },
    { "act": "execute_script",
      "script": "main.charge_controller.charge_used_label.text", "equals": "Used: 0.0\"" },
    { "act": "screenshot", "label": "04_m1_reverted_by_undo" },
    { "act": "screenshot", "label": "04b_undo_cluster_closeup", "region": [760, 260, 460, 340] }
  ]
}
