{
  "id": "infantry_enters_ruin_wall",
  "covers": ["movement.terrain.infantry_ruin_traversal", "deployment.terrain.infantry_ruin_traversal"],
  "fixture": "audit_baseline_postdeploy",
  "rng_seed": 42,
  "transition_to_phase": 7,
  "disable_ai": true,
  "description": "Regression: no model — including INFANTRY and FLY — may end its movement or deployment overlapping a ruin wall. Walls block ANY final position. Infantry may still pass *through* walls during movement (gated separately by TerrainManager.can_unit_cross_wall in path-traversal validation); this scenario only asserts the endpoint rule via Measurement.model_overlaps_any_wall. Reversing the earlier behavior recorded under #431 (which allowed INFANTRY/FLY to end on walls) — that interpretation was confirmed wrong in-game when Witchseekers were observed sitting on the north wall of Grey Ruins with no rejection.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "expect_state", "path": "meta.phase", "equals": 7 },

    { "act": "execute_script",
      "script": "TerrainManager.terrain_features.size()",
      "expect_min": 1
    },

    { "act": "screenshot", "label": "01_movement_phase_loaded" },

    { "act": "execute_script",
      "script": "Measurement.model_overlaps_any_wall({\"base_mm\": 32, \"base_type\": \"circular\", \"position\": {\"x\": 400, \"y\": 440}, \"rotation\": 0.0}, [])",
      "equals": true
    },
    { "act": "execute_script",
      "script": "Measurement.model_overlaps_any_wall({\"base_mm\": 32, \"base_type\": \"circular\", \"position\": {\"x\": 400, \"y\": 440}, \"rotation\": 0.0}, [\"VEHICLE\"])",
      "equals": true
    },
    { "act": "execute_script",
      "script": "Measurement.model_overlaps_any_wall({\"base_mm\": 32, \"base_type\": \"circular\", \"position\": {\"x\": 400, \"y\": 440}, \"rotation\": 0.0}, [\"MONSTER\"])",
      "equals": true
    },
    { "act": "execute_script",
      "script": "Measurement.model_overlaps_any_wall({\"base_mm\": 32, \"base_type\": \"circular\", \"position\": {\"x\": 400, \"y\": 440}, \"rotation\": 0.0}, [\"INFANTRY\"])",
      "equals": true
    },
    { "act": "execute_script",
      "script": "Measurement.model_overlaps_any_wall({\"base_mm\": 32, \"base_type\": \"circular\", \"position\": {\"x\": 400, \"y\": 440}, \"rotation\": 0.0}, [\"INFANTRY\", \"CHARACTER\"])",
      "equals": true
    },
    { "act": "execute_script",
      "script": "Measurement.model_overlaps_any_wall({\"base_mm\": 32, \"base_type\": \"circular\", \"position\": {\"x\": 400, \"y\": 440}, \"rotation\": 0.0}, [\"FLY\"])",
      "equals": true
    },
    { "act": "screenshot", "label": "02_wall_endpoint_block_universal" }
  ]
}
