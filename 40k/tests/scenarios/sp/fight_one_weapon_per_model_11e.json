{
  "id": "fight_one_weapon_per_model_11e",
  "covers": [
    "phases.FightPhase.one_weapon_per_model",
    "phases.FightPhase.attack_assignment",
    "dialogs.AttackAssignmentDialog.single_weapon_choice",
    "rules.11e.fight.select_melee_weapon"
  ],
  "fixture": "co_pretrigger",
  "edition": 11,
  "rng_seed": 42,
  "transition_to_phase": 10,
  "disable_ai": true,
  "description": "11e core rules (Fight — Select Melee Weapon): when a model fights it must select ONE melee weapon to make its attacks with; [EXTRA ATTACKS] weapons are used in addition. Previously the AttackAssignmentDialog let the player stack every weapon the model carries (Add Assignment per weapon, or 'All to Target'), so a Warboss swung Big choppa AND Power klaw in one activation. This scenario drives the fixed player path: (1) Warboss activation — the dialog separates the Attack squig [EXTRA ATTACKS] from the two regular weapons, adding a second regular weapon REPLACES the first (assignments stay at 1), and after Fight! the staged resolution holds exactly 2 assignments: the chosen Power klaw + the auto-included Attack squig. (2) Custodian Guard activation — engine-level negative test: a second ASSIGN_ATTACKS for a different regular weapon is REJECTED by validation while the first stays pending (the dispatched pending assignment is then cleared — setup-only privilege — so the real dialog path completes the activation), and the dialog's one-click assign button sends exactly ONE of the unit's three melee weapons. Setup-only privileges mirror sibling fight scenarios: CP zeroed to suppress stratagem prompts, wounds inflated so no unit dies mid-scenario, and the real auto-allocate-wounds game setting is switched ON so the defender's save allocation resolves without an interactive overlay (that overlay blocks every fight scenario in this container regardless of this change). Weapon rows are selected via ItemList.select() because synthetic clicks do not land inside popup windows; the Add/Assign/Fight button presses are real clicks.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.8 },
    { "act": "expect_state", "path": "meta.phase", "equals": 10 },
    { "act": "execute_script", "script": "SettingsService.set_auto_allocate_wounds(true)" },
    { "act": "execute_script", "script": "GameState.state.players[\"1\"].merge({\"cp\": 0}, true)" },
    { "act": "execute_script", "script": "GameState.state.players[\"2\"].merge({\"cp\": 0}, true)" },
    { "act": "execute_script", "script": "GameState.state.units[\"U_WARBOSS_B\"].models[0].merge({\"wounds\": 99, \"current_wounds\": 99}, true)" },
    { "act": "execute_script", "script": "GameState.state.units[\"U_CUSTODIAN_GUARD_B\"].models[0].merge({\"wounds\": 99, \"current_wounds\": 99}, true)" },
    { "act": "execute_script", "script": "GameState.state.units[\"U_CUSTODIAN_GUARD_B\"].models[1].merge({\"wounds\": 99, \"current_wounds\": 99}, true)" },
    { "act": "execute_script", "script": "GameState.state.units[\"U_CUSTODIAN_GUARD_B\"].models[2].merge({\"wounds\": 99, \"current_wounds\": 99}, true)" },
    { "act": "execute_script", "script": "GameState.state.units[\"U_CUSTODIAN_GUARD_B\"].models[3].merge({\"wounds\": 99, \"current_wounds\": 99}, true)" },
    { "act": "execute_script", "script": "GameState.state.units[\"U_TELEMON_HEAVY_DREADNOUGHT_I\"].models[0].merge({\"wounds\": 99, \"current_wounds\": 99}, true)" },

    { "act": "expect_node_visible", "node": "/root/Main/HUD_Right/VBoxContainer/FightScrollContainer/FightPanel/PileInStepPanel", "timeout_s": 5.0 },
    { "act": "click_node", "node": "/root/Main/HUD_Right/VBoxContainer/FightScrollContainer/FightPanel/PileInStepPanel/EndPileInButton", "emit_pressed": true },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "expect_node_visible", "node": "/root/Main/HUD_Right/VBoxContainer/FightScrollContainer/FightPanel/PileInStepPanel", "timeout_s": 5.0 },
    { "act": "click_node", "node": "/root/Main/HUD_Right/VBoxContainer/FightScrollContainer/FightPanel/PileInStepPanel/EndPileInButton", "emit_pressed": true },
    { "act": "wait_seconds", "seconds": 0.5 },

    { "act": "expect_node_visible", "node": "/root/FightSelectionDialog", "timeout_s": 5.0 },
    { "act": "click_node", "node": "/root/FightSelectionDialog/Content/UnitScroll/UnitList/Fight_U_WARBOSS_B", "emit_pressed": true },

    { "act": "expect_node_visible", "node": "/root/AttackAssignmentDialog", "timeout_s": 5.0 },
    { "act": "execute_script", "script": "main.get_tree().root.get_node(\"AttackAssignmentDialog\").weapon_list.item_count", "equals": 2 },
    { "act": "execute_script", "script": "main.get_tree().root.get_node(\"AttackAssignmentDialog\").weapon_list.select(0)" },
    { "act": "click_node", "node": "/root/AttackAssignmentDialog/Content/ButtonContainer/AssignButton", "emit_pressed": true },
    { "act": "execute_script", "script": "main.get_tree().root.get_node(\"AttackAssignmentDialog\").assignments.size()", "equals": 1 },
    { "act": "execute_script", "script": "main.get_tree().root.get_node(\"AttackAssignmentDialog\").assignments[0][\"weapon\"]", "equals": "big_choppa_melee" },
    { "act": "execute_script", "script": "main.get_tree().root.get_node(\"AttackAssignmentDialog\").weapon_list.select(1)" },
    { "act": "click_node", "node": "/root/AttackAssignmentDialog/Content/ButtonContainer/AssignButton", "emit_pressed": true },
    { "act": "execute_script", "script": "main.get_tree().root.get_node(\"AttackAssignmentDialog\").assignments.size()", "equals": 1 },
    { "act": "execute_script", "script": "main.get_tree().root.get_node(\"AttackAssignmentDialog\").assignments[0][\"weapon\"]", "equals": "power_klaw_melee" },
    { "act": "click_node", "node": "/root/AttackAssignmentDialog/Content/ButtonContainer/AllToTargetButton", "emit_pressed": true },
    { "act": "execute_script", "script": "main.get_tree().root.get_node(\"AttackAssignmentDialog\").assignments.size()", "equals": 1 },
    { "act": "screenshot", "label": "01_second_weapon_replaced_not_stacked" },

    { "act": "click_node", "node": "/root/AttackAssignmentDialog/Content/ButtonContainer/ConfirmButton", "emit_pressed": true },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "PhaseManager.get_current_phase_instance().staged_fight_state[\"assignments\"].size()", "equals": 2 },
    { "act": "execute_script", "script": "PhaseManager.get_current_phase_instance().staged_fight_state[\"assignments\"][0][\"weapon\"]", "equals": "power_klaw_melee" },
    { "act": "execute_script", "script": "PhaseManager.get_current_phase_instance().staged_fight_state[\"assignments\"][1][\"weapon\"]", "equals": "attack_squig_melee" },
    { "act": "screenshot", "label": "02_warboss_fights_klaw_plus_extra_attacks_only" },
    { "act": "execute_script", "script": "main.get_tree().root.get_node(\"FightSequenceDialog\").debug_click_through(12)" },
    { "act": "wait_frames", "frames": 4 },
    { "act": "click_node", "node": "/root/FightSequenceDialog/Content/Buttons/CloseButton", "emit_pressed": true },
    { "act": "wait_seconds", "seconds": 1.0 },

    { "act": "expect_node_visible", "node": "/root/FightSelectionDialog", "timeout_s": 8.0 },
    { "act": "click_node", "node": "/root/FightSelectionDialog/Content/UnitScroll/UnitList/Fight_U_CUSTODIAN_GUARD_B", "emit_pressed": true },
    { "act": "expect_node_visible", "node": "/root/KatahStanceDialog", "timeout_s": 5.0 },
    { "act": "click_node", "node": "/root/KatahStanceDialog/Content/Buttons/DacataraiButton", "emit_pressed": true },
    { "act": "expect_node_visible", "node": "/root/AttackAssignmentDialog", "timeout_s": 5.0 },

    { "act": "dispatch_action", "action": { "type": "ASSIGN_ATTACKS", "unit_id": "U_CUSTODIAN_GUARD_B", "target_id": "U_WARBOSS_B", "weapon_id": "misericordia_melee", "player": 1 } },
    { "act": "expect_action_result", "path": "success", "equals": true },
    { "act": "execute_script", "script": "PhaseManager.get_current_phase_instance().pending_attacks.size()", "equals": 1 },
    { "act": "dispatch_action", "action": { "type": "ASSIGN_ATTACKS", "unit_id": "U_CUSTODIAN_GUARD_B", "target_id": "U_WARBOSS_B", "weapon_id": "guardian_spear_melee", "player": 1 } },
    { "act": "expect_action_result", "path": "success", "equals": false },
    { "act": "execute_script", "script": "PhaseManager.get_current_phase_instance().pending_attacks.size()", "equals": 1 },
    { "act": "execute_script", "script": "PhaseManager.get_current_phase_instance().pending_attacks.clear()" },

    { "act": "click_node", "node": "/root/AttackAssignmentDialog/Content/ButtonContainer/AllToTargetButton", "emit_pressed": true },
    { "act": "execute_script", "script": "main.get_tree().root.get_node(\"AttackAssignmentDialog\").assignments.size()", "equals": 1 },
    { "act": "click_node", "node": "/root/AttackAssignmentDialog/Content/ButtonContainer/ConfirmButton", "emit_pressed": true },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "PhaseManager.get_current_phase_instance().staged_fight_state[\"assignments\"].size()", "equals": 1 },
    { "act": "execute_script", "script": "PhaseManager.get_current_phase_instance().staged_fight_state[\"assignments\"][0][\"weapon\"]", "equals": "guardian_spear_melee" },
    { "act": "screenshot", "label": "03_guard_fights_single_weapon_of_three" },
    { "act": "execute_script", "script": "main.get_tree().root.get_node(\"FightSequenceDialog\").debug_click_through(12)" },
    { "act": "wait_frames", "frames": 4 },
    { "act": "click_node", "node": "/root/FightSequenceDialog/Content/Buttons/CloseButton", "emit_pressed": true },
    { "act": "wait_seconds", "seconds": 1.0 },
    { "act": "screenshot", "label": "04_fight_flow_continues_normally" },
    { "act": "execute_script", "script": "SettingsService.set_auto_allocate_wounds(false)" }
  ]
}
