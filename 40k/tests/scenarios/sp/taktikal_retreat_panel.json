{
 "id": "taktikal_retreat_panel",
 "covers": [
  "movement.stratagem.taktikal_retreat",
  "stratagems.taktikal_brigade.loading",
  "ui.StratagemPanel.faction_rows",
  "ui.StratagemPanel.friendly_target_picker",
  "autoloads.StratagemManager.target_condition_enforcement"
 ],
 "fixture": "co_pretrigger",
 "edition": 11,
 "rng_seed": 42,
 "transition_to_phase": 7,
 "disable_ai": true,
 "description": "TAKTIKAL RETREAT (Taktikal Brigade, 1 CP) driven through the real player path: the Ork player (P2, active) opens the Stratagem Panel from the HUD button, presses Use on the TAKTIKAL RETREAT row, and picks the one eligible unit in the friendly-target dialog. Asserts the fall-back-and-shoot / fall-back-and-charge flags land on the unit and 1 CP is spent. Setup-only privileges (documented): the fixture's Ork detachment is flipped from War Horde to Taktikal Brigade + faction stratagems reloaded (no Taktikal fixture save exists), and U_BOYZ_K gets flags.fell_back=true to stand in for a fall-back move made earlier in the phase — the stratagem targeting, panel UI, picker dialog and effect application are all real. The picker listing ONLY U_BOYZ_K also proves the parsed target conditions (ORKS + Fell Back this phase) are enforced per-target.",
 "steps": [
  { "act": "wait_seconds", "seconds": 0.8 },
  { "act": "expect_phase", "equals": 7 },
  { "act": "execute_script", "script": "GameState.state[\"factions\"][\"2\"].merge({\"detachment\": \"Taktikal Brigade\"}, true)" },
  { "act": "execute_script", "script": "StratagemManager.load_faction_stratagems_for_player(2)" },
  { "act": "execute_script", "script": "GameState.get_unit(\"U_BOYZ_K\")[\"flags\"].merge({\"fell_back\": true}, true)" },
  { "act": "execute_script", "script": "StratagemManager.get_implemented_faction_stratagems_for_player(2).size()", "equals": 6 },
  { "act": "click_node", "node": "/root/Main/HUD_Bottom/HBoxContainer/StratagemPanelButton", "emit_pressed": true },
  { "act": "expect_node_visible", "node": "/root/Main/StratagemPanel" },
  { "act": "screenshot", "label": "01_panel_open" },
  { "act": "click_node", "node": "/root/Main/StratagemPanel/Scroll/List/Strat_faction_ork_taktikal_brigade_taktikal_retreat/Row/Use_faction_ork_taktikal_brigade_taktikal_retreat", "emit_pressed": true },
  { "act": "expect_node_visible", "node": "/root/StratagemTargetDialog" },
  { "act": "screenshot", "label": "02_unit_picker" },
  { "act": "execute_script", "script": "ScenarioRunner.get_node(\"/root/StratagemTargetDialog/Content\").get_child_count()", "equals": 1 },
  { "act": "click_node", "node": "/root/StratagemTargetDialog/Content/Pick_U_BOYZ_K", "emit_pressed": true },
  { "act": "wait_frames", "frames": 3 },
  { "act": "expect_state", "path": "units.U_BOYZ_K.flags.effect_fall_back_and_shoot", "equals": true },
  { "act": "expect_state", "path": "units.U_BOYZ_K.flags.effect_fall_back_and_charge", "equals": true },
  { "act": "expect_cp", "player": 2, "delta_from_start": -1 },
  { "act": "screenshot", "label": "03_after_use" }
 ]
}
