{
  "id": "objective_contested_vs_uncontrolled",
  "covers": [
    "scoring.objective_control.contested_vs_uncontrolled",
    "scoring.terrain_objective_14_01"
  ],
  "fixture": "audit_383_battleshock_shoot",
  "edition": 11,
  "description": "Mek-contested-status bug: (1) an EMPTY objective must read 'Uncontrolled' on the board label, never 'CONTESTED'; (2) a model whose base only PARTIALLY overlaps a terrain-hosted objective area (centre point outside the polygon) must control it; (3) 'CONTESTED' is reserved for a genuine stand-off (equal, nonzero OC on both sides). Stage A: every unit near obj_center is parked far from all objective-hosting areas, control re-checked, and the on-board ControlIndicator label must say 'Uncontrolled' (pre-fix it said CONTESTED). Stage B: the 11e layout disruption_vs_purge_the_foe_1 is loaded and objectives re-derived so obj_center is hosted by the two Center trapezoids; the Shield-Captain (40mm base, radius 31.5px) is placed at (660,1200) - 20px left of trapezoid-1's x=680 edge, centre OUTSIDE the area, base overlapping it by ~11px - and must now control obj_center ('Adeptus Custodes' label; pre-fix the centre-point-only check left it at 0/CONTESTED). Stage C: an alive Ork Boyz model (unit OC 2, equal to the Shield-Captain's 2) moves inside trapezoid-1 -> genuine tie -> label 'CONTESTED' and is_objective_contested true.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "expect_state", "path": "meta.phase", "equals": 8 },
    { "act": "screenshot", "label": "00_fixture_loaded" },

    { "act": "execute_script",
      "script": "GameState.state[\"units\"][\"U_SHIELD_CAPTAIN_A\"][\"models\"][0].merge({\"position\": Vector2(880.0, 2200.0)}, true)" },
    { "act": "execute_script",
      "script": "GameState.state[\"units\"][\"U_CALADIUS_GRAV-TANK_E\"][\"models\"][0].merge({\"position\": Vector2(1680.0, 1200.0)}, true)" },
    { "act": "execute_script",
      "script": "GameState.state[\"units\"][\"U_TELEMON_HEAVY_DREADNOUGHT_I\"][\"models\"][0].merge({\"position\": Vector2(80.0, 1200.0)}, true)" },
    { "act": "execute_script",
      "script": "GameState.state[\"units\"][\"U_CONTEMPTOR-ACHILLUS_DREADNOUGHT_H\"][\"models\"][0].merge({\"position\": Vector2(880.0, 80.0)}, true)" },
    { "act": "execute_script",
      "script": "GameState.state[\"units\"][\"U_KOMMANDOS_H\"][\"models\"][1].merge({\"position\": Vector2(940.0, 2260.0)}, true)" },
    { "act": "execute_script",
      "script": "GameState.state[\"units\"][\"U_KOMMANDOS_H\"][\"models\"][2].merge({\"position\": Vector2(1000.0, 2260.0)}, true)" },
    { "act": "execute_script",
      "script": "main._sync_all_token_positions()" },
    { "act": "execute_script",
      "script": "MissionManager.check_all_objectives()" },
    { "act": "wait_frames", "frames": 2 },

    { "act": "execute_script",
      "script": "MissionManager.objective_control_state.get(\"obj_center\", -1)",
      "equals": 0 },
    { "act": "execute_script",
      "script": "MissionManager.is_objective_contested(\"obj_center\")",
      "equals": false },
    { "act": "execute_script",
      "script": "MissionManager.objectives_visual_refs[\"obj_center\"].control_indicator.text",
      "equals": "Uncontrolled" },
    { "act": "execute_script",
      "script": "main.fit_view_to_board()" },
    { "act": "wait_for_tweens", "timeout_s": 6.0 },
    { "act": "wait_frames", "frames": 2 },
    { "act": "screenshot", "label": "01_empty_objective_reads_uncontrolled" },

    { "act": "execute_script",
      "script": "TerrainManager.load_terrain_layout(\"disruption_vs_purge_the_foe_1\")" },
    { "act": "wait_frames", "frames": 8 },
    { "act": "execute_script",
      "script": "MissionManager._setup_objectives_for_deployment(\"search_and_destroy\")" },
    { "act": "execute_script",
      "script": "MissionManager._get_objective_by_id(\"obj_center\").get(\"source_pieces\", []).size()",
      "equals": 2 },

    { "act": "execute_script",
      "script": "GameState.state[\"units\"][\"U_SHIELD_CAPTAIN_A\"][\"models\"][0].merge({\"position\": Vector2(660.0, 1200.0)}, true)" },
    { "act": "execute_script",
      "script": "main._sync_all_token_positions()" },
    { "act": "execute_script",
      "script": "TerrainManager.area_at(Vector2(660, 1200)).is_empty()",
      "equals": true },
    { "act": "execute_script",
      "script": "MissionManager.check_all_objectives()" },
    { "act": "wait_frames", "frames": 2 },

    { "act": "execute_script",
      "script": "MissionManager.objective_control_state.get(\"obj_center\", -1)",
      "equals": 1 },
    { "act": "execute_script",
      "script": "MissionManager.is_objective_contested(\"obj_center\")",
      "equals": false },
    { "act": "execute_script",
      "script": "MissionManager.objectives_visual_refs[\"obj_center\"].control_indicator.text",
      "equals": "Adeptus Custodes" },
    { "act": "execute_script",
      "script": "main.fit_view_to_selection(\"U_SHIELD_CAPTAIN_A\")" },
    { "act": "wait_for_tweens", "timeout_s": 6.0 },
    { "act": "wait_frames", "frames": 2 },
    { "act": "screenshot", "label": "02_partial_base_overlap_controls" },

    { "act": "execute_script",
      "script": "GameState.state[\"units\"][\"U_BOYZ_E\"][\"models\"][6].merge({\"position\": Vector2(750.0, 1000.0)}, true)" },
    { "act": "execute_script",
      "script": "main._sync_all_token_positions()" },
    { "act": "execute_script",
      "script": "MissionManager.check_all_objectives()" },
    { "act": "wait_frames", "frames": 2 },

    { "act": "execute_script",
      "script": "MissionManager.objective_control_state.get(\"obj_center\", -1)",
      "equals": 0 },
    { "act": "execute_script",
      "script": "MissionManager.is_objective_contested(\"obj_center\")",
      "equals": true },
    { "act": "execute_script",
      "script": "MissionManager.objectives_visual_refs[\"obj_center\"].control_indicator.text",
      "equals": "CONTESTED" },
    { "act": "execute_script",
      "script": "main.fit_view_to_selection(\"U_SHIELD_CAPTAIN_A\")" },
    { "act": "wait_for_tweens", "timeout_s": 6.0 },
    { "act": "wait_frames", "frames": 2 },
    { "act": "screenshot", "label": "03_genuine_tie_reads_contested" }
  ]
}
