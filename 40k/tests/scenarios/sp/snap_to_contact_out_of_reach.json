{
  "id": "snap_to_contact_out_of_reach",
  "covers": ["charge.ux.snap_to_contact_button", "charge.base_contact.closest_fallback", "charge.ux.snap_out_of_reach_best_effort"],
  "fixture": "test_charge_snap_short",
  "edition": 11,
  "rng_seed": 42,
  "transition_to_phase": 9,
  "disable_ai": true,
  "description": "Snap to Contact when NO model can reach base contact: 3 Boyz at exactly 5.94\"/7.5\"/8.5\" edge distance from a lone Shield-Captain, charge distance forced to 5\". Base contact (and even the 0.9\" near-contact sweep tier, which needs 5.04\") is out of reach for every model, so the pre-fix handler placed nothing and the button read as dead — the reported 'Snap to Contact does not seem to do anything' bug. After the fix the button must move every model as close as possible instead: the nearest model is pushed just inside the 1\" engagement band (0.95\" gap, 4.99\" of the 5\" roll), and the two out-of-range models spend their full 5\" straight toward the target, ending at 2.5\" and 3.5\" gaps. Confirm must then apply the charge through the real APPLY_CHARGE_MOVE pipeline — proving the best-effort placements satisfy the phase's ER-with-target, coherency, 11.04 base-contact-if-possible and distance validation.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.8 },
    { "act": "expect_state", "path": "meta.phase", "equals": 9 },
    { "act": "expect_state", "path": "meta.active_player", "equals": 2 },

    { "act": "execute_script",
      "script": "GameState.state.players[\"1\"].merge({\"cp\": 0}, true)" },
    { "act": "execute_script",
      "script": "GameState.state.players[\"2\"].merge({\"cp\": 0}, true)" },
    { "act": "screenshot", "label": "01_charge_phase_start" },

    { "act": "execute_script",
      "script": "Measurement.model_to_model_distance_inches(GameState.get_unit(\"U_CHARGER_0\").models[0], GameState.get_unit(\"U_TARGET_SC\").models[0])",
      "expect_min": 5.9 },
    { "act": "execute_script",
      "script": "Measurement.model_to_model_distance_inches(GameState.get_unit(\"U_CHARGER_0\").models[0], GameState.get_unit(\"U_TARGET_SC\").models[0])",
      "expect_max": 6.0 },

    { "act": "execute_script",
      "script": "main.charge_controller.unit_selector.select(0)" },
    { "act": "execute_script",
      "script": "main.charge_controller._on_unit_selected(0)" },
    { "act": "execute_script",
      "script": "main.charge_controller.active_unit_id", "equals": "U_CHARGER_0" },
    { "act": "execute_script",
      "script": "main.charge_controller.target_list.select(0)" },
    { "act": "execute_script",
      "script": "main.charge_controller._on_target_selected(0)" },
    { "act": "execute_script",
      "script": "main.charge_controller._on_declare_charge_pressed()" },
    { "act": "wait_seconds", "seconds": 0.2 },
    { "act": "execute_script",
      "script": "main.charge_controller._on_roll_charge_pressed()" },
    { "act": "wait_seconds", "seconds": 0.3 },

    { "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().has_pending_charge(\"U_CHARGER_0\")",
      "equals": true },
    { "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().pending_charges[\"U_CHARGER_0\"].merge({\"distance\": 5}, true)" },
    { "act": "execute_script",
      "script": "main.charge_controller.set(\"charge_distance\", 5)" },
    { "act": "execute_script",
      "script": "main.charge_controller.models_to_move.size()", "equals": 3 },
    { "act": "screenshot", "label": "02_roll_forced_5in_before_snap" },

    { "act": "expect_node_visible",
      "node": "/root/Main/HUD_Right/VBoxContainer/ChargeScrollContainer/ChargePanel/ChargeActionButtons/ConfirmRow/SnapToContactButton" },
    { "act": "click_node",
      "node": "/root/Main/HUD_Right/VBoxContainer/ChargeScrollContainer/ChargePanel/ChargeActionButtons/ConfirmRow/SnapToContactButton",
      "emit_pressed": true },
    { "act": "wait_seconds", "seconds": 0.3 },

    { "act": "execute_script",
      "script": "main.charge_controller.models_to_move.is_empty()", "equals": true },
    { "act": "execute_script",
      "script": "Measurement.model_to_model_distance_inches(GameState.get_unit(\"U_CHARGER_0\").models[0], GameState.get_unit(\"U_TARGET_SC\").models[0])",
      "expect_min": 0.9 },
    { "act": "execute_script",
      "script": "Measurement.model_to_model_distance_inches(GameState.get_unit(\"U_CHARGER_0\").models[0], GameState.get_unit(\"U_TARGET_SC\").models[0])",
      "expect_max": 1.0 },
    { "act": "execute_script",
      "script": "Measurement.model_to_model_distance_inches(GameState.get_unit(\"U_CHARGER_0\").models[1], GameState.get_unit(\"U_TARGET_SC\").models[0])",
      "expect_min": 2.4 },
    { "act": "execute_script",
      "script": "Measurement.model_to_model_distance_inches(GameState.get_unit(\"U_CHARGER_0\").models[1], GameState.get_unit(\"U_TARGET_SC\").models[0])",
      "expect_max": 2.6 },
    { "act": "execute_script",
      "script": "Measurement.model_to_model_distance_inches(GameState.get_unit(\"U_CHARGER_0\").models[2], GameState.get_unit(\"U_TARGET_SC\").models[0])",
      "expect_min": 3.4 },
    { "act": "execute_script",
      "script": "Measurement.model_to_model_distance_inches(GameState.get_unit(\"U_CHARGER_0\").models[2], GameState.get_unit(\"U_TARGET_SC\").models[0])",
      "expect_max": 3.6 },
    { "act": "execute_script",
      "script": "main.charge_controller.charge_info_label.text",
      "equals": "No model could reach base contact — all moved as close as possible. Confirm or adjust" },
    { "act": "screenshot", "label": "03_all_models_moved_as_close_as_possible" },
    { "act": "screenshot", "label": "03b_approach_closeup", "region": [1000, 280, 280, 180] },

    { "act": "expect_node_property",
      "node": "/root/Main/HUD_Right/VBoxContainer/ChargeScrollContainer/ChargePanel/ChargeActionButtons/ConfirmRow/ConfirmChargeButton",
      "property": "disabled", "equals": false },
    { "act": "click_node",
      "node": "/root/Main/HUD_Right/VBoxContainer/ChargeScrollContainer/ChargePanel/ChargeActionButtons/ConfirmRow/ConfirmChargeButton",
      "emit_pressed": true },
    { "act": "wait_seconds", "seconds": 0.8 },

    { "act": "expect_state", "path": "units.U_CHARGER_0.flags.charged_this_turn", "equals": true },
    { "act": "execute_script",
      "script": "\"U_CHARGER_0\" in PhaseManager.get_current_phase_instance().get_completed_charges()",
      "equals": true },
    { "act": "execute_script",
      "script": "Measurement.model_to_model_distance_inches(GameState.get_unit(\"U_CHARGER_0\").models[0], GameState.get_unit(\"U_TARGET_SC\").models[0])",
      "expect_max": 1.0 },
    { "act": "screenshot", "label": "04_charge_confirmed" },

    { "act": "execute_script", "script": "main.charge_controller.awaiting_movement", "equals": false },
    { "act": "execute_script", "script": "main.charge_controller.auto_path_charge_button.visible", "equals": false }
  ]
}
