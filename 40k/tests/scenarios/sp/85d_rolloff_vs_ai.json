{
  "id": "85d_rolloff_vs_ai",
  "covers": [
    "deployment.predeploy_roll_off",
    "ui.RollOffDialog.shown_vs_ai",
    "ui.RollOffDialog.acknowledge_required",
    "ai.AIPlayer.roll_off_suppressed",
    "phases.RollOffPhase.ROLL_OFF_DEPLOYMENT"
  ],
  "fixture": "audit_367_warlord",
  "rng_seed": 4,
  "description": "Deployment roll-off vs AI. P2 is AI and is made active at the roll-off, yet (a) the AI must NOT auto-resolve the mutual roll (suppressed while a human is present), (b) the dramatic dialog is shown to the human, (c) the human rolls (seed 4 → AI wins 6 vs 1), and (d) the human must click Continue. The AI then deploys SECOND (Attacker): meta.attacker=2, meta.defender=1. The first turn is NOT decided here (first_turn_player stays unset).",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script", "script": "AIPlayer.configure({1: \"HUMAN\", 2: \"AI\"})" },
    { "act": "execute_script", "script": "PhaseManager.transition_to_phase(3)" },
    { "act": "execute_script", "script": "GameState.set_active_player(2)" },
    { "act": "wait_seconds", "seconds": 2.0 },

    { "act": "expect_state", "path": "meta.roll_off_winner", "exists": false },
    { "act": "expect_node_visible", "node": "/root/Main/RollOffDialog", "timeout_s": 2.0 },
    { "act": "screenshot", "label": "01_dialog_shown_ai_suppressed" },

    { "act": "click_node", "node": "/root/Main/RollOffDialog/Content/ButtonBar/RollButton", "emit_pressed": true },
    { "act": "wait_seconds", "seconds": 1.6 },

    { "act": "expect_state", "path": "meta.roll_off_winner", "equals": 2 },
    { "act": "expect_state", "path": "meta.attacker", "exists": false },
    { "act": "expect_node_visible", "node": "/root/Main/RollOffDialog/Content/ButtonBar/ContinueButton", "timeout_s": 2.0 },
    { "act": "screenshot", "label": "02_ai_won_continue_required" },

    { "act": "click_node", "node": "/root/Main/RollOffDialog/Content/ButtonBar/ContinueButton", "emit_pressed": true },
    { "act": "wait_seconds", "seconds": 0.5 },

    { "act": "expect_state", "path": "meta.attacker", "equals": 2 },
    { "act": "expect_state", "path": "meta.defender", "equals": 1 },
    { "act": "expect_state", "path": "meta.first_turn_player", "exists": false },
    { "act": "screenshot", "label": "03_resolved_after_ack" }
  ]
}
