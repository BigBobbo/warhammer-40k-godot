{
  "id": "pad_deploy_model_type_rows",
  "covers": [
    "controller.deploy.model_type_rows",
    "controller.deploy.dpad_row_navigation",
    "controller.deploy.start_confirms_unit",
    "deployment.model_type_picker_pad",
    "PadRouter",
    "ModelTypePickerPanel",
    "Main"
  ],
  "fixture": "audit_377_defender_first",
  "transition_to_phase": 1,
  "disable_ai": true,
  "description": "DEPLOY-CYCLE part 2: on a unit with multiple model profiles (Lootas: 8x Deffgun, 2x Kustom Mega-blasta, 1x Spanner) the D-pad ▲ ▼ moves the ▶ highlight between the Select Model Type and Deploy Formation rows, and ◀ ▶ cycles the options of the highlighted row (model types drive the same handler a picker-button click uses; formation cycling is unaffected by the type row). Placing the last model of a type pauses the picker exactly like the mouse flow, and one ▶ press resumes with the next available type. X undoes with the cursor parked, switching to a single-type unit collapses the rows back to formation-only, and Start confirms the unit once every model is placed (turn passes to the other player).",
  "steps": [
    { "act": "wait_seconds", "seconds": 1.2 },
    { "act": "expect_state", "path": "meta.phase", "equals": 1 },
    { "act": "expect_state", "path": "meta.active_player", "equals": 2 },

    { "act": "execute_script", "multiline": true, "script": "var m = tree.current_scene\nvar list = m.unit_list\nfor i in range(list.item_count):\n\tif str(list.get_item_metadata(i)) == \"U_LOOTAS_A\":\n\t\tlist.select(i)\n\t\tlist.item_selected.emit(i)\n\t\treturn true\nreturn false", "equals": true },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "main.deployment_controller.unit_id", "equals": "U_LOOTAS_A" },
    { "act": "execute_script", "script": "main.deployment_controller.has_model_type_picker", "equals": true },
    { "act": "execute_script", "script": "main.deployment_controller.selected_model_type", "equals": "" },
    { "act": "execute_script", "script": "main.deployment_controller.ghost_sprite == null", "equals": true },
    { "act": "execute_script", "script": "main._deploy_active_pad_row()", "equals": "model_type" },
    { "act": "execute_script", "script": "main.deployment_controller.model_type_picker_panel._title_label.text", "equals": "▶ Select Model Type" },
    { "act": "execute_script", "script": "main.unit_list.visible", "equals": true },
    { "act": "screenshot", "label": "01_picker_waiting_type_row_highlighted" },

    { "act": "simulate_joy_button", "button_index": 14 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main.deployment_controller.selected_model_type", "equals": "loota_deffgun" },
    { "act": "execute_script", "script": "main.deployment_controller.ghost_sprite != null", "equals": true },
    { "act": "execute_script", "script": "main.deployment_controller.model_type_picker_panel.selected_type", "equals": "loota_deffgun" },
    { "act": "simulate_joy_button", "button_index": 14 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main.deployment_controller.selected_model_type", "equals": "loota_kmb" },
    { "act": "simulate_joy_button", "button_index": 13 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main.deployment_controller.selected_model_type", "equals": "loota_deffgun" },
    { "act": "simulate_joy_button", "button_index": 13 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main.deployment_controller.selected_model_type", "equals": "spanner" },
    { "act": "screenshot", "label": "02_type_cycled_to_spanner" },

    { "act": "simulate_joy_button", "button_index": 12 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main._deploy_active_pad_row()", "equals": "formation" },
    { "act": "execute_script", "script": "main.unit_card.get_node(\"FormationControls/FormationLabel\").text", "equals": "▶ Deploy Formation:" },
    { "act": "execute_script", "script": "main.deployment_controller.model_type_picker_panel._title_label.text", "equals": "Select Model Type" },
    { "act": "simulate_joy_button", "button_index": 14 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main.deployment_controller.formation_mode", "equals": "SPREAD" },
    { "act": "execute_script", "script": "main.deployment_controller.selected_model_type", "equals": "spanner" },
    { "act": "screenshot", "label": "03_formation_row_highlighted_spread" },
    { "act": "simulate_joy_button", "button_index": 13 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main.deployment_controller.formation_mode", "equals": "SINGLE" },

    { "act": "simulate_joy_button", "button_index": 11 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main._deploy_active_pad_row()", "equals": "model_type" },
    { "act": "execute_script", "script": "main.unit_card.get_node(\"FormationControls/FormationLabel\").text", "equals": "Deploy Formation:" },
    { "act": "execute_script", "script": "main.deployment_controller.model_type_picker_panel._title_label.text", "equals": "▶ Select Model Type" },

    { "act": "execute_script", "script": "InputDeviceManager.set_meta(\"ptype\", str(main.deployment_controller.selected_model_type))" },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "VirtualCursor.is_cursor_active()", "equals": true },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "main.deployment_controller.get_placed_count()", "equals": 1 },
    { "act": "execute_script", "script": "str(main.deployment_controller._get_effective_models()[main.deployment_controller.placement_order.back()].get(\"model_type\", \"\")) == str(InputDeviceManager.get_meta(\"ptype\"))", "equals": true },
    { "act": "execute_script", "script": "main.deployment_controller.selected_model_type", "equals": "" },
    { "act": "execute_script", "script": "main.deployment_controller.ghost_sprite == null", "equals": true },
    { "act": "screenshot", "label": "04_spanner_placed_picker_waiting_again" },

    { "act": "simulate_joy_button", "button_index": 14 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main.deployment_controller.selected_model_type", "equals": "loota_deffgun" },
    { "act": "execute_script", "script": "main.deployment_controller.ghost_sprite != null", "equals": true },

    { "act": "simulate_joy_button", "button_index": 2 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script", "script": "main.deployment_controller.get_placed_count()", "equals": 0 },

    { "act": "execute_script", "multiline": true, "script": "var m = tree.current_scene\nvar list = m.unit_list\nfor i in range(list.item_count):\n\tif str(list.get_item_metadata(i)) == \"U_WARBOSS_B\":\n\t\tlist.select(i)\n\t\tlist.item_selected.emit(i)\n\t\treturn true\nreturn false", "equals": true },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "main.deployment_controller.unit_id", "equals": "U_WARBOSS_B" },
    { "act": "execute_script", "script": "main.deployment_controller.has_model_type_picker", "equals": false },
    { "act": "execute_script", "script": "main._deploy_active_pad_row()", "equals": "formation" },

    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "main.deployment_controller.get_placed_count()", "equals": 1 },

    { "act": "simulate_joy_button", "button_index": 6 },
    { "act": "wait_seconds", "seconds": 0.8 },
    { "act": "expect_state", "path": "units.U_WARBOSS_B.status", "equals": 2 },
    { "act": "execute_script", "script": "main.deployment_controller.is_placing()", "equals": false },
    { "act": "expect_state", "path": "meta.active_player", "equals": 1 },
    { "act": "screenshot", "label": "05_start_confirmed_warboss_turn_passed" }
  ]
}
