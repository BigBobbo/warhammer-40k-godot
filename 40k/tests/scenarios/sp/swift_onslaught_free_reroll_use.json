{
  "id": "swift_onslaught_free_reroll_use",
  "covers": [
    "charge.ability_reroll.free_dialog_branding",
    "dialogs.CommandRerollDialog.free_ability_mode"
  ],
  "fixture": "attached_char_charge_overlap",
  "edition": 11,
  "rng_seed": 42,
  "transition_to_phase": 9,
  "disable_ai": true,
  "description": "Swift Onslaught free charge re-roll is usable at 0 CP (user report 2026-07-17): Blade Champion A leads Custodian Guard B, player 1 has 0 CP. Runs at edition 11 (the player default — ER 2\", matching the reported game); the enemy Boyz start 1.8\" from the guard in this fixture so they are nudged to 4.6\" edge-to-edge to make the charge declarable at 11e. The guard declares a charge and rolls 2D6; the ability re-roll dialog must present as the FREE Swift Onslaught re-roll — header 'SWIFT ONSLAUGHT — FREE RE-ROLL', 'Re-roll (Free)' button, 'FREE — costs no CP' line — NOT as the 1 CP Command Re-roll stratagem (the bug: at 0 CP the old 'Re-roll (1 CP)' / 'You have 0 CP' branding read as unaffordable). Clicking Re-roll (Free) re-rolls the 2D6 with player 1 still at 0 CP.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.8 },
    { "act": "expect_phase", "equals": 9 },
    { "act": "expect_state", "path": "meta.active_player", "equals": 1 },
    { "act": "expect_cp", "player": 1, "equals": 0 },
    { "act": "expect_state", "path": "units.U_CUSTODIAN_GUARD_B.attachment_data.attached_characters.0", "equals": "U_BLADE_CHAMPION_A" },
    { "act": "expect_state", "path": "units.U_CUSTODIAN_GUARD_B.flags.effect_reroll_charge", "equals": true },

    { "act": "execute_script",
      "script": "GameState.state.units[\"U_ENEMY_BOYZ_X\"].models[0].merge({\"position\": {\"x\": 600.0, \"y\": 480.0}}, true)" },
    { "act": "execute_script", "script": "main.update_unit_visuals(\"U_ENEMY_BOYZ_X\")" },
    { "act": "wait_frames", "frames": 5 },
    { "act": "execute_script",
      "script": "RulesEngine.is_unit_engaged(\"U_CUSTODIAN_GUARD_B\", GameState.state)",
      "equals": false },
    { "act": "screenshot", "label": "01_charge_phase_0cp" },

    { "act": "dispatch_action", "action": { "type": "DECLARE_CHARGE", "actor_unit_id": "U_CUSTODIAN_GUARD_B", "payload": { "target_unit_ids": ["U_ENEMY_BOYZ_X"] } } },
    { "act": "expect_action_result", "path": "success", "equals": true },
    { "act": "dispatch_action", "action": { "type": "CHARGE_ROLL", "actor_unit_id": "U_CUSTODIAN_GUARD_B" } },
    { "act": "expect_action_result", "path": "success", "equals": true },
    { "act": "expect_action_result", "path": "awaiting_ability_reroll", "equals": true },

    { "act": "expect_node_visible", "node": "/root/CommandRerollDialog", "timeout_s": 3.0 },
    { "act": "execute_script",
      "script": "var d = tree.root.get_node_or_null(\"CommandRerollDialog\")\nreturn d.get_node(\"Content/HeaderLabel\").text",
      "multiline": true,
      "equals": "SWIFT ONSLAUGHT — FREE RE-ROLL" },
    { "act": "execute_script",
      "script": "var d = tree.root.get_node_or_null(\"CommandRerollDialog\")\nreturn d.get_node(\"Content/SubheaderLabel\").text",
      "multiline": true,
      "equals": "Unit Ability — Free Re-roll" },
    { "act": "execute_script",
      "script": "var d = tree.root.get_node_or_null(\"CommandRerollDialog\")\nreturn d.get_node(\"Content/CpLabel\").text",
      "multiline": true,
      "equals": "FREE — costs no CP" },
    { "act": "execute_script",
      "script": "var d = tree.root.get_node_or_null(\"CommandRerollDialog\")\nreturn d.get_node(\"Content/ButtonRow/UseRerollButton\").text",
      "multiline": true,
      "equals": "Re-roll (Free)" },
    { "act": "screenshot", "label": "02_free_reroll_dialog_branding" },

    { "act": "click_node", "node": "/root/CommandRerollDialog/Content/ButtonRow/UseRerollButton", "emit_pressed": true },
    { "act": "wait_seconds", "seconds": 0.5 },

    { "act": "execute_script",
      "script": "return tree.root.get_node_or_null(\"CommandRerollDialog\") == null",
      "multiline": true,
      "equals": true },
    { "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().ability_reroll_used",
      "equals": true },
    { "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().awaiting_ability_reroll",
      "equals": false },
    { "act": "expect_cp", "player": 1, "equals": 0 },
    { "act": "screenshot", "label": "03_after_free_reroll_used" }
  ]
}
