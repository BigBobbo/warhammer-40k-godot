{
  "id": "keybindings_no_conflicts",
  "covers": [
    "autoloads/KeybindingManager.gd",
    "scripts/Main.gd",
    "keybindings.deconflict",
    "keybindings.rotate_board_v"
  ],
  "fixture": "audit_baseline_postdeploy",
  "rng_seed": 42,
  "transition_to_phase": 7,
  "description": "Regression gate for the duplicate-keybinding fix. The reported bug was that V toggled the VP timeline instead of rotating the board because two actions shared V. Seven always-active keys had two actions each (V, G, R, W, A, S, F); the fundamental/advertised binding keeps the plain letter and the accidental collider moved to Shift+letter. Stage A asserts the new binding table. Stage B asserts no registered conflict remains on the fixed keys. Stage C drives the real UI: plain V rotates the board (view_rotation -> PI/2) and does NOT open the VP timeline, Shift+V opens it; plain G/W/A/S do NOT trigger their old overlays (so the camera/terrain keys are unshadowed) while Shift+G/W/A/S do.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.8 },
    { "act": "expect_state", "path": "meta.phase", "equals": 7 },

    { "act": "execute_script", "script": "KeybindingManager.get_binding(\"rotate_board\").key == OS.find_keycode_from_string(\"V\") and not KeybindingManager.get_binding(\"rotate_board\").shift", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.get_binding(\"toggle_vp_timeline\").key == OS.find_keycode_from_string(\"V\") and KeybindingManager.get_binding(\"toggle_vp_timeline\").shift", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.get_binding(\"toggle_terrain\").key == OS.find_keycode_from_string(\"G\") and not KeybindingManager.get_binding(\"toggle_terrain\").shift", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.get_binding(\"toggle_grid_overlay\").key == OS.find_keycode_from_string(\"G\") and KeybindingManager.get_binding(\"toggle_grid_overlay\").shift", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.get_binding(\"weapon_range_panel\").key == OS.find_keycode_from_string(\"W\") and KeybindingManager.get_binding(\"weapon_range_panel\").shift", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.get_binding(\"toggle_aura_rings\").key == OS.find_keycode_from_string(\"A\") and KeybindingManager.get_binding(\"toggle_aura_rings\").shift", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.get_binding(\"toggle_stratagem_panel\").key == OS.find_keycode_from_string(\"S\") and KeybindingManager.get_binding(\"toggle_stratagem_panel\").shift", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.get_binding(\"toggle_replay_panel\").key == OS.find_keycode_from_string(\"P\") and KeybindingManager.get_binding(\"toggle_replay_panel\").shift", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.get_binding(\"focus_p2_zone\").key == OS.find_keycode_from_string(\"E\") and KeybindingManager.get_binding(\"focus_p2_zone\").shift", "equals": true },

    { "act": "execute_script", "script": "KeybindingManager.find_conflict(\"rotate_board\", OS.find_keycode_from_string(\"V\"), false, false, false, false) == \"\"", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.find_conflict(\"toggle_terrain\", OS.find_keycode_from_string(\"G\"), false, false, false, false) == \"\"", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.find_conflict(\"camera_pan_up\", OS.find_keycode_from_string(\"W\"), false, false, false, false) == \"\"", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.find_conflict(\"camera_pan_left\", OS.find_keycode_from_string(\"A\"), false, false, false, false) == \"\"", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.find_conflict(\"fit_view_board\", OS.find_keycode_from_string(\"F\"), false, false, false, false) == \"\"", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.find_conflict(\"ruler_tool\", OS.find_keycode_from_string(\"R\"), false, false, false, false) == \"\"", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.find_conflict(\"toggle_vp_timeline\", OS.find_keycode_from_string(\"V\"), true, false, false, false) == \"\"", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.find_conflict(\"toggle_stratagem_panel\", OS.find_keycode_from_string(\"S\"), true, false, false, false) == \"\"", "equals": true },

    { "act": "execute_script", "script": "main.view_rotation", "equals": 0.0 },
    { "act": "execute_script", "script": "main._vp_timeline_panel == null", "equals": true },
    { "act": "simulate_key", "keycode": "V" },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "int(round(main.view_rotation * 1000))", "equals": 1571 },
    { "act": "execute_script", "script": "main._vp_timeline_panel == null", "equals": true },
    { "act": "screenshot", "label": "plain_v_rotates_board" },

    { "act": "simulate_key", "keycode": "V", "shift": true },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._vp_timeline_panel != null", "equals": true },
    { "act": "screenshot", "label": "shift_v_opens_vp_timeline" },
    { "act": "simulate_key", "keycode": "V", "shift": true },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._vp_timeline_panel == null", "equals": true },

    { "act": "execute_script", "script": "main._grid_overlay == null", "equals": true },
    { "act": "simulate_key", "keycode": "G" },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._grid_overlay == null", "equals": true },
    { "act": "simulate_key", "keycode": "G", "shift": true },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._grid_overlay != null", "equals": true },

    { "act": "execute_script", "script": "main._weapon_range_panel == null", "equals": true },
    { "act": "simulate_key", "keycode": "W" },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._weapon_range_panel == null", "equals": true },
    { "act": "simulate_key", "keycode": "W", "shift": true },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._weapon_range_panel != null", "equals": true },

    { "act": "execute_script", "script": "main._aura_rings_visible", "equals": false },
    { "act": "simulate_key", "keycode": "A" },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._aura_rings_visible", "equals": false },
    { "act": "simulate_key", "keycode": "A", "shift": true },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._aura_rings_visible", "equals": true },

    { "act": "execute_script", "script": "main._stratagem_panel == null", "equals": true },
    { "act": "simulate_key", "keycode": "S" },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._stratagem_panel == null", "equals": true },
    { "act": "simulate_key", "keycode": "S", "shift": true },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._stratagem_panel != null", "equals": true },
    { "act": "screenshot", "label": "shift_s_opens_stratagems" }
  ]
}
