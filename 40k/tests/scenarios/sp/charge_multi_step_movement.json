{
  "id": "charge_multi_step_movement",
  "covers": [
    "scripts.ChargeController.multi_step_charge_move",
    "charge.movement.multi_step_drag_accumulates"
  ],
  "fixture": "audit_372_charge_modifier",
  "edition": 11,
  "rng_seed": 42,
  "transition_to_phase": 9,
  "disable_ai": true,
  "description": "Multi-step charge movement (feature): a charging model can now be dragged in SEVERAL hops around an obstacle, each hop adding to the total distance until the charge roll is spent — mirroring the Movement phase. WARBOSS_B (owner 2) charges the Blade Champion with a friendly Mega-Armour Warboss blocking the straight line. Player path: DECLARE_CHARGE, CHARGE_ROLL (seed 23 -> 12), the real Command Re-roll dialog's 'Keep Roll' button is clicked (declines the reroll, resolves the roll, enables movement via the real charge_roll_made signal path). Each hop is a real drag_board (mouse press/motion/release InputEvents dispatched into the ChargeController's _input), then the real 'Confirm Charge Moves' button is clicked. Proves: (1) the model is re-draggable after the first drop via the real token-hit-test pickup (before the fix it was removed from models_to_move and could not be picked up again); (2) distance accumulates across hops (Used 4.6\" -> 5.8\") and is capped at the roll (an over-budget 3rd drag is rejected 'Movement too far: 5.8 prior + ... > 12', leaving the recorded path unchanged); (3) the confirmed path is the real 3-point polyline; (4) the charge completes into engagement range.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "expect_state", "path": "meta.phase", "equals": 9 },
    { "act": "expect_state", "path": "meta.active_player", "equals": 2 },

    { "act": "execute_script",
      "script": "GameState.state.units[\"U_WARBOSS_B\"].models[0].merge({\"position\": {\"x\": 300.0, \"y\": 1880.0}, \"rotation\": 0.0}, true)" },
    { "act": "execute_script",
      "script": "GameState.state.units[\"U_WARBOSS_IN_MEGA_ARMOUR_D\"].models[0].merge({\"position\": {\"x\": 300.0, \"y\": 2020.0}, \"rotation\": 0.0}, true)" },
    { "act": "execute_script",
      "script": "GameState.state.units[\"U_BLADE_CHAMPION_A\"].models[0].merge({\"position\": {\"x\": 300.0, \"y\": 2160.0}, \"rotation\": 0.0}, true)" },
    { "act": "execute_script",
      "script": "GameState.state.units[\"U_WARBOSS_B\"].merge({\"flags\": {}}, true)" },
    { "act": "execute_script", "script": "main.update_unit_visuals(\"U_WARBOSS_B\")" },
    { "act": "execute_script", "script": "main.update_unit_visuals(\"U_WARBOSS_IN_MEGA_ARMOUR_D\")" },
    { "act": "execute_script", "script": "main.update_unit_visuals(\"U_BLADE_CHAMPION_A\")" },
    { "act": "wait_for_tweens" },
    { "act": "wait_frames", "frames": 8 },

    { "act": "execute_script",
      "script": "min_edge_distance_between_units(\"U_WARBOSS_B\", \"U_BLADE_CHAMPION_A\")",
      "expect_min": 5.0, "expect_max": 5.9 },
    { "act": "screenshot", "label": "01_setup_charger_target_blocker" },

    { "act": "dispatch_action", "action": {
      "type": "DECLARE_CHARGE",
      "actor_unit_id": "U_WARBOSS_B",
      "payload": { "target_unit_ids": ["U_BLADE_CHAMPION_A"] }
    }},
    { "act": "expect_action_result", "path": "success", "equals": true },

    { "act": "dispatch_action", "action": {
      "type": "CHARGE_ROLL",
      "actor_unit_id": "U_WARBOSS_B",
      "payload": { "rng_seed": 23 }
    }},
    { "act": "expect_action_result", "path": "success", "equals": true },

    { "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().has_pending_charge(\"U_WARBOSS_B\")",
      "equals": true },

    { "act": "execute_script",
      "script": "get_tree().root.find_children(\"KeepRollButton\", \"\", true, false)[0].emit_signal(\"pressed\")" },
    { "act": "wait_frames", "frames": 6 },

    { "act": "execute_script",
      "script": "main.charge_controller.set(\"active_unit_id\", \"U_WARBOSS_B\")" },
    { "act": "execute_script",
      "script": "main.charge_controller.set(\"selected_targets\", [\"U_BLADE_CHAMPION_A\"])" },
    { "act": "execute_script",
      "script": "main.charge_controller.charge_distance",
      "equals": 12 },
    { "act": "execute_script",
      "script": "main.charge_controller.awaiting_movement",
      "equals": true },
    { "act": "execute_script",
      "script": "main.charge_controller.models_to_move.has(\"m1\")",
      "equals": true },
    { "act": "wait_frames", "frames": 5 },
    { "act": "screenshot", "label": "02_rolled_12_movement_enabled" },

    { "act": "drag_board", "from_x": 300, "from_y": 1880, "to_x": 420, "to_y": 2020, "steps": 10 },
    { "act": "wait_frames", "frames": 6 },
    { "act": "execute_script",
      "script": "Vector2(GameState.state.units[\"U_WARBOSS_B\"].models[0].position[\"x\"], GameState.state.units[\"U_WARBOSS_B\"].models[0].position[\"y\"]).distance_to(Vector2(420, 2020))",
      "expect_max": 12.0 },
    { "act": "execute_script",
      "script": "main.charge_controller.moved_models.has(\"m1\")",
      "equals": true },
    { "act": "execute_script",
      "script": "main.charge_controller._get_model_charge_accumulated(\"m1\")",
      "expect_min": 4.2, "expect_max": 5.0 },
    { "act": "screenshot", "label": "03_hop1_partial_move_around_blocker" },

    { "act": "drag_board", "from_x": 420, "from_y": 2020, "to_x": 386, "to_y": 2056, "steps": 8 },
    { "act": "wait_frames", "frames": 6 },
    { "act": "execute_script",
      "script": "Vector2(GameState.state.units[\"U_WARBOSS_B\"].models[0].position[\"x\"], GameState.state.units[\"U_WARBOSS_B\"].models[0].position[\"y\"]).distance_to(Vector2(386, 2056))",
      "expect_max": 12.0 },
    { "act": "execute_script",
      "script": "main.charge_controller._get_model_charge_accumulated(\"m1\")",
      "expect_min": 5.4, "expect_max": 6.3 },
    { "act": "execute_script",
      "script": "main.charge_controller._model_charge_paths[\"m1\"].size()",
      "equals": 3 },
    { "act": "screenshot", "label": "04_hop2_into_engagement_range" },

    { "act": "drag_board", "from_x": 386, "from_y": 2056, "to_x": 300, "to_y": 2315, "steps": 12 },
    { "act": "wait_frames", "frames": 6 },
    { "act": "execute_script",
      "script": "Vector2(GameState.state.units[\"U_WARBOSS_B\"].models[0].position[\"x\"], GameState.state.units[\"U_WARBOSS_B\"].models[0].position[\"y\"]).distance_to(Vector2(386, 2056))",
      "expect_max": 12.0 },
    { "act": "execute_script",
      "script": "main.charge_controller._model_charge_paths[\"m1\"].size()",
      "equals": 3 },
    { "act": "screenshot", "label": "05_overbudget_hop_reverted_cap_enforced" },

    { "act": "expect_node_property",
      "node": "/root/Main/HUD_Right/VBoxContainer/ChargeScrollContainer/ChargePanel/ChargeActionButtons/ConfirmRow/ConfirmChargeButton",
      "property": "disabled", "equals": false },
    { "act": "click_node",
      "node": "/root/Main/HUD_Right/VBoxContainer/ChargeScrollContainer/ChargePanel/ChargeActionButtons/ConfirmRow/ConfirmChargeButton",
      "emit_pressed": true },
    { "act": "wait_frames", "frames": 10 },

    { "act": "expect_state", "path": "units.U_WARBOSS_B.flags.charged_this_turn", "equals": true },
    { "act": "execute_script",
      "script": "min_edge_distance_between_units(\"U_WARBOSS_B\", \"U_BLADE_CHAMPION_A\")",
      "expect_max": 2.0 },
    { "act": "expect_token_visible", "unit_id": "U_WARBOSS_B" },
    { "act": "screenshot", "label": "06_charge_completed_multi_step" }
  ]
}
