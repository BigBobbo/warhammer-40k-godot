{
  "id": "85_predeploy_rolloff",
  "covers": [
    "deployment.predeploy_roll_off",
    "phases.RollOffPhase.ROLL_OFF_DEPLOYMENT",
    "phases.RollOffPhase.CHOOSE_DEPLOYMENT"
  ],
  "fixture": "audit_367_warlord",
  "transition_to_phase": 3,
  "disable_ai": true,
  "description": "10e roll-off #1 (pre-deployment): both players roll; the winner chooses to DEPLOY FIRST (Defender) or DEPLOY SECOND (Attacker). This decides deployment order ONLY — it must NOT set meta.first_turn_player. Drive with dice_roll=[5,3] (P1 wins) and choice='first' (P1 deploys first = Defender), then verify meta.defender=1, meta.attacker=2, and first_turn_player still unset.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "expect_state", "path": "meta.phase", "equals": 3 },
    { "act": "screenshot", "label": "01_rolloff_dialog_visible" },

    { "act": "dispatch_action", "action": {
      "type": "ROLL_OFF_DEPLOYMENT",
      "dice_roll": [5, 3]
    }},
    { "act": "expect_action_result", "path": "success", "equals": true },
    { "act": "expect_action_result", "path": "winner", "equals": 1 },
    { "act": "expect_state", "path": "meta.roll_off_winner", "equals": 1 },
    { "act": "screenshot", "label": "02_rolloff_p1_wins_5v3" },

    { "act": "dispatch_action", "action": {
      "type": "CHOOSE_DEPLOYMENT",
      "choice": "first"
    }},
    { "act": "expect_action_result", "path": "success", "equals": true },
    { "act": "expect_state", "path": "meta.defender", "equals": 1 },
    { "act": "expect_state", "path": "meta.attacker", "equals": 2 },
    { "act": "expect_state", "path": "meta.first_turn_player", "exists": false },
    { "act": "screenshot", "label": "03_p1_chose_deploy_first" }
  ]
}
