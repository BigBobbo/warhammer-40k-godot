{
  "id": "token_hover_tooltip",
  "covers": ["ui.token_hover_tooltip"],
  "fixture": "audit_baseline_postdeploy",
  "description": "Board token mouseover tooltip: hovering ANY model (own or opponent, anywhere on the board) shows the unit's real name, stats (from unit.meta.stats), model count and wound totals — no 'Unknown', no '?' placeholders. Hovering empty board hides the tooltip. Regression test for the schema mismatch (top-level name/stats vs meta.*) and the screen-vs-board coordinate mixup that made hover work only near the view transform's fixed point.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "expect_state", "path": "meta.phase", "equals": 6 },

    { "act": "hover_unit", "unit_id": "U_WARBOSS_B" },
    { "act": "expect_node_visible", "node": "/root/Main/TokenHoverTooltip", "timeout_s": 2.0 },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('Warboss')",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('M:6\"')",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('T:5')",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('Sv:4+')",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('W:6')",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('OC:1')",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('Models: 1/1')",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('Wounds: 6/6')",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('?')",
      "equals": false },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('Unknown')",
      "equals": false },
    { "act": "screenshot", "label": "01_opponent_warboss_tooltip" },

    { "act": "hover_unit", "unit_id": "U_CUSTODIAN_GUARD_B" },
    { "act": "expect_node_visible", "node": "/root/Main/TokenHoverTooltip", "timeout_s": 2.0 },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('Custodian Guard')",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('Sv:2+')",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('Models: 4/4')",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node('TokenHoverTooltip/TokenHoverLabel').get_parsed_text().contains('Wounds: 16/16')",
      "equals": true },
    { "act": "screenshot", "label": "02_own_custodian_tooltip" },

    { "act": "hover_board_at", "x": 880.0, "y": 1200.0 },
    { "act": "expect_node_property", "node": "/root/Main/TokenHoverTooltip", "property": "visible", "equals": false },
    { "act": "screenshot", "label": "03_empty_board_no_tooltip" }
  ]
}
