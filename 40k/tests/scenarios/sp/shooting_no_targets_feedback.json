{
  "id": "shooting_no_targets_feedback",
  "covers": ["shooting.no_eligible_targets_feedback"],
  "fixture": "audit_383_battleshock_shoot",
  "rng_seed": 42,
  "transition_to_phase": 8,
  "description": "Stompa silent-click bug: the unit list shows shooters that P3-96 refuses to select (no eligible targets — both Witchseekers squads carry only 12\" flamers with every Ork 25\"+ away). Selecting such a unit and clicking enemies used to do NOTHING silently. Now: selection explains why nothing is targetable (dice log + status label + toast) and a board click on an enemy appends the per-target reason. Index 6 may be either Witchseekers squad depending on list order — both have zero eligible targets.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "expect_state", "path": "meta.phase", "equals": 8 },
    { "act": "expect_state", "path": "meta.active_player", "equals": 1 },
    { "act": "screenshot", "label": "01_shooting_phase_loaded" },

    { "act": "dispatch_action", "action": {
      "type": "SELECT_SHOOTER",
      "actor_unit_id": "U_WITCHSEEKERS_C"
    }},
    { "act": "expect_action_result", "path": "success", "equals": false },

    { "act": "execute_script",
      "script": "str(main.get_node(\"ShootingController\").unit_selector.get_item_metadata(6)).contains(\"U_WITCHSEEKERS\")",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").unit_selector.select(6)" },
    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").unit_selector.emit_signal(\"item_selected\", 6)" },
    { "act": "wait_seconds", "seconds": 0.5 },

    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").active_shooter_id.contains(\"U_WITCHSEEKERS\")",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").dice_log_display.get_parsed_text().contains(\"has no eligible targets\")",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").dice_log_display.get_parsed_text().contains(\"is out of range\")",
      "equals": true },
    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").shooter_status_label.get_parsed_text().contains(\"No eligible targets\")",
      "equals": true },
    { "act": "screenshot", "label": "02_no_targets_feedback_on_selection" },

    { "act": "execute_script",
      "script": "set_meta(\"log_len_before_click\", main.get_node(\"ShootingController\").dice_log_display.get_parsed_text().length())" },

    { "act": "click_unit", "unit_id": "U_BOYZ_E" },
    { "act": "wait_seconds", "seconds": 0.3 },

    { "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").dice_log_display.get_parsed_text().substr(get_meta(\"log_len_before_click\")).contains(\"Boyz is out of range\")",
      "equals": true },
    { "act": "screenshot", "label": "03_click_enemy_appends_reason" }
  ]
}
