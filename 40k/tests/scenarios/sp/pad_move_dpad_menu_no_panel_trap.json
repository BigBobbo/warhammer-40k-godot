{
  "id": "pad_move_dpad_menu_no_panel_trap",
  "covers": [
    "controller.move.dpad_lr_opens_menu",
    "controller.move.panel_focus_guard",
    "controller.move.stale_focus_release",
    "controller.m4.action_bar",
    "PadRouter",
    "PadActionBar"
  ],
  "fixture": "audit_baseline_postdeploy",
  "transition_to_phase": 7,
  "disable_ai": true,
  "rng_seed": 42,
  "description": "Movement-phase D-pad panel-trap fix: with a bumper-selected unit whose move decision is open, D-pad RIGHT (and LEFT) open the on-screen PadActionBar exactly like DOWN/UP — focus never lands in the right-hand mouse panel, so the player can't get stranded walking panel buttons. Stale panel focus (mouse-click residue simulated via grab_focus, or deliberate direct panel entry) is released the moment the pad is picked back up (device switch) or a bumper cycles units, and the very same press already acts on the board flow. While a model is in hand or the move session is locked (model staged, awaiting Start), the D-pad refuses panel-focus entry entirely; entry re-arms once the staged model is undone.",
  "steps": [
    { "act": "wait_seconds", "seconds": 1.5 },
    { "act": "expect_state", "path": "meta.phase", "equals": 7 },

    { "act": "simulate_joy_button", "button_index": 10 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script", "script": "str(main.movement_controller.active_unit_id) != \"\"", "equals": true },
    { "act": "execute_script", "script": "InputDeviceManager.set_meta(\"u1\", str(main.movement_controller.active_unit_id))" },

    { "act": "simulate_joy_button", "button_index": 14 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "PadActionBar.is_open()", "equals": true },
    { "act": "execute_script", "script": "main.get_viewport().gui_get_focus_owner() == null", "equals": true },
    { "act": "execute_script", "script": "PadActionBar.highlighted_id()", "equals": "NORMAL" },
    { "act": "screenshot", "label": "01_dpad_right_opens_menu_not_panel" },

    { "act": "simulate_joy_button", "button_index": 14 },
    { "act": "wait_seconds", "seconds": 0.2 },
    { "act": "execute_script", "script": "PadActionBar.highlighted_id()", "equals": "ADVANCE" },
    { "act": "simulate_joy_button", "button_index": 1 },
    { "act": "wait_seconds", "seconds": 0.2 },
    { "act": "execute_script", "script": "PadActionBar.is_open()", "equals": false },

    { "act": "simulate_joy_button", "button_index": 13 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "PadActionBar.is_open()", "equals": true },
    { "act": "execute_script", "script": "main.get_viewport().gui_get_focus_owner() == null", "equals": true },
    { "act": "simulate_joy_button", "button_index": 1 },
    { "act": "wait_seconds", "seconds": 0.2 },

    { "act": "execute_script", "multiline": true, "script": "InputDeviceManager._claim(InputDeviceManager.InputMode.KBM)\nvar radio = tree.current_scene.movement_controller.advance_radio\nradio.grab_focus()\nreturn tree.root.get_viewport().gui_get_focus_owner() == radio", "equals": true },
    { "act": "simulate_joy_button", "button_index": 12 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main.get_viewport().gui_get_focus_owner() == null", "equals": true },
    { "act": "execute_script", "script": "PadActionBar.is_open()", "equals": true },
    { "act": "screenshot", "label": "02_pad_takeover_clears_stale_focus_menu_opens" },
    { "act": "simulate_joy_button", "button_index": 1 },
    { "act": "wait_seconds", "seconds": 0.2 },

    { "act": "execute_script", "script": "PadRouter._enter_panel_focus()", "equals": true },
    { "act": "execute_script", "script": "main.get_viewport().gui_get_focus_owner() != null", "equals": true },
    { "act": "simulate_joy_button", "button_index": 10 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "main.get_viewport().gui_get_focus_owner() == null", "equals": true },
    { "act": "execute_script", "script": "str(main.movement_controller.active_unit_id) != str(InputDeviceManager.get_meta(\"u1\"))", "equals": true },
    { "act": "simulate_joy_button", "button_index": 12 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "PadActionBar.is_open()", "equals": true },
    { "act": "execute_script", "script": "PadActionBar.highlighted_id()", "equals": "NORMAL" },
    { "act": "screenshot", "label": "03_bumper_releases_panel_focus_menu_answers" },

    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.6 },
    { "act": "execute_script", "script": "PadActionBar.is_open()", "equals": false },
    { "act": "execute_script", "script": "PadRouter.is_carrying()", "equals": true },
    { "act": "simulate_joy_button", "button_index": 14 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main.get_viewport().gui_get_focus_owner() == null", "equals": true },
    { "act": "execute_script", "script": "PadActionBar.is_open()", "equals": false },
    { "act": "execute_script", "script": "PadRouter.is_carrying()", "equals": true },
    { "act": "screenshot", "label": "04_dpad_inert_while_carrying" },

    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.6 },
    { "act": "execute_script", "script": "PadRouter.is_carrying()", "equals": false },
    { "act": "execute_script", "script": "main.movement_controller.pad_is_move_session_locked()", "equals": true },
    { "act": "simulate_joy_button", "button_index": 12 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main.get_viewport().gui_get_focus_owner() == null", "equals": true },
    { "act": "execute_script", "script": "PadActionBar.is_open()", "equals": false },
    { "act": "screenshot", "label": "05_dpad_inert_while_move_locked" },

    { "act": "simulate_joy_button", "button_index": 1 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script", "script": "main.movement_controller.pad_is_move_session_locked()", "equals": false },
    { "act": "simulate_joy_button", "button_index": 12 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "PadActionBar.is_open()", "equals": true },
    { "act": "execute_script", "script": "main.get_viewport().gui_get_focus_owner() == null", "equals": true },
    { "act": "screenshot", "label": "06_entry_rearms_after_undo" },
    { "act": "simulate_joy_button", "button_index": 1 },
    { "act": "wait_seconds", "seconds": 0.2 },
    { "act": "execute_script", "script": "PadActionBar.is_open()", "equals": false }
  ]
}
