    { "act": "execute_script", "script": "main.game_log_panel.is_dice_tab_unread()", "equals": true },

    { "act": "click_node", "node": "/root/Main/GameLogPanel/VBox/HeaderRow/TabDiceLog", "emit_pressed": true },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main.game_log_panel.get_active_tab()", "equals": "dice" },
    { "act": "expect_node_visible", "node": "/root/Main/GameLogPanel/VBox/DiceLogDisplay", "timeout_s": 2.0 },
    { "act": "execute_script", "script": "tree.root.get_node(\"Main/GameLogPanel/VBox/LogScroll\").visible", "equals": false },
    { "act": "execute_script", "script": "main.game_log_panel.is_dice_tab_unread()", "equals": false },
    { "act": "execute_script", "script": "main.game_log_panel.get_dice_log_display().get_total_character_count()", "expect_min": 1 },
    { "act": "screenshot", "label": "01_dice_log_tab_active_left_panel", "region": [0, 100, 360, 760] },

    { "act": "click_node", "node": "/root/Main/GameLogPanel/VBox/HeaderRow/TabGameLog", "emit_pressed": true },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main.game_log_panel.get_active_tab()", "equals": "game" },
    { "act": "execute_script", "script": "tree.root.get_node(\"Main/GameLogPanel/VBox/LogScroll\").visible", "equals": true },
    { "act": "execute_script", "script": "tree.root.get_node(\"Main/GameLogPanel/VBox/DiceLogDisplay\").visible", "equals": false },
    { "act": "screenshot", "label": "02_game_log_tab_active_left_panel", "region": [0, 100, 360, 760] },

    { "act": "click_node", "node": "/root/Main/GameLogPanel/VBox/HeaderRow/TabDiceLog", "emit_pressed": true },
    { "act": "wait_frames", "frames": 4 },
    { "act": "screenshot", "label": "03_full_frame_right_panel_decluttered" }
  ]
