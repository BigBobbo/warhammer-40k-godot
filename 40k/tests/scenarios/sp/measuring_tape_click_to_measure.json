{
  "id": "measuring_tape_click_to_measure",
  "covers": ["tools.measuring_tape", "tools.measuring_tape.click_flow"],
  "fixture": "co_pretrigger",
  "transition_to_phase": 7,
  "description": "Measuring tape click-to-measure tool. The measuring-tape key (default T) toggles an armed mode; the first board click places the start, the second click finalises a persisted line. ESC cancels an in-progress line then exits the tool; the clear key (Y) removes all measurements. Drives the real player input path (simulate_key + click_board_at).",

  "steps": [
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "main.fit_view_to_board()" },
    { "act": "wait_frames", "frames": 3 },

    { "act": "execute_script",
      "script": "MeasuringTapeManager.measure_mode_active",
      "equals": false },
    { "act": "execute_script",
      "script": "MeasuringTapeManager.measurements.size()",
      "equals": 0 },
    { "act": "screenshot", "label": "01_idle" },

    { "act": "simulate_key", "keycode": "T" },
    { "act": "wait_frames", "frames": 2 },
    { "act": "execute_script",
      "script": "MeasuringTapeManager.measure_mode_active",
      "equals": true },
    { "act": "execute_script",
      "script": "get_node_or_null(\"/root/Main/MeasureModeHint\") != null",
      "equals": true },
    { "act": "screenshot", "label": "02_armed" },

    { "act": "click_board_at", "x": 700.0, "y": 1000.0 },
    { "act": "wait_frames", "frames": 2 },
    { "act": "execute_script",
      "script": "MeasuringTapeManager.is_measuring",
      "equals": true },

    { "act": "hover_board_at", "x": 940.0, "y": 1000.0 },
    { "act": "wait_frames", "frames": 2 },
    { "act": "click_board_at", "x": 940.0, "y": 1000.0 },
    { "act": "wait_frames", "frames": 2 },

    { "act": "execute_script",
      "script": "MeasuringTapeManager.is_measuring",
      "equals": false },
    { "act": "execute_script",
      "script": "MeasuringTapeManager.measurements.size()",
      "equals": 1 },
    { "act": "execute_script",
      "script": "abs(MeasuringTapeManager.measurements[0].distance - 6.0)",
      "expect_max": 0.5 },
    { "act": "screenshot", "label": "03_measured" },

    { "act": "click_board_at", "x": 700.0, "y": 1400.0 },
    { "act": "wait_frames", "frames": 2 },
    { "act": "execute_script",
      "script": "MeasuringTapeManager.is_measuring",
      "equals": true },

    { "act": "simulate_key", "keycode": "Escape" },
    { "act": "wait_frames", "frames": 2 },
    { "act": "execute_script",
      "script": "MeasuringTapeManager.is_measuring",
      "equals": false },
    { "act": "execute_script",
      "script": "MeasuringTapeManager.measure_mode_active",
      "equals": true },
    { "act": "execute_script",
      "script": "MeasuringTapeManager.measurements.size()",
      "equals": 1 },

    { "act": "simulate_key", "keycode": "Escape" },
    { "act": "wait_frames", "frames": 2 },
    { "act": "execute_script",
      "script": "MeasuringTapeManager.measure_mode_active",
      "equals": false },
    { "act": "execute_script",
      "script": "get_node_or_null(\"/root/Main/MeasureModeHint\") == null",
      "equals": true },
    { "act": "screenshot", "label": "04_exited" },

    { "act": "simulate_key", "keycode": "Y" },
    { "act": "wait_frames", "frames": 2 },
    { "act": "execute_script",
      "script": "MeasuringTapeManager.measurements.size()",
      "equals": 0 },
    { "act": "screenshot", "label": "05_cleared" }
  ]
}
