{
  "id": "co_offer_after_charge",
  "covers": ["fight.stratagem.counter_offensive", "fight.fights_first_pulse"],
  "fixture": "co_pretrigger",
  "rng_seed": 42,
  "transition_to_phase": 10,
  "description": "COUNTER-OFFENSIVE end-to-end: post-charge fixture loaded, drive SELECT_FIGHTER → DECLINE_EPIC_CHALLENGE → PILE_IN → CONSOLIDATE on Warboss B, verify the trigger surfaces with U_CUSTODIAN_GUARD_B as eligible defender, dispatch USE_COUNTER_OFFENSIVE, assert CP delta and fights_first flag. Mirrors test_co_pretrigger.gd but runs in windowed mode so TokenLayer rendering is exercised — token-visibility asserts prove the fixture renders correctly.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.3 },

    { "act": "expect_state", "path": "meta.phase", "equals": 10 },
    { "act": "expect_state", "path": "units.U_WARBOSS_B.flags.charged_this_turn", "equals": true },
    { "act": "expect_token_visible", "unit_id": "U_WARBOSS_B", "timeout_s": 3.0 },
    { "act": "expect_token_visible", "unit_id": "U_CUSTODIAN_GUARD_B", "timeout_s": 3.0 },
    { "act": "screenshot", "label": "01_loaded_fight_phase" },

    { "act": "dispatch_action", "action": { "type": "SELECT_FIGHTER", "unit_id": "U_WARBOSS_B" } },
    { "act": "dispatch_action", "action": { "type": "DECLINE_EPIC_CHALLENGE" } },
    { "act": "dispatch_action", "action": { "type": "PILE_IN", "unit_id": "U_WARBOSS_B", "actor_unit_id": "U_WARBOSS_B", "payload": { "per_model_paths": {} } } },
    { "act": "dispatch_action", "action": { "type": "CONSOLIDATE", "unit_id": "U_WARBOSS_B", "actor_unit_id": "U_WARBOSS_B" } },

    { "act": "expect_action_result", "path": "trigger_counter_offensive", "equals": true },
    { "act": "expect_action_result", "path": "counter_offensive_player", "equals": 1 },
    { "act": "screenshot", "label": "02_after_consolidate_co_offered" },

    { "act": "dispatch_action", "action": { "type": "USE_COUNTER_OFFENSIVE", "unit_id": "U_CUSTODIAN_GUARD_B", "player": 1 } },
    { "act": "expect_action_result", "path": "success", "equals": true },
    { "act": "expect_phase_property", "property": "active_fighter_id", "equals": "U_CUSTODIAN_GUARD_B" },
    { "act": "expect_phase_property", "property": "current_selecting_player", "equals": 1 },
    { "act": "expect_phase_property", "property": "awaiting_counter_offensive", "equals": false },
    { "act": "expect_cp", "player": 1, "delta_from_start": -2 },
    { "act": "screenshot", "label": "03_after_co_used" }
  ]
}
