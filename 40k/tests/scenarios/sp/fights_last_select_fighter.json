    { "act": "expect_action_result", "path": "success", "equals": true },
    { "act": "expect_phase_property", "property": "active_fighter_id", "equals": "U_SHIELD_CAPTAIN_FL" },
    { "act": "screenshot", "label": "02_shield_captain_selected_in_fights_last" }
  ]
