  "steps": [
    { "act": "wait_seconds", "seconds": 0.5 },

    { "act": "expect_state", "path": "meta.phase", "equals": 10 },
    { "act": "expect_token_visible", "unit_id": "U_SHIELD_CAPTAIN_FL", "timeout_s": 3.0 },
    { "act": "expect_token_visible", "unit_id": "U_BOYZ_FL", "timeout_s": 3.0 },
