{
  "id": "367_designate_warlord",
  "covers": ["phases.FormationsPhase.DESIGNATE_WARLORD", "pregame.warlord_designation"],
  "fixture": "audit_367_warlord",
  "transition_to_phase": 0,
  "description": "Issue #367: DESIGNATE_WARLORD action in FormationsPhase. Fixture has 3 P1 CHARACTERs with no warlord set. Dispatch DESIGNATE_WARLORD for Shield-Captain, verify is_warlord=true. Then re-designate Blade Champion and verify warlord switched.",
  "steps": [
