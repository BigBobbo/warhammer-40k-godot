    { "act": "expect_action_result", "path": "success", "equals": true },
    { "act": "expect_state", "path": "units.U_BLADE_CHAMPION_A.meta.is_warlord", "equals": true },
    { "act": "expect_state", "path": "units.U_SHIELD_CAPTAIN_A.meta.is_warlord", "equals": false },
    { "act": "screenshot", "label": "03_warlord_switched_to_blade_champion" }
  ]
