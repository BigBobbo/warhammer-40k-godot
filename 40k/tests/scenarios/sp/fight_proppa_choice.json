  { "act": "click_node", "node": "/root/Main/StratagemPanel/Scroll/List/Strat_faction_ork_taktikal_brigade_fight_proppa/Row/Use_faction_ork_taktikal_brigade_fight_proppa", "emit_pressed": true },
  { "act": "expect_node_visible", "node": "/root/StratagemTargetDialog" },
