{
  "id": "pad_deploy_unit_cycling",
  "covers": [
    "controller.deploy.unit_cycling",
    "controller.deploy.formation_dpad",
    "deployment.unit_list_stays_visible",
    "deployment.switch_locked_after_placement",
    "PadRouter",
    "DeploymentController",
    "Main"
  ],
  "fixture": "New Game",
  "transition_to_phase": 1,
  "disable_ai": true,
  "description": "DEPLOY-CYCLE: during deployment the right-panel unit list stays visible while placing, RB/LB cycle which unit is being deployed (the highlighted row follows, old unit returns to UNDEPLOYED, new one becomes DEPLOYING), D-pad left/right steps the formation mode Single/Spread/Tight, and once a model is placed switching is locked for BOTH pad bumpers and mouse row-clicks until every placed model is undone (pad X = undo last model with the cursor parked). Also proves the mouse row-click switch path works when nothing is placed.",
  "steps": [
    { "act": "wait_seconds", "seconds": 1.2 },
    { "act": "expect_state", "path": "meta.phase", "equals": 1 },
    { "act": "expect_state", "path": "meta.active_player", "equals": 1 },

    { "act": "simulate_joy_button", "button_index": 10 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "main.deployment_controller.is_placing()", "equals": true },
    { "act": "execute_script", "script": "InputDeviceManager.set_meta(\"u1\", str(main.deployment_controller.unit_id))" },
    { "act": "execute_script", "script": "main.unit_list.visible", "equals": true },
    { "act": "execute_script", "script": "main.unit_list.get_selected_items().size()", "equals": 1 },
    { "act": "execute_script", "script": "str(main.unit_list.get_item_metadata(main.unit_list.get_selected_items()[0])) == str(main.deployment_controller.unit_id)", "equals": true },
    { "act": "screenshot", "label": "01_rb_first_unit_list_still_visible" },

    { "act": "simulate_joy_button", "button_index": 10 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "main.deployment_controller.is_placing() and str(main.deployment_controller.unit_id) != str(InputDeviceManager.get_meta(\"u1\"))", "equals": true },
    { "act": "execute_script", "script": "InputDeviceManager.set_meta(\"u2\", str(main.deployment_controller.unit_id))" },
    { "act": "execute_script", "script": "int(GameState.get_unit(str(InputDeviceManager.get_meta(\"u1\"))).status)", "equals": 0 },
    { "act": "execute_script", "script": "int(GameState.get_unit(str(InputDeviceManager.get_meta(\"u2\"))).status)", "equals": 1 },
    { "act": "execute_script", "script": "str(main.unit_list.get_item_metadata(main.unit_list.get_selected_items()[0])) == str(InputDeviceManager.get_meta(\"u2\"))", "equals": true },
    { "act": "screenshot", "label": "02_rb_cycled_to_second_unit" },

    { "act": "simulate_joy_button", "button_index": 9 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "str(main.deployment_controller.unit_id) == str(InputDeviceManager.get_meta(\"u1\"))", "equals": true },
    { "act": "execute_script", "script": "int(GameState.get_unit(str(InputDeviceManager.get_meta(\"u2\"))).status)", "equals": 0 },

    { "act": "simulate_joy_button", "button_index": 14 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main.deployment_controller.formation_mode", "equals": "SPREAD" },
    { "act": "simulate_joy_button", "button_index": 14 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main.deployment_controller.formation_mode", "equals": "TIGHT" },
    { "act": "screenshot", "label": "03_dpad_formation_tight" },
    { "act": "simulate_joy_button", "button_index": 13 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main.deployment_controller.formation_mode", "equals": "SPREAD" },
    { "act": "simulate_joy_button", "button_index": 13 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main.deployment_controller.formation_mode", "equals": "SINGLE" },

    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "VirtualCursor.is_cursor_active()", "equals": true },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "main.deployment_controller.get_placed_count()", "equals": 1 },
    { "act": "screenshot", "label": "04_one_model_placed_via_pad" },

    { "act": "simulate_joy_button", "button_index": 10 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script", "script": "str(main.deployment_controller.unit_id) == str(InputDeviceManager.get_meta(\"u1\"))", "equals": true },
    { "act": "execute_script", "script": "main.deployment_controller.get_placed_count()", "equals": 1 },
    { "act": "execute_script", "script": "str(main.unit_list.get_item_metadata(main.unit_list.get_selected_items()[0])) == str(InputDeviceManager.get_meta(\"u1\"))", "equals": true },
    { "act": "screenshot", "label": "05_rb_switch_blocked_while_model_placed" },

    { "act": "click_item_list", "node": "/root/Main/HUD_Right/VBoxContainer/UnitListPanel", "index": 1 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script", "script": "str(main.deployment_controller.unit_id) == str(InputDeviceManager.get_meta(\"u1\"))", "equals": true },
    { "act": "execute_script", "script": "str(main.unit_list.get_item_metadata(main.unit_list.get_selected_items()[0])) == str(InputDeviceManager.get_meta(\"u1\"))", "equals": true },

    { "act": "simulate_joy_button", "button_index": 1 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "VirtualCursor.is_cursor_active()", "equals": false },
    { "act": "simulate_joy_button", "button_index": 2 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script", "script": "main.deployment_controller.get_placed_count()", "equals": 0 },

    { "act": "simulate_joy_button", "button_index": 10 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "str(main.deployment_controller.unit_id) == str(InputDeviceManager.get_meta(\"u2\"))", "equals": true },
    { "act": "screenshot", "label": "06_rb_switch_works_after_undo" },

    { "act": "click_item_list", "node": "/root/Main/HUD_Right/VBoxContainer/UnitListPanel", "index": 0 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "str(main.deployment_controller.unit_id) == str(InputDeviceManager.get_meta(\"u1\"))", "equals": true },
    { "act": "execute_script", "script": "int(GameState.get_unit(str(InputDeviceManager.get_meta(\"u2\"))).status)", "equals": 0 },
    { "act": "execute_script", "script": "main.unit_list.visible", "equals": true },
    { "act": "screenshot", "label": "07_mouse_row_click_switched_back" }
  ]
}
