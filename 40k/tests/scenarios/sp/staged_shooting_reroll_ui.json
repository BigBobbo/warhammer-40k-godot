{
  "id": "staged_shooting_reroll_ui",
  "covers": [
    "scripts.ShootingResolutionDock.reroll_chips",
    "phases.ShootingPhase.use_shooting_reroll",
    "shooting.staged.command_reroll_hit_die"
  ],
  "fixture": "shooting_phase",
  "rng_seed": 42,
  "transition_to_phase": 8,
  "disable_ai": true,
  "description": "Command Re-roll at the staged hit pause, driven through the B2 resolution dock. Battlewagon Alpha fires big shootas (weapon 1 of 2) at the Witchseekers; at the hit pause the dock shows one clickable die chip per hit roll (Command Re-roll, 1 CP). Clicking a chip dispatches USE_SHOOTING_REROLL: the CP is spent, the chips disappear (once per phase), and the pause remains until the attacker continues to the wound roll.",
  "steps": [
    {
      "act": "wait_seconds",
      "seconds": 0.5
    },
    {
      "act": "expect_state",
      "path": "meta.phase",
      "equals": 8
    },
    {
      "act": "execute_script",
      "script": "GameState.set_edition(11)",
      "equals": 11
    },
    {
      "act": "execute_script",
      "script": "GameState.get_unit(\"U_BLADE_CHAMPION_A\").models[0].position.merge({\"x\": 1150.0, \"y\": 2150.0}, true)"
    },
    {
      "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().game_state_snapshot.units[\"U_BLADE_CHAMPION_A\"].models[0].position.merge({\"x\": 1150.0, \"y\": 2150.0}, true)"
    },
    {
      "act": "dispatch_action",
      "action": {
        "type": "SELECT_SHOOTER",
        "actor_unit_id": "U_BATTLEWAGON_A"
      }
    },
    {
      "act": "expect_action_result",
      "path": "success",
      "equals": true
    },
    {
      "act": "wait_seconds",
      "seconds": 0.5
    },
    {
      "act": "dispatch_action",
      "action": {
        "type": "ASSIGN_TARGET",
        "actor_unit_id": "U_BATTLEWAGON_A",
        "payload": {
          "weapon_id": "big_shoota_ranged",
          "target_unit_id": "U_WITCHSEEKERS_C",
          "model_ids": [
            "m1"
          ]
        }
      }
    },
    {
      "act": "expect_action_result",
      "path": "success",
      "equals": true
    },
    {
      "act": "dispatch_action",
      "action": {
        "type": "ASSIGN_TARGET",
        "actor_unit_id": "U_BATTLEWAGON_A",
        "payload": {
          "weapon_id": "zzap_gun_ranged",
          "target_unit_id": "U_BLADE_CHAMPION_A",
          "model_ids": [
            "m1"
          ]
        }
      }
    },
    {
      "act": "expect_action_result",
      "path": "success",
      "equals": true
    },
    {
      "act": "dispatch_action",
      "action": {
        "type": "CONFIRM_TARGETS"
      }
    },
    {
      "act": "expect_action_result",
      "path": "success",
      "equals": true
    },
    {
      "act": "wait_seconds",
      "seconds": 0.5
    },
    {
      "act": "dispatch_action",
      "action": {
        "type": "DECLINE_REACTIVE_STRATAGEM"
      }
    },
    {
      "act": "wait_seconds",
      "seconds": 0.8
    },
    {
      "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").resolution_dock.is_active()",
      "equals": true
    },
    {
      "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").resolution_dock.primary_button.emit_signal(\"pressed\")"
    },
    {
      "act": "wait_seconds",
      "seconds": 0.8
    },
    {
      "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").resolution_dock.state",
      "equals": "staged_hits"
    },
    {
      "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").resolution_dock.reroll_row.get_child_count()",
      "equals": 5
    },
    {
      "act": "screenshot",
      "label": "01_hit_pause_with_reroll_chips"
    },
    {
      "act": "execute_script",
      "script": "StratagemManager.get_player_cp(1)",
      "equals": 4
    },
    {
      "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").resolution_dock.reroll_row.get_child(0).emit_signal(\"pressed\")"
    },
    {
      "act": "wait_seconds",
      "seconds": 0.6
    },
    {
      "act": "execute_script",
      "script": "StratagemManager.get_player_cp(1)",
      "equals": 3
    },
    {
      "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").resolution_dock.reroll_row.get_child_count()",
      "equals": 0
    },
    {
      "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().resolution_state.get(\"stage\", \"?\")",
      "equals": "hits_pending"
    },
    {
      "act": "screenshot",
      "label": "02_after_command_reroll"
    },
    {
      "act": "execute_script",
      "script": "main.get_node(\"ShootingController\").resolution_dock.primary_button.emit_signal(\"pressed\")"
    },
    {
      "act": "wait_seconds",
      "seconds": 0.8
    },
    {
      "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().resolution_state.get(\"stage\", \"?\")",
      "equals": "wounds_pending"
    },
    {
      "act": "screenshot",
      "label": "03_wound_pause_after_reroll"
    }
  ]
}