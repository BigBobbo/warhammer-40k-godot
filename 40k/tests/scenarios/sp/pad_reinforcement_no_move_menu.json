{
  "id": "pad_reinforcement_no_move_menu",
  "covers": [
    "controller.reinforcement.no_move_menu_during_placement",
    "controller.reinforcement.stale_selection_cleared",
    "controller.reinforcement.start_confirms_arrival",
    "controller.reinforcement.arrived_unit_no_move_menu",
    "PadRouter",
    "MovementController",
    "Main"
  ],
  "fixture": "ri_pretrigger",
  "rng_seed": 42,
  "edition": 11,
  "transition_to_phase": 7,
  "disable_ai": true,
  "description": "Deep-strike/reinforcement pad confusion regression: selecting a normal unit (open move-mode decision) and THEN a reserve unit used to leave MovementController.active_unit_id pointing at the stale unit, so during placement any D-pad press (or A with a parked cursor) fell through _try_open_move_menu and opened the Move / Advance / Fall Back / Stay Still action bar for the STALE unit instead of the deploy affordances — the player saw movement options mid-deep-strike and no way to confirm. Now: beginning reinforcement placement clears the stale movement selection, _try_open_move_menu stands down while a placement session is live (D-pad falls through to panel focus exactly like deployment), A warps the cursor over the placement area, a placed model + Start confirms the arrival (status DEPLOYED, ingress flags set), and the freshly arrived unit is never offered move-mode options (flags.moved / no_moves_until_charge_phase gate pad_menu_options).",
  "steps": [
    { "act": "wait_seconds", "seconds": 1.0 },
    { "act": "expect_state", "path": "meta.phase", "equals": 7 },
    { "act": "expect_state", "path": "meta.active_player", "equals": 2 },
    { "act": "expect_state", "path": "units.U_BATTLEWAGON_G.status", "equals": 7 },

    { "act": "execute_script", "multiline": true, "script": "var m = tree.current_scene\nvar list = m.movement_controller.unit_list\nfor i in range(list.item_count):\n\tif str(list.get_item_metadata(i)) == \"U_WARBOSS_B\":\n\t\tlist.select(i)\n\t\tlist.item_selected.emit(i)\n\t\treturn true\nreturn false", "equals": true },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "str(main.movement_controller.active_unit_id)", "equals": "U_WARBOSS_B" },
    { "act": "execute_script", "script": "main.movement_controller.pad_menu_options().size() > 0", "equals": true },
    { "act": "screenshot", "label": "01_stale_unit_selected_menu_offerable" },

    { "act": "execute_script", "multiline": true, "script": "var m = tree.current_scene\nvar list = m.movement_controller.unit_list\nfor i in range(list.item_count):\n\tif str(list.get_item_metadata(i)) == \"U_BATTLEWAGON_G\":\n\t\tlist.select(i)\n\t\tlist.item_selected.emit(i)\n\t\treturn true\nreturn false", "equals": true },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "main.deployment_controller.is_placing()", "equals": true },
    { "act": "execute_script", "script": "main.deployment_controller.is_reinforcement_mode", "equals": true },
    { "act": "execute_script", "script": "str(main.deployment_controller.unit_id)", "equals": "U_BATTLEWAGON_G" },
    { "act": "execute_script", "script": "str(main.movement_controller.active_unit_id)", "equals": "" },
    { "act": "execute_script", "script": "main.movement_controller.pad_menu_options().size()", "equals": 0 },
    { "act": "screenshot", "label": "02_placement_started_stale_selection_cleared" },

    { "act": "simulate_joy_button", "button_index": 12 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "PadActionBar.is_open()", "equals": false },
    { "act": "execute_script", "script": "main.get_viewport().gui_get_focus_owner() != null", "equals": true },
    { "act": "screenshot", "label": "03_dpad_during_placement_no_move_menu" },
    { "act": "simulate_joy_button", "button_index": 1 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main.get_viewport().gui_get_focus_owner() == null", "equals": true },

    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "PadActionBar.is_open()", "equals": false },
    { "act": "execute_script", "script": "VirtualCursor.is_cursor_active()", "equals": true },

    { "act": "pad_cursor_glide", "x": 1450, "y": 2220 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "main.deployment_controller.get_placed_count()", "equals": 1 },
    { "act": "screenshot", "label": "04_all_models_placed" },

    { "act": "simulate_joy_button", "button_index": 11 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "PadActionBar.is_open()", "equals": false },
    { "act": "execute_script", "script": "main.deployment_controller.get_placed_count()", "equals": 1 },
    { "act": "screenshot", "label": "05_dpad_after_all_placed_no_move_menu" },
    { "act": "simulate_joy_button", "button_index": 1 },
    { "act": "wait_seconds", "seconds": 0.3 },

    { "act": "simulate_joy_button", "button_index": 6 },
    { "act": "wait_seconds", "seconds": 0.8 },
    { "act": "expect_state", "path": "units.U_BATTLEWAGON_G.status", "equals": 2 },
    { "act": "execute_script", "script": "GameState.get_unit(\"U_BATTLEWAGON_G\").get(\"flags\", {}).get(\"moved\", false)", "equals": true },
    { "act": "execute_script", "script": "GameState.get_unit(\"U_BATTLEWAGON_G\").get(\"flags\", {}).get(\"arrived_from_reserves\", false)", "equals": true },
    { "act": "execute_script", "script": "main.deployment_controller.is_placing()", "equals": false },
    { "act": "screenshot", "label": "06_start_confirmed_arrival" },

    { "act": "click_unit", "unit_id": "U_BATTLEWAGON_G" },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "main.movement_controller.pad_menu_options().size()", "equals": 0 },
    { "act": "simulate_joy_button", "button_index": 11 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "PadActionBar.is_open()", "equals": false },
    { "act": "simulate_joy_button", "button_index": 1 },
    { "act": "wait_seconds", "seconds": 0.2 },
    { "act": "screenshot", "label": "07_arrived_unit_offers_no_move_menu" }
  ]
}
