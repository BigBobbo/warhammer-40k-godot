  "enhancements.taktikal_brigade.skwad_leader",
  "enhancements.taktikal_brigade.morks_kunnin",
  "armies.orks_taktikal.load_path",
  "autoloads.CharacterAttachmentManager.enhancement_can_lead"
 ],
 "fixture": "co_pretrigger",
