    { "act": "execute_script",
      "script": "RulesEngine.get_eligible_targets(\"U_CONTEMPTOR-ACHILLUS_DREADNOUGHT_H\", GameState.create_snapshot()).has(\"U_KOMMANDOS_H\")",
      "equals": true },
    { "act": "execute_script",
      "script": "RulesEngine.get_eligible_targets(\"U_CONTEMPTOR-ACHILLUS_DREADNOUGHT_H\", GameState.create_snapshot()).has(\"U_BOYZ_E\")",
      "equals": false },
    { "act": "execute_script",
      "script": "TerrainManager.model_visible_11e(GameState.state[\"units\"][\"U_CONTEMPTOR-ACHILLUS_DREADNOUGHT_H\"][\"models\"][0], GameState.state[\"units\"][\"U_BOYZ_E\"][\"models\"][0])",
      "equals": false },
    { "act": "execute_script",
      "script": "TerrainManager.model_visible_11e(GameState.state[\"units\"][\"U_CONTEMPTOR-ACHILLUS_DREADNOUGHT_H\"][\"models\"][0], GameState.state[\"units\"][\"U_KOMMANDOS_H\"][\"models\"][0])",
      "equals": true },

    { "act": "execute_script",
      "script": "TerrainManager.area_at(Vector2(880, 1200)).get(\"link_group\", \"\")",
      "equals": "Center" },
    { "act": "execute_script",
      "script": "Vector2(GameState.state[\"units\"][\"U_SHIELD_CAPTAIN_A\"][\"models\"][0][\"position\"][\"x\"], GameState.state[\"units\"][\"U_SHIELD_CAPTAIN_A\"][\"models\"][0][\"position\"][\"y\"]).distance_to(Vector2(880, 1200))",
      "expect_max": 151.6 },
    { "act": "execute_script",
      "script": "GameState.state[\"units\"][\"U_SHIELD_CAPTAIN_A\"][\"flags\"].get(\"battle_shocked\", false)",
