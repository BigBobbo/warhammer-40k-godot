    { "act": "execute_script", "script": "GameState.state.units[\"U_WITCHSEEKERS_D\"].models[0].position.y - InputDeviceManager.get_meta(\"d_y0\")", "expect_min": 100 },
    { "act": "execute_script", "script": "GameState.state.units[\"U_WITCHSEEKERS_D\"].models[3].position.y - InputDeviceManager.get_meta(\"d_y0\")", "expect_min": 100 },
