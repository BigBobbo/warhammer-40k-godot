{
  "id": "pad_group_move_all",
  "covers": [
    "controller.move.group_carry_menu",
    "controller.move.group_carry_dpad_grab",
    "controller.move.group_drop_all_staged",
    "controller.move.group_illegal_drop_keeps_group",
    "controller.move.group_cancel_stages_nothing"
  ],
  "fixture": "audit_baseline_postdeploy",
  "transition_to_phase": 7,
  "disable_ai": true,
  "rng_seed": 42,
  "description": "Pad group carry: the whole multi-model unit can be moved at once. Part A (menu path): selecting 'Move All Together' from the move menu (one dpad-left wrap from Move) picks up EVERY model of the Witchseekers as one formation riding the cursor; a single A drop stages all four models at the translated positions and the confirm button lands all four in GameState. Part B (D-pad path, second unit): after choosing plain Move (single model auto-carried), any D-pad press converts the carry into the whole-group carry; an all-off-board drop is refused and keeps the group in hand (toast, still carrying); B cancels the group without staging anything; the menu then reopens and 'Move All Together' + drop + confirm moves the second unit too.",
  "steps": [
    { "act": "wait_seconds", "seconds": 1.5 },
    { "act": "expect_state", "path": "meta.phase", "equals": 7 },

    { "act": "execute_script", "script": "InputDeviceManager.set_meta(\"c_y0\", GameState.state.units[\"U_WITCHSEEKERS_C\"].models[0].position.y)" },
    { "act": "execute_script", "script": "InputDeviceManager.set_meta(\"d_y0\", GameState.state.units[\"U_WITCHSEEKERS_D\"].models[0].position.y)" },

    { "act": "pad_cursor_glide", "unit_id": "U_WITCHSEEKERS_C" },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script", "script": "str(main.movement_controller.active_unit_id)", "equals": "U_WITCHSEEKERS_C" },

    { "act": "simulate_joy_button", "button_index": 1 },
    { "act": "wait_seconds", "seconds": 0.2 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "PadActionBar.is_open()", "equals": true },
    { "act": "execute_script", "script": "PadActionBar.highlighted_id()", "equals": "NORMAL" },

    { "act": "simulate_joy_button", "button_index": 13 },
    { "act": "wait_seconds", "seconds": 0.2 },
    { "act": "execute_script", "script": "PadActionBar.highlighted_id()", "equals": "NORMAL_ALL" },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.6 },
    { "act": "execute_script", "script": "PadRouter.is_carrying()", "equals": true },
    { "act": "execute_script", "script": "PadRouter.group_carry_active", "equals": true },
    { "act": "execute_script", "script": "main.movement_controller.group_dragging", "equals": true },
    { "act": "execute_script", "script": "main.movement_controller.selected_models.size()", "equals": 4 },
    { "act": "screenshot", "label": "01_whole_unit_in_hand" },

    { "act": "pad_cursor_glide", "x": 910.0, "y": 190.0 },
    { "act": "screenshot", "label": "02_formation_preview_at_target" },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 1.2 },
    { "act": "execute_script", "script": "PadRouter.is_carrying()", "equals": false },
    { "act": "execute_script", "script": "PhaseManager.current_phase_instance.active_moves[\"U_WITCHSEEKERS_C\"].staged_moves.size()", "equals": 4 },
    { "act": "screenshot", "label": "03_group_dropped_all_four_staged" },

    { "act": "pad_cursor_glide", "button_text": "End This Unit's Move" },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.6 },
    { "act": "execute_script", "script": "GameState.state.units[\"U_WITCHSEEKERS_C\"].models[0].position.y - InputDeviceManager.get_meta(\"c_y0\")", "expect_min": 100 },
    { "act": "execute_script", "script": "GameState.state.units[\"U_WITCHSEEKERS_C\"].models[1].position.y - InputDeviceManager.get_meta(\"c_y0\")", "expect_min": 100 },
    { "act": "execute_script", "script": "GameState.state.units[\"U_WITCHSEEKERS_C\"].models[2].position.y - InputDeviceManager.get_meta(\"c_y0\")", "expect_min": 100 },
    { "act": "execute_script", "script": "GameState.state.units[\"U_WITCHSEEKERS_C\"].models[3].position.y - InputDeviceManager.get_meta(\"c_y0\")", "expect_min": 100 },
    { "act": "screenshot", "label": "04_confirmed_all_four_moved" },

    { "act": "execute_script", "script": "main.movement_controller._select_unit_in_list_by_id(\"U_WITCHSEEKERS_D\")", "equals": true },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script", "script": "str(main.movement_controller.active_unit_id)", "equals": "U_WITCHSEEKERS_D" },
    { "act": "simulate_joy_button", "button_index": 1 },
    { "act": "wait_seconds", "seconds": 0.2 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "PadActionBar.is_open()", "equals": true },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "PadRouter.is_carrying()", "equals": true },
    { "act": "execute_script", "script": "PadRouter.group_carry_active", "equals": false },

    { "act": "simulate_joy_button", "button_index": 11 },
    { "act": "wait_seconds", "seconds": 0.6 },
    { "act": "execute_script", "script": "PadRouter.is_carrying()", "equals": true },
    { "act": "execute_script", "script": "PadRouter.group_carry_active", "equals": true },
    { "act": "execute_script", "script": "main.movement_controller.selected_models.size()", "equals": 4 },
    { "act": "execute_script", "script": "PhaseManager.current_phase_instance.active_moves[\"U_WITCHSEEKERS_D\"].staged_moves.size()", "equals": 0 },
    { "act": "screenshot", "label": "05_dpad_converted_single_carry_to_group" },

    { "act": "pad_cursor_glide", "x": 1160.0, "y": -160.0 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.6 },
    { "act": "execute_script", "script": "PadRouter.is_carrying()", "equals": true },
    { "act": "execute_script", "script": "PadRouter.group_carry_active", "equals": true },
    { "act": "execute_script", "script": "PhaseManager.current_phase_instance.active_moves[\"U_WITCHSEEKERS_D\"].staged_moves.size()", "equals": 0 },
    { "act": "screenshot", "label": "06_offboard_drop_refused_group_still_in_hand" },

    { "act": "simulate_joy_button", "button_index": 1 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "PadRouter.is_carrying()", "equals": false },
    { "act": "execute_script", "script": "main.movement_controller.group_dragging", "equals": false },
    { "act": "execute_script", "script": "main.movement_controller.selected_models.size()", "equals": 0 },
    { "act": "execute_script", "script": "PhaseManager.current_phase_instance.active_moves[\"U_WITCHSEEKERS_D\"].staged_moves.size()", "equals": 0 },

    { "act": "simulate_joy_button", "button_index": 11 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "PadActionBar.is_open()", "equals": true },
    { "act": "simulate_joy_button", "button_index": 13 },
    { "act": "wait_seconds", "seconds": 0.2 },
    { "act": "execute_script", "script": "PadActionBar.highlighted_id()", "equals": "NORMAL_ALL" },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.6 },
    { "act": "execute_script", "script": "PadRouter.group_carry_active", "equals": true },

    { "act": "pad_cursor_glide", "x": 1160.0, "y": 200.0 },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 1.2 },
    { "act": "execute_script", "script": "PhaseManager.current_phase_instance.active_moves[\"U_WITCHSEEKERS_D\"].staged_moves.size()", "equals": 4 },

    { "act": "pad_cursor_glide", "button_text": "End This Unit's Move" },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.6 },
    { "act": "execute_script", "script": "GameState.state.units[\"U_WITCHSEEKERS_D\"].models[0].position.y - InputDeviceManager.get_meta(\"d_y0\")", "expect_min": 100 },
    { "act": "execute_script", "script": "GameState.state.units[\"U_WITCHSEEKERS_D\"].models[3].position.y - InputDeviceManager.get_meta(\"d_y0\")", "expect_min": 100 },
    { "act": "screenshot", "label": "07_second_unit_moved_via_dpad_group_flow" }
  ]
}
