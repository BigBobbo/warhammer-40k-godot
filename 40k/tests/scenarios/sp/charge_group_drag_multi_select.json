{
  "id": "charge_group_drag_multi_select",
  "covers": [
    "scripts.ChargeController.multi_select_group_drag",
    "charge.movement.shift_drag_box_multi_select"
  ],
  "fixture": "test_charge_congestion",
  "rng_seed": 42,
  "transition_to_phase": 9,
  "disable_ai": true,
  "description": "Charge-phase multi-select + group drag (feature): during charge movement the player can Shift+drag a selection box over several charging models and then drag any selected model to move the WHOLE group by the same offset — mirroring the Movement phase multi-select UX (previously charge moves were strictly one model per drag). Player path: U_CHARGER_0's 3 Ork Boyz are respaced to a legal formation (x=971, y=740/800/860 — the fixture's saved 30px spacing self-overlaps 32mm bases), then declare a charge on the Shield-Captain at (800,800), CHARGE_ROLL (seed 23), the real Command Re-roll dialog's 'Keep Roll' button is clicked, then a REAL Shift+held drag_board rubber-bands a box around all 3 Boyz (press on empty board, motion, release — the new drag_board shift:true option holds a real KEY_SHIFT through the whole gesture). Asserts 3 models selected with pulsing ring indicators. An over-budget group drag (15\" > roll) is then attempted and must be rejected with NOTHING moved (all-or-nothing group validation). A legal 2.1\" group drag then moves all three models at once into engagement range: moved_models has all 3, per-model charge paths accumulate the hop, and the real 'Confirm Charge Moves' button completes the charge with every model within ER of the target.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "expect_state", "path": "meta.phase", "equals": 9 },
    { "act": "expect_state", "path": "meta.active_player", "equals": 2 },

    { "act": "execute_script",
      "script": "GameState.state.units[\"U_CHARGER_0\"].models[0].merge({\"position\": {\"x\": 971.2, \"y\": 740.0}}, true)" },
    { "act": "execute_script",
      "script": "GameState.state.units[\"U_CHARGER_0\"].models[1].merge({\"position\": {\"x\": 971.2, \"y\": 800.0}}, true)" },
    { "act": "execute_script",
      "script": "GameState.state.units[\"U_CHARGER_0\"].models[2].merge({\"position\": {\"x\": 971.2, \"y\": 860.0}}, true)" },
    { "act": "execute_script", "script": "main.update_unit_visuals(\"U_CHARGER_0\")" },
    { "act": "wait_for_tweens" },
    { "act": "wait_frames", "frames": 5 },
    { "act": "screenshot", "label": "01_setup_three_boyz_vs_shield_captain" },

    { "act": "dispatch_action", "action": {
      "type": "DECLARE_CHARGE",
      "actor_unit_id": "U_CHARGER_0",
      "payload": { "target_unit_ids": ["U_TARGET_SC"] }
    }},
    { "act": "expect_action_result", "path": "success", "equals": true },

    { "act": "dispatch_action", "action": {
      "type": "CHARGE_ROLL",
      "actor_unit_id": "U_CHARGER_0",
      "payload": { "rng_seed": 23 }
    }},
    { "act": "expect_action_result", "path": "success", "equals": true },

    { "act": "execute_script",
      "script": "get_tree().root.find_children(\"KeepRollButton\", \"\", true, false)[0].emit_signal(\"pressed\")" },
    { "act": "wait_frames", "frames": 6 },

    { "act": "execute_script",
      "script": "main.charge_controller.set(\"active_unit_id\", \"U_CHARGER_0\")" },
    { "act": "execute_script",
      "script": "main.charge_controller.set(\"selected_targets\", [\"U_TARGET_SC\"])" },
    { "act": "execute_script",
      "script": "main.charge_controller.awaiting_movement",
      "equals": true },
    { "act": "execute_script",
      "script": "main.charge_controller.charge_distance",
      "expect_min": 3 },
    { "act": "execute_script",
      "script": "main.charge_controller.models_to_move.size()",
      "equals": 3 },
    { "act": "execute_script",
      "script": "main.charge_controller.selected_models.size()",
      "equals": 0 },
    { "act": "wait_frames", "frames": 5 },
    { "act": "screenshot", "label": "02_roll_kept_movement_enabled" },

    { "act": "drag_board", "from_x": 1040, "from_y": 705, "to_x": 905, "to_y": 895, "steps": 10, "shift": true },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script",
      "script": "main.charge_controller.selected_models.size()",
      "equals": 3 },
    { "act": "execute_script",
      "script": "main.charge_controller.selection_indicators.size()",
      "equals": 3 },
    { "act": "execute_script",
      "script": "main.charge_controller.drag_box_active",
      "equals": false },
    { "act": "screenshot", "label": "03_shift_drag_box_selected_three_models" },

    { "act": "drag_board", "from_x": 971, "from_y": 800, "to_x": 371, "to_y": 800, "steps": 10 },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script",
      "script": "main.charge_controller.moved_models.size()",
      "equals": 0 },
    { "act": "execute_script",
      "script": "main.charge_controller.models_to_move.size()",
      "equals": 3 },
    { "act": "execute_script",
      "script": "main.charge_controller.selected_models.size()",
      "equals": 3 },
    { "act": "screenshot", "label": "04_overbudget_group_drag_rejected" },

    { "act": "drag_board", "from_x": 971, "from_y": 800, "to_x": 886, "to_y": 800, "steps": 10 },
    { "act": "wait_frames", "frames": 6 },
    { "act": "execute_script",
      "script": "main.charge_controller.moved_models.size()",
      "equals": 3 },
    { "act": "execute_script",
      "script": "main.charge_controller.models_to_move.size()",
      "equals": 0 },
    { "act": "execute_script",
      "script": "Vector2(GameState.state.units[\"U_CHARGER_0\"].models[0].position[\"x\"], GameState.state.units[\"U_CHARGER_0\"].models[0].position[\"y\"]).distance_to(Vector2(886.2, 740.0))",
      "expect_max": 8.0 },
    { "act": "execute_script",
      "script": "Vector2(GameState.state.units[\"U_CHARGER_0\"].models[1].position[\"x\"], GameState.state.units[\"U_CHARGER_0\"].models[1].position[\"y\"]).distance_to(Vector2(886.2, 800.0))",
      "expect_max": 8.0 },
    { "act": "execute_script",
      "script": "Vector2(GameState.state.units[\"U_CHARGER_0\"].models[2].position[\"x\"], GameState.state.units[\"U_CHARGER_0\"].models[2].position[\"y\"]).distance_to(Vector2(886.2, 860.0))",
      "expect_max": 8.0 },
    { "act": "execute_script",
      "script": "main.charge_controller._get_model_charge_accumulated(\"m1\")",
      "expect_min": 1.8, "expect_max": 2.5 },
    { "act": "execute_script",
      "script": "main.charge_controller._get_model_charge_accumulated(\"m3\")",
      "expect_min": 1.8, "expect_max": 2.5 },
    { "act": "screenshot", "label": "05_group_dragged_into_engagement" },

    { "act": "expect_node_property",
      "node": "/root/Main/HUD_Right/VBoxContainer/ChargeScrollContainer/ChargePanel/ChargeActionButtons/ConfirmRow/ConfirmChargeButton",
      "property": "disabled", "equals": false },
    { "act": "click_node",
      "node": "/root/Main/HUD_Right/VBoxContainer/ChargeScrollContainer/ChargePanel/ChargeActionButtons/ConfirmRow/ConfirmChargeButton",
      "emit_pressed": true },
    { "act": "wait_frames", "frames": 10 },

    { "act": "expect_state", "path": "units.U_CHARGER_0.flags.charged_this_turn", "equals": true },
    { "act": "execute_script",
      "script": "min_edge_distance_between_units(\"U_CHARGER_0\", \"U_TARGET_SC\")",
      "expect_max": 1.0 },
    { "act": "expect_token_visible", "unit_id": "U_CHARGER_0" },
    { "act": "screenshot", "label": "06_group_charge_confirmed" }
  ]
}
