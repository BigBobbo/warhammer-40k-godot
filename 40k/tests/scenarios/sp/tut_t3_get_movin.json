{
  "id": "tut_t3_get_movin",
  "covers": ["tutorial.t3.movement", "tutorial.t3.disembark", "tutorial.engine.strict_spotlight"],
  "rng_seed": 4242,
  "description": "Tutorial lesson T3 (Get Movin'), mouse+keyboard player path: menu -> picker -> lesson boots from tutorial_postdeploy -> disembark the Boyz+Warboss from the Battlewagon via the real row-click + ConfirmationDialog + 11 placement clicks inside the 3-inch ring -> Advance the Battlewagon through the mode radio + Confirm Movement Mode gate -> drag the hull, End This Unit's Move -> End Movement Phase under a strict spotlight -> summary, completion persisted, back to menu.",
  "steps": [
    { "act": "wait_seconds", "seconds": 1.5 },
    { "act": "click_node", "node": "/root/MainMenu/ScrollContainer/MenuContainer/ButtonSection/TutorialButton" },
    { "act": "expect_node_visible", "node": "/root/MainMenu/TutorialPicker", "timeout_s": 3.0 },
    { "act": "click_node", "node": "/root/MainMenu/TutorialPicker/Margin/VBox/LessonRows/Row_t3_get_movin/Play_t3_get_movin" },
    { "act": "wait_seconds", "seconds": 8.0 },
    { "act": "execute_script", "script": "TutorialManager.active", "equals": true },
    { "act": "execute_script", "script": "TutorialManager.current_step_id()", "equals": "intro" },
    { "act": "screenshot", "label": "01_intro" },

    { "act": "dispatch_action", "action": { "type": "END_MOVEMENT" } },
    { "act": "expect_action_result", "path": "tutorial_blocked", "equals": true },

    { "act": "click_node", "node": "/root/TutorialOverlay/InstructorCard/Margin/VBox/Footer/ContinueButton" },
    { "act": "wait_frames", "frames": 15 },
    { "act": "execute_script", "script": "TutorialManager.current_step_id()", "equals": "disembark_start" },

    { "act": "click_item_list", "node": "/root/Main/HUD_Right/VBoxContainer/MovementScrollContainer/MovementPanel/Section1_UnitList/MovementUnitList", "index": 1 },
    { "act": "wait_seconds", "seconds": 0.6 },
    { "act": "execute_script", "script": "var dd = tree.root.get_node_or_null(\"/root/DisembarkDialog\")\nif dd == null:\n\treturn false\ndd.get_ok_button().pressed.emit()\nreturn true", "multiline": true, "equals": true, "comment": "OK on the native ConfirmationDialog - its internal button has no scene path for click_node" },
    { "act": "wait_seconds", "seconds": 0.8 },
    { "act": "execute_script", "script": "TutorialManager.current_step_id()", "equals": "disembark_place" },
    { "act": "screenshot", "label": "02_placement_ring" },

    { "act": "click_board_at", "x": 480.0, "y": 500.0 },
    { "act": "click_board_at", "x": 544.0, "y": 500.0 },
    { "act": "click_board_at", "x": 608.0, "y": 500.0 },
    { "act": "click_board_at", "x": 672.0, "y": 500.0 },
    { "act": "click_board_at", "x": 736.0, "y": 500.0 },
    { "act": "click_board_at", "x": 808.0, "y": 500.0 },
    { "act": "click_board_at", "x": 512.0, "y": 556.0 },
    { "act": "click_board_at", "x": 576.0, "y": 556.0 },
    { "act": "click_board_at", "x": 640.0, "y": 556.0 },
    { "act": "click_board_at", "x": 704.0, "y": 556.0 },
    { "act": "click_board_at", "x": 780.0, "y": 552.0 },
    { "act": "wait_seconds", "seconds": 1.0 },
    { "act": "execute_script", "script": "TutorialManager.current_step_id()", "equals": "wagon_mode" },
    { "act": "expect_state", "path": "units.U_BOYZ_T.disembarked_this_phase", "equals": true },
    { "act": "screenshot", "label": "03_boyz_out" },

    { "act": "click_item_list", "node": "/root/Main/HUD_Right/VBoxContainer/MovementScrollContainer/MovementPanel/Section1_UnitList/MovementUnitList", "index": 0 },
    { "act": "wait_frames", "frames": 15 },
    { "act": "click_node", "button_text": "Advance" },
    { "act": "wait_frames", "frames": 10 },
    { "act": "click_node", "node": "/root/Main/HUD_Right/VBoxContainer/MovementScrollContainer/MovementPanel/Section3_ModeSelection/ConfirmModeButton" },
    { "act": "wait_seconds", "seconds": 1.0 },
    { "act": "execute_script", "script": "TutorialManager.current_step_id()", "equals": "keep_da_roll" },
    { "act": "screenshot", "label": "04a_command_reroll_offer" },
    { "act": "click_node", "button_text": "Keep Roll", "emit_pressed": true, "comment": "Keep Roll lives inside an embedded Window (AcceptDialog) - real-coordinate clicks into embedded windows are unreliable, the schema's emit_pressed escape hatch exists for this" },
    { "act": "wait_frames", "frames": 20 },
    { "act": "execute_script", "script": "TutorialManager.current_step_id()", "equals": "wagon_move" },
    { "act": "screenshot", "label": "04_advance_confirmed" },

    { "act": "drag_board", "from_x": 640.0, "from_y": 320.0, "to_x": 640.0, "to_y": 200.0 },
    { "act": "wait_frames", "frames": 20 },
    { "act": "execute_script", "script": "TutorialManager.current_step_id()", "equals": "wagon_confirm" },

    { "act": "click_node", "node": "/root/Main/HUD_Right/VBoxContainer/MovementScrollContainer/MovementPanel/Section4_Actions/ActionButtons/ConfirmMoveButton" },
    { "act": "wait_frames", "frames": 20 },
    { "act": "execute_script", "script": "TutorialManager.current_step_id()", "equals": "end_phase" },
    { "act": "screenshot", "label": "05_strict_spotlight_end_phase" },

    { "act": "click_node", "node": "/root/Main/PhaseActionButton" },
    { "act": "wait_seconds", "seconds": 1.5 },
    { "act": "expect_phase", "equals": 8 },
    { "act": "expect_node_visible", "node": "/root/TutorialOverlay/InstructorCard/Margin/VBox/Footer/BackToMenuButton", "timeout_s": 3.0 },
    { "act": "execute_script", "script": "TutorialManager.is_completed(\"t3_get_movin\")", "equals": true },
    { "act": "screenshot", "label": "06_summary" },

    { "act": "click_node", "node": "/root/TutorialOverlay/InstructorCard/Margin/VBox/Footer/BackToMenuButton" },
    { "act": "wait_seconds", "seconds": 3.0 },
    { "act": "expect_node_visible", "node": "/root/MainMenu/ScrollContainer", "timeout_s": 5.0 },
    { "act": "screenshot", "label": "07_back_at_menu" }
  ]
}
