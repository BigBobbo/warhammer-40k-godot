    { "act": "expect_state", "path": "meta.phase", "equals": 11 },
    { "act": "expect_state", "path": "meta.active_player", "equals": 2 },

    { "act": "execute_script",
      "script": "GameState.state[\"meta\"].merge({\"game_config\": {\"deployment\": \"search_and_destroy\", \"player1_disposition\": \"reconnaissance\", \"player2_disposition\": \"disruption\"}}, true)" },
    { "act": "execute_script", "script": "MissionManager.initialize_mission(\"take_and_hold\")" },
    { "act": "execute_script",
      "script": "MissionManager.get_primary_mission_for_player(2)[\"id\"]",
      "equals": "smoke_and_mirrors" },

    { "act": "execute_script", "script": "GameState.get_unit(\"U_CALADIUS_GRAV-TANK_E\")[\"models\"][0].merge({\"position\": {\"x\": 200.0, \"y\": 300.0}}, true)" },
    { "act": "execute_script", "script": "GameState.get_unit(\"U_CONTEMPTOR-ACHILLUS_DREADNOUGHT_H\")[\"models\"][0].merge({\"position\": {\"x\": 320.0, \"y\": 300.0}}, true)" },
    { "act": "execute_script", "script": "GameState.get_unit(\"U_WARBOSS_B\")[\"models\"][0].merge({\"position\": {\"x\": 880.0, \"y\": 1180.0}}, true)" },
    { "act": "execute_script", "script": "MissionManager.check_all_objectives()" },
    { "act": "execute_script",
      "script": "MissionManager.objective_control_state[\"obj_center\"]",
      "equals": 2 },
    { "act": "execute_script", "script": "MissionManager.on_turn_start_11e(2)" },
    { "act": "execute_script",
      "script": "MissionManager.get_pending_card_action_11e(2)[\"mode\"]",
      "equals": "multi" },
    { "act": "screenshot", "label": "01_before_end_turn" },

    { "act": "click_node", "node": "/root/Main/PhaseActionButton", "emit_pressed": true },
    { "act": "expect_node_visible", "node": "/root/CardActionDialog", "timeout_s": 3.0 },
    { "act": "expect_node_visible", "node": "/root/CardActionDialog/Content/Check_obj_center", "timeout_s": 2.0 },
    { "act": "expect_node_visible", "node": "/root/CardActionDialog/Content/Check_obj_nml_2", "timeout_s": 2.0 },
    { "act": "expect_node_property", "node": "/root/CardActionDialog/Content/Check_obj_center", "property": "button_pressed", "equals": true },
    { "act": "expect_node_property", "node": "/root/CardActionDialog/Content/Check_obj_nml_2", "property": "button_pressed", "equals": true },
    { "act": "screenshot", "label": "02_decoy_dialog_all_preselected" },

    { "act": "execute_script",
      "script": "main.get_tree().root.get_node(\"CardActionDialog/Content/Check_obj_nml_2\").set(\"button_pressed\", false)" },
    { "act": "expect_node_property", "node": "/root/CardActionDialog/Content/Check_obj_nml_2", "property": "button_pressed", "equals": false },
    { "act": "click_node", "node": "/root/CardActionDialog/Content/Actions/ConfirmCardAction", "emit_pressed": true },
    { "act": "wait_seconds", "seconds": 1.0 },

    { "act": "execute_script",
      "script": "\"obj_center\" in MissionManager._primary_state_11e[\"2\"][\"decoyed\"]",
      "equals": true },
    { "act": "execute_script",
      "script": "\"obj_center\" in MissionManager._primary_state_11e[\"2\"][\"decoyed_ever\"]",
      "equals": true },
    { "act": "execute_script",
      "script": "MissionManager._primary_state_11e[\"2\"][\"decoyed_ever\"].size()",
      "equals": 1 },
    { "act": "expect_state", "path": "players.2.primary_vp", "equals": 4 },
    { "act": "expect_state", "path": "meta.active_player", "equals": 1 },
    { "act": "screenshot", "label": "03_subset_decoyed_turn_ended" }
