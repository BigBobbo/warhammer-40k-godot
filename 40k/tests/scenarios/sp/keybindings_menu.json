{
  "id": "keybindings_menu",
  "covers": [
    "autoloads/KeybindingManager.gd",
    "scripts/SettingsMenu.gd",
    "scripts/Main.gd",
    "keybindings.menu_complete",
    "keybindings.rebind_mid_game"
  ],
  "fixture": "audit_baseline_postdeploy",
  "rng_seed": 42,
  "transition_to_phase": 7,
  "description": "Every player-facing keyboard shortcut is registered in KeybindingManager (so it appears in Settings -> Controls) and is dispatched via matches_action (so a mid-game rebind takes effect). Stage A: assert the newly-registered actions exist and the 7 categories are populated (>=70 bindings total). Stage B: open the in-game Settings menu, switch to the Controls tab, and assert every registered action has a rebind row; screenshot it. Stage C: prove a mid-game rebind is live -- the Army panel opens on its default key (U), then after rebinding toggle_army_panel to J the old key U no longer opens it while J does, then reset restores U.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.8 },
    { "act": "expect_state", "path": "meta.phase", "equals": 7 },

    { "act": "execute_script", "script": "KeybindingManager.reset_binding(\"toggle_army_panel\")" },

    { "act": "execute_script", "script": "KeybindingManager.bindings.size()", "expect_min": 70 },
    { "act": "execute_script", "script": "KeybindingManager.get_categories().size()", "equals": 7 },
    { "act": "execute_script", "script": "KeybindingManager.get_actions_in_category(\"Panels & Overlays\").size()", "expect_min": 13 },
    { "act": "execute_script", "script": "KeybindingManager.get_actions_in_category(\"Debug\").size()", "equals": 3 },
    { "act": "execute_script", "script": "KeybindingManager.get_actions_in_category(\"Replay Playback\").size()", "equals": 6 },

    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"toggle_army_panel\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"toggle_stratagem_panel\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"toggle_grid_overlay\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"toggle_vp_timeline\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"weapon_range_panel\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"datasheet_modal\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"toggle_chat_panel\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"toggle_roster_strip\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"fit_view_board\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"fit_view_selection\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"ruler_tool\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"threat_overlay\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"los_check\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"los_debug\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"toggle_visual_style\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"toggle_debug_mode\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"objective_check\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"toggle_dev_tools\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"ai_export_log\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"hotkey_help\")", "equals": true },
    { "act": "execute_script", "script": "KeybindingManager.bindings.has(\"replay_play_pause\")", "equals": true },

    { "act": "execute_script", "script": "main._open_settings_menu()" },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._settings_menu != null", "equals": true },
    { "act": "execute_script", "script": "main._settings_menu._on_tab_pressed(3)" },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._settings_menu._keybinding_buttons.size()", "expect_min": 70 },
    { "act": "screenshot", "label": "controls_tab_top_camera" },
    { "act": "execute_script", "script": "main._settings_menu._tab_containers[3].set(\"scroll_vertical\", 620)" },
    { "act": "wait_frames", "frames": 3 },
    { "act": "screenshot", "label": "controls_tab_mid_panels" },
    { "act": "execute_script", "script": "main._settings_menu._tab_containers[3].set(\"scroll_vertical\", 3000)" },
    { "act": "wait_frames", "frames": 3 },
    { "act": "screenshot", "label": "controls_tab_bottom_debug_replay" },
    { "act": "execute_script", "script": "main._settings_menu._on_close_pressed()" },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._settings_menu == null", "equals": true },

    { "act": "execute_script", "script": "main._army_panel == null", "equals": true },
    { "act": "simulate_key", "keycode": "U" },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._army_panel != null", "equals": true },
    { "act": "screenshot", "label": "army_panel_default_U" },
    { "act": "simulate_key", "keycode": "U" },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._army_panel == null", "equals": true },

    { "act": "execute_script", "script": "KeybindingManager.set_binding(\"toggle_army_panel\", OS.find_keycode_from_string(\"J\"))" },
    { "act": "execute_script", "script": "KeybindingManager.get_binding(\"toggle_army_panel\").key == OS.find_keycode_from_string(\"J\")", "equals": true },
    { "act": "simulate_key", "keycode": "U" },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._army_panel == null", "equals": true },
    { "act": "simulate_key", "keycode": "J" },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._army_panel != null", "equals": true },
    { "act": "screenshot", "label": "army_panel_rebound_J" },

    { "act": "execute_script", "script": "KeybindingManager.reset_binding(\"toggle_army_panel\")" },
    { "act": "execute_script", "script": "KeybindingManager.get_binding(\"toggle_army_panel\").key == OS.find_keycode_from_string(\"U\")", "equals": true },
    { "act": "simulate_key", "keycode": "U" },
    { "act": "wait_frames", "frames": 4 },
    { "act": "execute_script", "script": "main._army_panel == null", "equals": true }
  ]
}
