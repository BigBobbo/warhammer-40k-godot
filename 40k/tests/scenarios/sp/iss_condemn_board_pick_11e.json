{
  "id": "iss_condemn_board_pick_11e",
  "covers": [
    "rules.primary.punishment.condemn",
    "ui.command.condemn_board_pick_multi"
  ],
  "fixture": "audit_374_kunnin",
  "edition": 11,
  "rng_seed": 42,
  "disable_ai": true,
  "description": "11e Punishment 'Condemn' multi-select 'Pick on board': the checkbox picker offers a 'Pick on board' button that hides the dialog and lets the player toggle enemy units by clicking them on the battlefield (multi-select — stays armed until Done). Drives the REAL click path: arm the board pick, click two enemy tokens to toggle them, press Done, and assert exactly those two checkboxes are ticked and the un-clicked one is not.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.6 },
    { "act": "expect_state", "path": "meta.phase", "equals": 7 },

    { "act": "execute_script", "script": "SecondaryMissionManager.initialize_for_game()" },
    { "act": "execute_script", "script": "PhaseManager.transition_to_phase(6)" },
    { "act": "wait_seconds", "seconds": 0.8 },
    { "act": "expect_state", "path": "meta.phase", "equals": 6 },

    { "act": "expect_node_visible", "node": "/root/SecondaryMissionReviewDialog", "timeout_s": 5.0 },
    { "act": "click_node", "node": "/root/SecondaryMissionReviewDialog/OuterScroll/MainContainer/ButtonRow/DoneButton", "emit_pressed": true },
    { "act": "wait_seconds", "seconds": 0.3 },

    { "act": "execute_script",
      "script": "SceneRefs.main().get_node(\"CommandController\")._show_condemn_dialog({\"card_name\": \"Punishment\", \"description\": \"Condemn up to 3 enemy units.\", \"max_picks\": 3, \"current\": [], \"eligible\": [{\"id\": \"U_BLADE_CHAMPION_A\", \"label\": \"Blade Champion (1 models)\"}, {\"id\": \"U_CALADIUS_GRAV-TANK_E\", \"label\": \"Caladius Grav-tank (1 models)\"}, {\"id\": \"U_SHIELD_CAPTAIN_A\", \"label\": \"Shield-Captain (1 models)\"}]}, 2)" },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "expect_node_visible", "node": "/root/CondemnChoiceDialog", "timeout_s": 3.0 },
    { "act": "expect_node_visible", "node": "/root/CondemnChoiceDialog/Content/PickCondemnOnBoard", "timeout_s": 2.0 },

    { "act": "click_node", "node": "/root/CondemnChoiceDialog/Content/PickCondemnOnBoard", "emit_pressed": true },
    { "act": "wait_seconds", "seconds": 0.4 },

    { "act": "execute_script", "script": "get_tree().root.get_node(\"CondemnChoiceDialog\").visible", "equals": false },
    { "act": "expect_node_visible", "node": "/root/BoardPickBanner/BannerPanel/BannerRow/DoneBoardPick", "timeout_s": 2.0 },
    { "act": "screenshot", "label": "01_condemn_board_pick_armed" },

    { "act": "click_unit", "unit_id": "U_BLADE_CHAMPION_A" },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "click_unit", "unit_id": "U_SHIELD_CAPTAIN_A" },
    { "act": "wait_seconds", "seconds": 0.3 },

    { "act": "click_node", "node": "/root/BoardPickBanner/BannerPanel/BannerRow/DoneBoardPick", "emit_pressed": true },
    { "act": "wait_seconds", "seconds": 0.4 },

    { "act": "execute_script", "script": "get_tree().root.get_node(\"CondemnChoiceDialog\").visible", "equals": true },
    { "act": "execute_script", "script": "get_tree().root.get_node_or_null(\"BoardPickBanner\") == null", "equals": true },
    { "act": "execute_script", "script": "get_tree().root.get_node(\"CondemnChoiceDialog/Content/Check_U_BLADE_CHAMPION_A\").button_pressed", "equals": true },
    { "act": "execute_script", "script": "get_tree().root.get_node(\"CondemnChoiceDialog/Content/Check_U_SHIELD_CAPTAIN_A\").button_pressed", "equals": true },
    { "act": "execute_script", "script": "get_tree().root.get_node(\"CondemnChoiceDialog/Content/Check_U_CALADIUS_GRAV-TANK_E\").button_pressed", "equals": false },

    { "act": "screenshot", "label": "02_condemn_board_pick_applied" }
  ]
}
