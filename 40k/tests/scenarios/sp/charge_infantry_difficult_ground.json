{
  "id": "charge_infantry_difficult_ground",
  "covers": ["charge.terrain.difficult_ground_infantry_exempt", "charge.bug.difficult_ground_slows_infantry"],
  "fixture": "audit_372_charge_modifier",
  "edition": 11,
  "rng_seed": 42,
  "transition_to_phase": 9,
  "disable_ai": true,
  "description": "Regression for the user-reported charge bug (2026-07-16, Custodian Guard vs Lootas): INFANTRY charging while inside/through difficult_ground area ruins (how every converted 11e layout tags its big area pieces) was charged a flat 2\" per piece on top of the real drag distance — the UI showed e.g. 'Effective: 16.1\" (10.1\" - 6.0\" terrain)', small drags read as many inches, and valid drops were rejected ('Invalid position!'). The movement phase already exempted traversal-capable units from difficult ground; the charge phase did not. Setup: Warboss C (INFANTRY) starts inside three stacked tall difficult_ground ruins (pre-fix penalty 6.0\", matching the report) and drags a real 6.3\" path (drag_board through ChargeController._input) to base contact with Shield-Captain A. Pre-fix: effective 12.3\" exceeds even boxcars, the drop reverts, accumulated stays 0 and Confirm stays disabled. Post-fix: the drop lands, accumulated reads the raw 6.3\", the terrain-penalty label stays hidden, and the real Confirm button completes the charge.",
  "steps": [
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "expect_state", "path": "meta.phase", "equals": 9 },
    { "act": "expect_state", "path": "meta.active_player", "equals": 2 },

    { "act": "execute_script",
      "script": "GameState.state.units[\"U_WARBOSS_C\"].models[0].merge({\"position\": {\"x\": 1340.0, \"y\": 1300.0}, \"rotation\": 0.0}, true)" },
    { "act": "execute_script",
      "script": "GameState.state.units[\"U_SHIELD_CAPTAIN_A\"].models[0].merge({\"position\": {\"x\": 1655.0, \"y\": 1300.0}}, true)" },
    { "act": "execute_script",
      "script": "GameState.state.players[\"1\"].merge({\"cp\": 0}, true)" },
    { "act": "execute_script",
      "script": "GameState.state.players[\"2\"].merge({\"cp\": 0}, true)" },
    { "act": "execute_script", "script": "main.update_unit_visuals(\"U_WARBOSS_C\")" },
    { "act": "execute_script", "script": "main.update_unit_visuals(\"U_SHIELD_CAPTAIN_A\")" },
    { "act": "wait_for_tweens" },
    { "act": "wait_frames", "frames": 8 },

    { "act": "execute_script",
      "script": "TerrainManager.terrain_features.append({\"id\": \"dg_area_1\", \"type\": \"ruins\", \"polygon\": PackedVector2Array([Vector2(1290, 1240), Vector2(1420, 1240), Vector2(1420, 1360), Vector2(1290, 1360)]), \"height_category\": \"tall\", \"position\": Vector2(1355, 1300), \"size\": Vector2(130, 120), \"rotation\": 0.0, \"can_move_through\": {\"INFANTRY\": true, \"VEHICLE\": false, \"MONSTER\": false}, \"traits\": [\"obscuring\", \"difficult_ground\"]})" },
    { "act": "execute_script",
      "script": "TerrainManager.terrain_features.append({\"id\": \"dg_area_2\", \"type\": \"ruins\", \"polygon\": PackedVector2Array([Vector2(1300, 1250), Vector2(1440, 1250), Vector2(1440, 1370), Vector2(1300, 1370)]), \"height_category\": \"tall\", \"position\": Vector2(1370, 1310), \"size\": Vector2(140, 120), \"rotation\": 0.0, \"can_move_through\": {\"INFANTRY\": true, \"VEHICLE\": false, \"MONSTER\": false}, \"traits\": [\"obscuring\", \"difficult_ground\"]})" },
    { "act": "execute_script",
      "script": "TerrainManager.terrain_features.append({\"id\": \"dg_area_3\", \"type\": \"ruins\", \"polygon\": PackedVector2Array([Vector2(1310, 1230), Vector2(1460, 1230), Vector2(1460, 1350), Vector2(1310, 1350)]), \"height_category\": \"tall\", \"position\": Vector2(1385, 1290), \"size\": Vector2(150, 120), \"rotation\": 0.0, \"can_move_through\": {\"INFANTRY\": true, \"VEHICLE\": false, \"MONSTER\": false}, \"traits\": [\"obscuring\", \"difficult_ground\"]})" },

    { "act": "execute_script",
      "script": "TerrainManager.calculate_charge_terrain_penalty(Vector2(1340, 1300), Vector2(1592, 1300), false, [])",
      "expect_min": 6.0 },
    { "act": "execute_script",
      "script": "TerrainManager.calculate_charge_terrain_penalty(Vector2(1340, 1300), Vector2(1592, 1300), false, [\"VEHICLE\"])",
      "expect_min": 6.0 },
    { "act": "execute_script",
      "script": "TerrainManager.calculate_charge_terrain_penalty(Vector2(1340, 1300), Vector2(1592, 1300), false, [\"INFANTRY\"])",
      "equals": 0.0 },
    { "act": "execute_script",
      "script": "TerrainManager.calculate_movement_terrain_penalty(Vector2(1340, 1300), Vector2(1592, 1300), false, [\"INFANTRY\"])",
      "equals": 0.0 },
    { "act": "screenshot", "label": "01_warboss_inside_difficult_ground" },

    { "act": "dispatch_action", "action": {
      "type": "DECLARE_CHARGE",
      "actor_unit_id": "U_WARBOSS_C",
      "payload": { "target_unit_ids": ["U_SHIELD_CAPTAIN_A"] }
    }},
    { "act": "expect_action_result", "path": "success", "equals": true },

    { "act": "dispatch_action", "action": {
      "type": "CHARGE_ROLL",
      "actor_unit_id": "U_WARBOSS_C",
      "payload": { "rng_seed": 99 }
    }},
    { "act": "expect_action_result", "path": "success", "equals": true },

    { "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().has_pending_charge(\"U_WARBOSS_C\")",
      "equals": true },
    { "act": "execute_script",
      "script": "PhaseManager.get_current_phase_instance().get_charge_distance(\"U_WARBOSS_C\")",
      "expect_min": 7 },

    { "act": "execute_script",
      "script": "main.charge_controller.set(\"active_unit_id\", \"U_WARBOSS_C\")" },
    { "act": "execute_script",
      "script": "main.charge_controller.set(\"selected_targets\", [\"U_SHIELD_CAPTAIN_A\"])" },
    { "act": "execute_script",
      "script": "main.charge_controller.awaiting_movement",
      "equals": true },
    { "act": "execute_script",
      "script": "main.charge_controller.models_to_move.has(\"m1\")",
      "equals": true },

    { "act": "execute_script",
      "script": "main.charge_controller._calculate_terrain_penalty_for_path(Vector2(1340, 1300), Vector2(1580, 1300))",
      "equals": 0.0 },
    { "act": "wait_frames", "frames": 5 },
    { "act": "screenshot", "label": "02_roll_succeeded_movement_enabled" },

    { "act": "drag_board", "from_x": 1340, "from_y": 1300, "to_x": 1580, "to_y": 1300, "steps": 10 },
    { "act": "wait_frames", "frames": 6 },

    { "act": "execute_script",
      "script": "main.charge_controller.moved_models.has(\"m1\")",
      "equals": true },
    { "act": "execute_script",
      "script": "Vector2(GameState.state.units[\"U_WARBOSS_C\"].models[0].position[\"x\"], GameState.state.units[\"U_WARBOSS_C\"].models[0].position[\"y\"]).distance_to(Vector2(1586, 1300))",
      "expect_max": 20.0 },
    { "act": "execute_script",
      "script": "main.charge_controller._get_model_charge_accumulated(\"m1\")",
      "expect_min": 5.7, "expect_max": 6.7 },
    { "act": "execute_script",
      "script": "main.charge_controller.charge_terrain_label.visible",
      "equals": false },
    { "act": "screenshot", "label": "03_drop_accepted_no_phantom_inches" },

    { "act": "expect_node_property",
      "node": "/root/Main/HUD_Right/VBoxContainer/ChargeScrollContainer/ChargePanel/ChargeActionButtons/ConfirmRow/ConfirmChargeButton",
      "property": "disabled", "equals": false },
    { "act": "click_node",
      "node": "/root/Main/HUD_Right/VBoxContainer/ChargeScrollContainer/ChargePanel/ChargeActionButtons/ConfirmRow/ConfirmChargeButton",
      "emit_pressed": true },
    { "act": "wait_frames", "frames": 10 },

    { "act": "expect_state", "path": "units.U_WARBOSS_C.flags.charged_this_turn", "equals": true },
    { "act": "execute_script",
      "script": "min_edge_distance_between_units(\"U_WARBOSS_C\", \"U_SHIELD_CAPTAIN_A\")",
      "expect_max": 1.0 },
    { "act": "expect_token_visible", "unit_id": "U_WARBOSS_C" },
    { "act": "screenshot", "label": "04_charge_completed_through_difficult_ground" }
  ]
}
