    { "act": "execute_script", "script": "main._pad_phase_confirm.dialog_text", "equals": "End Charge Phase?" },
    { "act": "execute_script", "script": "main._pad_phase_confirm.hide()" },
    { "act": "wait_seconds", "seconds": 0.3 },

    { "act": "execute_script", "multiline": true, "script": "var m = tree.current_scene\nvar cc = m.charge_controller\ncc._refresh_ui()\nfor i in range(cc.unit_selector.item_count):\n\tif str(cc.unit_selector.get_item_metadata(i)) == \"U_BOYZ_E\":\n\t\tcc.unit_selector.select(i)\n\t\tcc.unit_selector.item_selected.emit(i)\n\t\tbreak\nreturn str(cc.active_unit_id)", "equals": "U_BOYZ_E" },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script", "script": "main.charge_controller.selected_targets.size()", "equals": 1 },
    { "act": "simulate_joy_button", "button_index": 6 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "main.charge_controller.awaiting_roll", "equals": true },
    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script", "script": "PadRouter.carry_active", "equals": false },
    { "act": "simulate_joy_button", "button_index": 6 },
    { "act": "wait_seconds", "seconds": 0.8 },
    { "act": "execute_script", "script": "main.charge_controller.awaiting_movement", "equals": true },

    { "act": "simulate_joy_button", "button_index": 0 },
