    { "act": "execute_script", "script": "GameState.state.units[\"U_BLADE_CHAMPION_A\"].models[0].merge({\"position\": {\"x\": 973.0, \"y\": 2150.0}}, true)" },
    { "act": "execute_script", "script": "GameState.state.units[\"U_SHIELD_CAPTAIN_A\"].models[0].merge({\"position\": {\"x\": 1240.0, \"y\": 2150.0}}, true)" },
    { "act": "execute_script", "multiline": true, "script": "var models = GameState.state.units[\"U_BOYZ_E\"].models\nvar placed = 0\nfor i in range(models.size()):\n\tif not models[i].get(\"alive\", true):\n\t\tcontinue\n\tvar col = placed % 5\n\tvar row = placed / 5\n\tmodels[i][\"position\"] = {\"x\": 880.0 + col * 46.0, \"y\": 2330.0 + row * 46.0}\n\tplaced += 1\nreturn placed", "expect_min": 1 },
    { "act": "execute_script", "script": "GameState.state.units[\"U_WARBOSS_B\"].models[0].merge({\"position\": {\"x\": 995.0, \"y\": 2470.0}}, true)" },
    { "act": "execute_script", "script": "GameState.state.players[\"1\"].merge({\"cp\": 0}, true)" },
    { "act": "execute_script", "script": "GameState.state.players[\"2\"].merge({\"cp\": 0}, true)" },
    { "act": "execute_script", "script": "main.charge_controller._refresh_ui()" },
    { "act": "execute_script", "script": "main.charge_controller.unit_selector.item_count", "expect_min": 2 },

    { "act": "simulate_joy_button", "button_index": 10 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script", "multiline": true, "script": "var m = tree.current_scene\nvar cc = m.charge_controller\nif str(cc.active_unit_id) != \"U_BATTLEWAGON_G\":\n\tfor i in range(cc.unit_selector.item_count):\n\t\tif str(cc.unit_selector.get_item_metadata(i)) == \"U_BATTLEWAGON_G\":\n\t\t\tcc.unit_selector.select(i)\n\t\t\tcc.unit_selector.item_selected.emit(i)\n\t\t\tbreak\nreturn str(cc.active_unit_id)", "equals": "U_BATTLEWAGON_G" },

    { "act": "execute_script", "multiline": true, "script": "var labels = []\nfor chip in PadHintBar._row.get_children():\n\tfor l in chip.find_children(\"*\", \"Label\", true, false):\n\t\tlabels.append(l.text)\nreturn \"End Phase\" in labels and not (\"Declare / Roll\" in labels)", "equals": true },

    { "act": "simulate_joy_button", "button_index": 0 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script", "script": "main.charge_controller.selected_targets.size()", "equals": 1 },
    { "act": "execute_script", "script": "main.charge_controller.pad_target_cursor", "equals": 0 },
    { "act": "execute_script", "script": "PadRouter.carry_active", "equals": false },
    { "act": "execute_script", "multiline": true, "script": "var labels = []\nfor chip in PadHintBar._row.get_children():\n\tfor l in chip.find_children(\"*\", \"Label\", true, false):\n\t\tlabels.append(l.text)\nreturn \"Declare Charge\" in labels", "equals": true },

    { "act": "simulate_joy_button", "button_index": 14 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main.charge_controller.pad_target_cursor", "equals": 1 },
    { "act": "execute_script", "script": "main.get_viewport().gui_get_focus_owner() == null", "equals": true },
    { "act": "simulate_joy_button", "button_index": 13 },
    { "act": "wait_seconds", "seconds": 0.3 },
    { "act": "execute_script", "script": "main.charge_controller.pad_target_cursor", "equals": 0 },
    { "act": "execute_script", "script": "main.get_viewport().gui_get_focus_owner() == null", "equals": true },
    { "act": "screenshot", "label": "01_dpad_steps_targets_no_focus_trap" },

    { "act": "simulate_joy_button", "button_index": 6 },
    { "act": "wait_seconds", "seconds": 0.5 },
    { "act": "execute_script", "script": "main.charge_controller.awaiting_roll", "equals": true },
    { "act": "execute_script", "multiline": true, "script": "var labels = []\nfor chip in PadHintBar._row.get_children():\n\tfor l in chip.find_children(\"*\", \"Label\", true, false):\n\t\tlabels.append(l.text)\nreturn \"Roll 2D6\" in labels", "equals": true },

    { "act": "simulate_joy_button", "button_index": 10 },
    { "act": "wait_seconds", "seconds": 0.4 },
    { "act": "execute_script", "script": "str(main.charge_controller.active_unit_id)", "equals": "U_BATTLEWAGON_G" },
