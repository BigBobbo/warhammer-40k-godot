    { "act": "execute_script", "script": "main.charge_controller.dragging_model != null", "equals": true },
    { "act": "screenshot", "label": "05_l3_swapped_carried_model" },
    { "act": "simulate_joy_button", "button_index": 1 },
    { "act": "wait_seconds", "seconds": 0.6 },
