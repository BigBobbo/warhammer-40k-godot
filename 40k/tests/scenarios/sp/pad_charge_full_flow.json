    { "act": "execute_script", "script": "PhaseManager.get_current_phase_instance().get_completed_charges().has(\"U_BATTLEWAGON_G\")", "equals": true },
    { "act": "expect_state", "path": "meta.phase", "equals": 9 },
    { "act": "screenshot", "label": "04_start_confirmed_charge_complete" },

    { "act": "simulate_joy_button", "button_index": 6 },
    { "act": "wait_seconds", "seconds": 0.4 },
