    { "act": "execute_script", "multiline": true, "script": "var labels = []\nfor chip in PadHintBar._row.get_children():\n\tfor l in chip.find_children(\"*\", \"Label\", true, false):\n\t\tlabels.append(l.text)\nreturn \"Confirm Charge\" in labels and \"Snap to Contact\" in labels", "equals": true },

    { "act": "simulate_joy_button", "button_index": 6 },
    { "act": "wait_seconds", "seconds": 0.4 },
