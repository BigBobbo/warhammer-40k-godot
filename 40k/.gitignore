# Godot 4+ specific ignores
.godot/
/android/

# Local development config (contains local server URL)
server_config.local.json

# Export builds
exports/

# Wahapedia data exports — kept locally, not committed
data/*.csv
data/*.csv.import

# Tier B review HTML — generated locally from .llm/todo.md + per-task
# screenshots by 40k/tests/tools/generate_review_html.py; reproducible,
# so not committed. Covers single-file and --chunks N output.
test_results/design_guidelines/review.html
test_results/design_guidelines/review-*of*.html

# Per-invocation telemetry — gets rewritten on every godot run. Was
# tracked historically; untracking + ignoring stops it from dirtying
# the tree on every scenario invocation.
test_results/test_commands/args_log.txt
